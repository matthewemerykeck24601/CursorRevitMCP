<Window x:Class="EDGE.InsulationTools.InsulationDrawing.Views.InsulationDrawingPerPieceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:EDGE.InsulationTools.InsulationDrawing"
        Closing="Window_Closing" Title="Insulation Drawing - Assembly" SizeToContent="Height"
        MaxHeight="525" Width="350" ResizeMode="NoResize" MinHeight="500" MinWidth="350"
        Background="LightGray">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="5"/>
      <ColumnDefinition Width="325"/>
      <ColumnDefinition Width="5"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="5"/>
      <RowDefinition Height="30"/>
      <RowDefinition Height="325"/>
      <RowDefinition Height="auto"/>
    </Grid.RowDefinitions>
    <Grid Row="1" Column="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="320"/>
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="5"/>
        <RowDefinition Height="auto"/>
        <RowDefinition Height="5"/>
      </Grid.RowDefinitions>
      <Label Grid.Row="1" Grid.Column="1" Content="Select Assembly Sheets" FontSize="14"/>
    </Grid>
    <DataGrid Name="PerPieceDataGrid" Grid.Row="2" Grid.Column="1" AutoGenerateColumns="false"
              CanUserResizeColumns="true" CanUserAddRows="false" CanUserReorderColumns="false" Margin="5"
              ItemsSource="{Binding InsulationDrawingPerPieceObject}">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Assembly Name" IsReadOnly="true" CanUserSort="false" Width=".333333*"
                            Binding="{Binding Path=AssemblyName}">
          <DataGridBoundColumn.ElementStyle>
            <Style TargetType="{x:Type TextBlock}">
              <Style.Triggers>
                <DataTrigger Binding="{Binding ContainsUnmarked}" Value="True">
                  <Setter Property="TextBlock.Foreground" Value="Red"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </DataGridBoundColumn.ElementStyle>
        </DataGridTextColumn>
        <DataGridTemplateColumn Header="Sheets" Width=".666666*">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <ComboBox ItemsSource="{Binding SheetList}"
                        SelectedValue="{Binding SheetName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
      </DataGrid.Columns>
    </DataGrid>
    <Grid Row="3" Column="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="5"/>
        <ColumnDefinition Width="*" MinWidth="130"/>
        <ColumnDefinition Width="*" MaxWidth="340"/>
        <ColumnDefinition Width="5"/>
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="5"/>
        <RowDefinition Height="auto"/>
        <RowDefinition Height="auto"/>
        <RowDefinition Height="auto"/>
        <RowDefinition Height="5"/>
      </Grid.RowDefinitions>
      <Label Grid.Column="1" Grid.Row="2" Content="Scale" FontSize="14" Margin="10,0,5,10"
             VerticalAlignment="Center"/>
      <ComboBox Name="ScalesComboBox" Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="2" Margin="70,0,10,10"
                VerticalAlignment="Center" Height="22"/>
      <TextBlock Name="UnmarkedMessage" Grid.ColumnSpan="2" Grid.Column="1" Grid.Row="1" FontSize="12"
                 Margin="10,0,0,10" TextWrapping="Wrap" TextAlignment="Center" Foreground="Red"
                 Visibility="Collapsed">
        * Assembly contains insulation that is not marked and will not be detailed.
      </TextBlock>
      <Button Click="btnDrawInsulation_Click" Name="btnDrawInsulation" Grid.Row="3" Grid.Column="1"
              Content="Draw Insulation" FontSize="14" Height="25" Margin="10,5,5,10"/>
      <Button Click="btnCancel_Click" Name="btnCancel" Grid.Row="3" Grid.Column="2" Content="Cancel"
              FontSize="14" Height="25" Margin="10,5,5,10"/>
    </Grid>
  </Grid>
</Window>