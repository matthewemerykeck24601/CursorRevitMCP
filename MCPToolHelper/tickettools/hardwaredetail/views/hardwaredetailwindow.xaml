<Window x:Class="EDGE.TicketTools.HardwareDetail.Views.HardwareDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:EDGE.TicketTools.HardwareDetail.Views"
        Closing="Window_Closing" Title="Hardware Detail" Height="315" Width="450" Background="LightGray"
        ResizeMode="NoResize">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="0.025*"/>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="0.025*"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="5"/>
      <RowDefinition Height="55"/>
      <RowDefinition Height="55"/>
      <RowDefinition Height="35"/>
      <RowDefinition Height="35"/>
      <RowDefinition Height="55"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="5"/>
    </Grid.RowDefinitions>
    <Grid Row="1" Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="*"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      <Label Name="templateManufactureLabel" Grid.Row="0" Content="Template Manufacturer" Margin="0,-3,0,0"/>
      <ComboBox SelectionChanged="manufactureListComboBox_SelectionChanged" Name="manufactureListComboBox"
                Grid.Row="2" Height="25" Margin="5,0,5,2" DisplayMemberPath="ValueString"
                SelectedValuePath="ValueString" IsEnabled="false" ItemsSource="{Binding ManufacturerList}"
                SelectedValue="{Binding ManufacturerString}"/>
    </Grid>
    <Grid Row="2" Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="*"/>
        <RowDefinition Height="30"/>
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="100"/>
      </Grid.ColumnDefinitions>
      <Label Name="templateLabel" Grid.Row="0" Content="Template" Margin="0,-3,0,0"/>
      <ComboBox SelectionChanged="templateListComboBox_SelectionChanged" Name="templateListComboBox" Grid.Row="2"
                Height="25" Margin="5,0,5,2" DisplayMemberPath="ValueString" SelectedValuePath="ValueString"
                IsEnabled="false" ItemsSource="{Binding TemplateList}" SelectedValue="{Binding TemplateString}"/>
      <Button Click="selectMultipleButton_Click" Name="selectMultipleButton" Grid.Row="1" Grid.Column="1"
              Content="Select Multiple" Height="25" Margin="2,0,5,2"/>
    </Grid>
    <Grid Row="3" Column="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="70"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <Label Name="scaleLabel" Grid.Column="0" Content="Scale" VerticalAlignment="Center"/>
      <ComboBox Name="scaleComboBox" Grid.Column="1" Height="25" VerticalAlignment="Center" Margin="0,0,5,0"
                DisplayMemberPath="ValueString" SelectedValuePath="ValueString" IsEnabled="false"
                ItemsSource="{Binding ScaleList}" SelectedValue="{Binding ScaleString}"/>
    </Grid>
    <Grid Row="4" Column="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="70"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <Label Name="titleBlockLabel" Grid.Column="0" Content="Titleblock" VerticalAlignment="Center"/>
      <ComboBox Name="titleBlockComboBox" Grid.Column="1" Height="25" VerticalAlignment="Center" Margin="0,0,5,0"
                DisplayMemberPath="ValueString" SelectedValuePath="ValueString" IsEnabled="false"
                ItemsSource="{Binding TitleBlockList}" SelectedValue="{Binding TitleBlockString}"/>
    </Grid>
    <Grid Row="5" Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="*"/>
        <RowDefinition Height="30"/>
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="100"/>
      </Grid.ColumnDefinitions>
      <Label Name="copyLabel" Grid.Row="0" Content="Copy Sheet Elements" Margin="0,-3,0,0"/>
      <ComboBox Name="copySourceComboBox" Grid.Row="2" Height="25" Margin="5,0,5,2" DisplayMemberPath="ValueString"
                SelectedValuePath="ValueString" IsEnabled="false" ItemsSource="{Binding CopyList}"
                SelectedValue="{Binding CopyString}"/>
      <Button Click="clearButton_Click" Name="clearButton" Grid.Row="1" Grid.Column="1" Content="Clear"
              IsEnabled="false" Height="23" Margin="2,0,5,2"/>
    </Grid>
    <Grid Row="6" Column="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="100"/>
        <ColumnDefinition Width="100"/>
      </Grid.ColumnDefinitions>
      <Button Click="populateButton_Click" Name="populateButton" Grid.Column="1" Content="Populate" Height="20"
              Margin="2,0,5,0"/>
      <Button Click="cancelButton_Click" Name="cancelButton" Grid.Column="2" Content="Cancel" Height="20"
              Margin="2,0,5,0"/>
    </Grid>
  </Grid>
</Window>