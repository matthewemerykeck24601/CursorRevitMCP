<Window x:Class="EDGE.AssemblyTools.MarkVerification.InitialPresentation.MKVerificationResult_Initial"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:EDGE.AssemblyTools.MarkVerification.InitialPresentation"
        Activated="App_Activated" Height="430" Width="630" MinWidth="630" MinHeight="430"
        Title="Mark Verification Initial Result" WindowStartupLocation="CenterScreen">
  <FrameworkElement.Resources>
    <local:InitialRotateImagePathConverter x:Key="InitialRotateImagePathConverter"/>
    <local:ExclamationConverters x:Key="ExclamationConverters"/>
    <local:OrangeExclamationConverters x:Key="OrangeExclamationConverters"/>
    <local:CountMultiplierImagePathConverter x:Key="CountMultiplierImagePathConverter"/>
    <local:VisibilityConverter x:Key="VisibilityConverter"/>
  </FrameworkElement.Resources>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="7*"/>
      <RowDefinition Height="1*"/>
    </Grid.RowDefinitions>
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="3*"/>
        <ColumnDefinition Width="6*"/>
      </Grid.ColumnDefinitions>
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="139*"/>
          <RowDefinition Height="36*"/>
        </Grid.RowDefinitions>
        <ListBox SelectionChanged="lstResults_SelectionChanged"
                 PreviewMouseLeftButtonDown="lstResults_PreviewMouseLeftButtonDown" Name="lstResults"
                 Margin="7,7,7,3.4" HorizontalContentAlignment="Stretch" HorizontalAlignment="Stretch">
          <ItemsControl.ItemContainerStyle>
            <Style>
              <Setter Property="Control.Padding" Value="0"/>
              <Style.Triggers>
                <Trigger Property="ListBoxItem.IsSelected" Value="true">
                  <Setter Property="Control.BorderThickness" Value="4"/>
                </Trigger>
              </Style.Triggers>
            </Style>
          </ItemsControl.ItemContainerStyle>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Grid>
                <Border Margin="3" Padding="2" BorderBrush="Black" BorderThickness="1">
                  <Grid>
                    <Grid.RowDefinitions>
                      <RowDefinition/>
                      <RowDefinition/>
                      <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" FontWeight="Bold" HorizontalAlignment="Stretch" Grid.ColumnSpan="3"
                               Text="{Binding Path=Bucket}"/>
                    <TextBlock Grid.Row="1" HorizontalAlignment="Stretch" Grid.ColumnSpan="3" Text="{Binding Path=Count}"/>
                    <Image Grid.Row="2" Grid.Column="1" Height="18" Width="18" HorizontalAlignment="Left" Margin="4,0,0,0"
                           Source="{Binding Path=InitialPlateRotated, Converter={StaticResource InitialRotateImagePathConverter}}"
                           Visibility="{Binding Path=PlateRotated, Converter={StaticResource VisibilityConverter}}"/>
                    <Image Grid.Row="2" Grid.Column="2" Height="18" Width="18" HorizontalAlignment="Left" Margin="4,0,0,0"
                           Source="{Binding Path=UseCountMultiplier, Converter={StaticResource CountMultiplierImagePathConverter}}"
                           Visibility="{Binding Path=UseCountMultiplier, Converter={StaticResource VisibilityConverter}}"/>
                  </Grid>
                </Border>
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ListBox>
        <TextBlock Grid.Row="3" Margin="32,7.2,7,36.8" FontSize="11" TextWrapping="WrapWithOverflow">
          - ignored embed and precast rotation
        </TextBlock>
        <Image Grid.Row="3" Height="16" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,7.2,0,0"
               Width="16" Source="{Binding Converter={StaticResource ExclamationConverters}}"/>
        <TextBlock Grid.Row="3" Margin="32,34,7,0" FontSize="11" TextWrapping="WrapWithOverflow">
          - ignored embeds configured to multiply for marks
        </TextBlock>
        <Image Grid.Row="3" Height="16" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,34,0,0"
               Width="16" Source="{Binding Converter={StaticResource OrangeExclamationConverters}}"/>
      </Grid>
      <Border Name="deatilBorder" Grid.Column="1" BorderThickness="1" BorderBrush="Black" Margin="0 0 3 0"
              Background="Ivory" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Visibility="Hidden">
        <Grid Name="detailPanel" Column="1" Visibility="Hidden"
              DataContext="{Binding ElementName=lstResults, Path=SelectedItem}">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160*"/>
            <ColumnDefinition Width="150*"/>
            <ColumnDefinition Width="80*"/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="35*"/>
            <RowDefinition Height="35*"/>
            <RowDefinition Height="260*"/>
          </Grid.RowDefinitions>
          <TextBlock HorizontalAlignment="Stretch" VerticalAlignment="Center" Grid.ColumnSpan="2" Margin="10,0,0,0.4">New Control Mark</TextBlock>
          <TextBox TextChanged="TextBox_TextChanged" x:Name="MarkNumberBox" Grid.Column="1"
                   HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
          <Button Click="SaveButton_Click" Name="btnSave" Grid.Column="2" HorizontalAlignment="Center"
                  VerticalAlignment="Center" Width="48" Height="20">Save</Button>
          <TextBlock Grid.Row="1" Margin="10,4.6,4.8,4.8" VerticalAlignment="Center">
            Elements inside the bucket:
          </TextBlock>
          <ListBox SelectionChanged="lstTestResults_SelectionChanged" Name="lstTestResults" Grid.Row="2"
                   Grid.Column="0" Grid.ColumnSpan="3" HorizontalContentAlignment="Stretch" Margin="10,0,10,10"
                   ItemsSource="{Binding DetailedResults}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                  <Border Margin="3" BorderThickness="1" BorderBrush="Blue">
                    <Grid Margin="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                      <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                      </Grid.RowDefinitions>
                      <TextBlock FontWeight="Bold" Grid.Row="0" ToolTip="Element Control Number(Element Id)"
                                 Text="{Binding Path=controlNumberandID}"/>
                      <TextBlock Grid.Row="1" ToolTip="Element Name" Text="{Binding Path=Name}"/>
                      <TextBlock Grid.Row="3" ToolTip="Element Construction Product" Text="{Binding Path=ConstructionProduct}"/>
                    </Grid>
                  </Border>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>
    </Grid>
    <Grid Row="1">
      <Button Click="ApplyButton_Click" Name="btnApply" BorderBrush="Black" VerticalAlignment="Center"
              HorizontalAlignment="Center" Width="65" Height="24" Margin="10">Apply</Button>
      <Button Click="btnExport_Click" Name="btnExport" BorderBrush="Black" VerticalAlignment="Bottom"
              HorizontalAlignment="Right" Width="65" Height="24" Margin="10">Export</Button>
    </Grid>
  </Grid>
</Window>