<Window x:Class="EDGE.AssemblyTools.MarkVerification.UserSettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:EDGE.AssemblyTools.MarkVerification"
        Title="Initial Mark Verification Prefix Settings" Height="500" Width="500"
        WindowStartupLocation="CenterOwner" MinWidth="480" MinHeight="225">
  <FrameworkElement.Resources>
    <local:ImageConverters x:Key="ImageConverters"/>
  </FrameworkElement.Resources>
  <Border Grid.Column="1" Padding="7" Margin="8">
    <ScrollViewer VerticalScrollBarVisibility="Visible">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Image Grid.Row="0" HorizontalAlignment="Left" Width="120" Height="60" Margin="10,0,0,0.8"
               Source="{Binding Converter={StaticResource ImageConverters}}"/>
        <TextBox Name="NewProductName" Grid.Row="1" Width="174" VerticalAlignment="Bottom" Margin="25,0,0,5"
                 HorizontalAlignment="Left" Height="20">
          <FrameworkElement.Style>
            <Style xmlns:sys="clr-namespace:System;assembly=mscorlib"
                   TargetType="{x:Type TextBox}">
              <Style.Resources>
                <VisualBrush x:Key="CueBannerBrush" AlignmentX="Left" AlignmentY="Center" Stretch="None">
                  <VisualBrush.Visual>
                    <Label Content="Enter New Product Name" Foreground="Gray"/>
                  </VisualBrush.Visual>
                </VisualBrush>
              </Style.Resources>
              <Style.Triggers>
                <Trigger Property="TextBox.Text" Value="{x:Static sys:String.Empty}">
                  <Setter Property="Control.Background" Value="{StaticResource CueBannerBrush}"/>
                </Trigger>
                <Trigger Property="TextBox.Text" Value="{x:Null}">
                  <Setter Property="Control.Background" Value="{StaticResource CueBannerBrush}"/>
                </Trigger>
                <Trigger Property="UIElement.IsKeyboardFocused" Value="true">
                  <Setter Property="Control.Background" Value="White"/>
                </Trigger>
              </Style.Triggers>
            </Style>
          </FrameworkElement.Style>
        </TextBox>
        <Button Click="AddNewButton_Click" Name="AddNewAdmin" Grid.Row="1" Width="60" Margin="244,0,0,5"
                HorizontalAlignment="Left" VerticalAlignment="Bottom" Content="Add"/>
        <Button Click="DeleteButton_Click" Name="DeleteAdmin" Grid.Row="1" Width="60" Visibility="Hidden"
                Margin="365,20.6,0,5" HorizontalAlignment="Left">Delete</Button>
        <DataGrid SelectionChanged="Mark_Prefix_List_SelectionChanged" Name="Mark_Prefix_List" Width="400"
                  AutoGenerateColumns="false" CanUserAddRows="false" Margin="25,0,0,0" HorizontalAlignment="Left"
                  Grid.Row="2">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Product Name" IsReadOnly="true" Width="6*" Binding="{Binding productName}"/>
            <DataGridTextColumn Header="Mark Prefix" IsReadOnly="false" Width="5*" Binding="{Binding markPrefix}"/>
          </DataGrid.Columns>
        </DataGrid>
        <Button Click="CancelButton_Click" Margin="260,8.6,0,1" HorizontalAlignment="Left" Grid.Row="3"
                Content="Cancel" Width="75"/>
        <Button Click="SaveButton_Click" Margin="105,8.6,0,1" HorizontalAlignment="Left" Grid.Row="3"
                Content="Save" Width="75"/>
      </Grid>
    </ScrollViewer>
  </Border>
</Window>