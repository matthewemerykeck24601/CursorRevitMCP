<Window x:Class="EDGE.AdminTools.CAM.LaserProjectionUI.CADExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:EDGE.AdminTools.CAM.LaserProjectionUI"
        xmlns:Validation="clr-namespace:EDGE.UserSettingTools.CAD_Export_Settings"
        Height="325" Width="500" MinHeight="325" MinWidth="500" Background="LightGray"
        ResizeMode="NoResize">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="5"/>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="5"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="5"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*" MaxHeight="25"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*" MaxHeight="25"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*" MaxHeight="25"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*" MaxHeight="25"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="5"/>
    </Grid.RowDefinitions>
    <Grid Row="1" Column="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="50"/>
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <Label Grid.Row="0" Grid.Column="0" Content="Export Folder Path:"/>
      <TextBox x:Name="ExportFolderPathTextBox" Grid.Row="1" Grid.Column="0" Height="22" Margin="5,0,5,0">
        <Binding Path="ExportFolderPathString">
          <Binding.ValidationRules>
            <Validation:FolderPathRule EmptyAllowed="false"/>
          </Binding.ValidationRules>
        </Binding>
        <FrameworkElement.Style>
          <Style TargetType="{x:Type TextBox}">
            <Style.Triggers>
              <Trigger Property="Validation.HasError" Value="true">
                <Setter Property="Control.BorderBrush" Value="Red"/>
              </Trigger>
            </Style.Triggers>
          </Style>
        </FrameworkElement.Style>
      </TextBox>
      <Button Click="FolderExplorerButton_Click" x:Name="FolderExplorerButton" Grid.Row="1" Grid.Column="1"
              Content="..." Height="22" Width="45"/>
    </Grid>
    <Grid Row="3" Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <Label Grid.Row="0" Content="File Name Suffix:"/>
      <TextBox x:Name="FileNameSuffixTextBox" Grid.Row="1" Height="22" Margin="5,0,2.5,0">
        <Binding Path="FileNameSuffixString">
          <Binding.ValidationRules>
            <Validation:FileSuffixRule EmptyAllowed="false"/>
          </Binding.ValidationRules>
        </Binding>
        <FrameworkElement.Style>
          <Style TargetType="{x:Type TextBox}">
            <Style.Triggers>
              <Trigger Property="Validation.HasError" Value="true">
                <Setter Property="Control.BorderBrush" Value="Red"/>
              </Trigger>
            </Style.Triggers>
          </Style>
        </FrameworkElement.Style>
      </TextBox>
    </Grid>
    <Grid Row="5" Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <Label Grid.Row="0" Content="Export File Format: "/>
      <Grid Row="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="20"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <CheckBox x:Name="DWGCheckBox" Grid.Column="0" Content="DWG" Margin="5,0,0,0"
                  IsChecked="{Binding DWGChecked}">
          <FrameworkElement.Style>
            <Style TargetType="{x:Type CheckBox}">
              <Style.Triggers>
                <DataTrigger Binding="{Binding BothUnchecked}" Value="True">
                  <Setter Property="Control.BorderBrush" Value="Red"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </FrameworkElement.Style>
        </CheckBox>
        <CheckBox x:Name="DFXChekBox" Grid.Column="2" Content="DXF" IsChecked="{Binding DXFChecked}">
          <FrameworkElement.Style>
            <Style TargetType="{x:Type CheckBox}">
              <Style.Triggers>
                <DataTrigger Binding="{Binding BothUnchecked}" Value="True">
                  <Setter Property="Control.BorderBrush" Value="Red"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </FrameworkElement.Style>
        </CheckBox>
      </Grid>
    </Grid>
    <Grid Row="7" Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <Label Grid.Row="0" Content="Example File Path:"/>
      <TextBlock x:Name="ExampleFilePathLabel" Grid.Row="1" TextWrapping="WrapWithOverflow" Margin="5,0,0,0"
                 Text="{Binding ExampleFilePathString}"/>
    </Grid>
    <Label x:Name="FileOverwriteWarningLable" Grid.Row="8" Grid.Column="1"
           Content="*The settings above will overwrite one or more existing files." Foreground="Red">
      <FrameworkElement.Style>
        <Style TargetType="{x:Type Label}">
          <Style.Triggers>
            <DataTrigger Binding="{Binding OverwriteWarning, UpdateSourceTrigger=PropertyChanged}" Value="True">
              <Setter Property="UIElement.Visibility" Value="Visible"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding OverwriteWarning, UpdateSourceTrigger=PropertyChanged}" Value="False">
              <Setter Property="UIElement.Visibility" Value="Collapsed"/>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </FrameworkElement.Style>
    </Label>
    <Grid Row="10" Column="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="1.5*"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <Button Click="ResetButton_Click" x:Name="ResetButton" Grid.Column="0" Content="Reset Settings" Height="22"
              VerticalAlignment="Bottom" Margin="5,0,5,14"/>
      <Button Click="ExportButton_Click" x:Name="ExportButton" Grid.Column="2" Content="Export" Height="22"
              VerticalAlignment="Bottom" Margin="5,0,5,14"/>
      <Button Click="CancelButton_Click" x:Name="CancelButton" Grid.Column="3" Content="Cancel" Height="22"
              VerticalAlignment="Bottom" Margin="5,0,5,14"/>
    </Grid>
  </Grid>
</Window>