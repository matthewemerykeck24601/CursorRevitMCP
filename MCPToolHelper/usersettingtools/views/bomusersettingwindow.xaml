<Window x:Class="EDGE.UserSettingTools.Views.BOMUserSettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        Title="Ticket BOM User Settings" Height="500" Width="480" WindowStartupLocation="CenterOwner"
        MinWidth="480" MaxWidth="480" MinHeight="450" ResizeMode="CanResize">
  <FrameworkElement.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/EDGEforREVIT;component/EDGELogo.xaml"/>
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </FrameworkElement.Resources>
  <Grid Margin="15">
    <Grid.RowDefinitions>
      <RowDefinition Height="66"/>
      <RowDefinition Height="80"/>
      <RowDefinition Height="40"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="40"/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition/>
      <ColumnDefinition/>
    </Grid.ColumnDefinitions>
    <ContentControl Template="{StaticResource EDGELogoStyle}" Grid.ColumnSpan="2" HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch" Height="60"/>
    <Button Click="AddRow_Click" Name="AddRow" Width="100" Grid.Row="2" Margin="5" HorizontalAlignment="Center"
            VerticalAlignment="Top" Content="Add Row"/>
    <Button Click="DeleteButton_Click" Name="Delete" Width="100" Grid.Row="2" Grid.Column="1"
            Visibility="Visible" IsEnabled="false" Margin="5" HorizontalAlignment="Center"
            VerticalAlignment="Top">Delete Row</Button>
    <DataGrid SelectionChanged="Ticket_BOM_List_SelectionChanged" Name="Ticket_BOM_List" Grid.ColumnSpan="2"
              VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
              HorizontalAlignment="Center" Grid.Row="3" AutoGenerateColumns="false" CanUserAddRows="false">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Template Schedule" IsReadOnly="false" Width="6*" Binding="{Binding templateSchedule}"/>
        <DataGridTextColumn Header="Assembly Schedule Suffix" IsReadOnly="false" Width="6*" Binding="{Binding scheduleSuffix}"/>
      </DataGrid.Columns>
    </DataGrid>
    <Button Click="SaveButton_Click" Grid.Column="0" Margin="5" HorizontalAlignment="Center"
            VerticalAlignment="Bottom" Grid.Row="4" Content="Save" Width="100"/>
    <Button Click="CancelButton_Click" Grid.Column="1" Margin="5" HorizontalAlignment="Center"
            VerticalAlignment="Bottom" Grid.Row="4" Content="Cancel" Width="100"/>
    <TextBlock Grid.ColumnSpan="2" Grid.Row="1" Margin="10"
               Text="*Note: please leave the Assembly Schedule Suffix column blank if the schedule you defined is a note type. (Which means if the suffix column is blank we'll consider the schedule as a note type and will place it as note.)"
               TextWrapping="Wrap"/>
  </Grid>
</Window>