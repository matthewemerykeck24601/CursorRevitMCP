<Window x:Class="EDGE.TicketTools.CheckFlagger.CheckWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:EDGE.TicketTools.CheckFlagger"
        MouseDown="Window_MouseDown" SizeToContent="WidthAndHeight" ResizeMode="NoResize"
        WindowStyle="None">
  <Border BorderThickness="1" BorderBrush="Black">
    <Grid MinWidth="350">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <Grid Row="0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Label Name="TitleLbl" HorizontalAlignment="Center" Margin="10" Grid.Column="1" FontSize="14">
          Ticket Checking: Assembly Name
        </Label>
        <Button Click="LeftArrowBtn_Click" Name="LeftArrowBtn" Visibility="Visible" FontFamily="Marlett"
                Content="3" Padding="5" Margin="10,0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <Button Click="RightArrowBtn_Click" Name="RightArrowBtn" Visibility="Visible" FontFamily="Marlett"
                Grid.Column="2" Content="4" Padding="5" Margin="10,0" HorizontalAlignment="Center"
                VerticalAlignment="Center"/>
      </Grid>
      <Grid Name="CheckAllGrid" Row="1" Visibility="Visible" Margin="2">
        <Grid.ColumnDefinitions>
          <ColumnDefinition/>
          <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Button Click="EngChkAllBtn_Click" Name="EngChkAllBtn" Grid.Column="0" Padding="5,2" Margin="5">
          Engineering Check All
        </Button>
        <Button Click="DraftChkAllBtn_Click" Name="DraftChkAllBtn" Grid.Column="1" Padding="5,2" Margin="5">Drafting Check All</Button>
        <Button Click="NeedsRevAll_Click" Name="NeedsRevAll" Grid.Row="1" Grid.Column="0" Padding="5,2" Margin="5">Needs Revision All</Button>
        <Button Click="IssueRevAll_Click" Name="IssueRevAll" Grid.Row="1" Grid.Column="1" Padding="5,2" Margin="5">Issue Revision All</Button>
      </Grid>
      <Border Grid.Row="2" Margin="2" BorderBrush="Gray" BorderThickness=".25">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <TextBlock VerticalAlignment="Center" FontWeight="Bold" HorizontalAlignment="Center" Margin="5,0">Engineering Check</TextBlock>
          <TextBlock VerticalAlignment="Center" Grid.Column="1" Grid.Row="0" TextAlignment="Right" Text="Checked?"
                     Margin="5,0"/>
          <TextBlock Name="EngYesNo" VerticalAlignment="Center" Text="NO" Foreground="Red" TextAlignment="Left"
                     Grid.Column="2" Margin="5,0"/>
          <Button Click="EngChkBtn_Click" Name="EngChkBtn" Grid.Column="3" Margin="2" Padding="2"
                  VerticalAlignment="Center">Check</Button>
          <Grid Row="1" ColumnSpan="4">
            <Grid.RowDefinitions>
              <RowDefinition/>
              <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition/>
              <ColumnDefinition/>
              <ColumnDefinition/>
              <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Label Content="Current" Grid.Row="0" Margin="5,0"/>
            <Label Grid.Row="1" HorizontalAlignment="Right">User:</Label>
            <Label Name="EngCurrentUser" Grid.Row="1" Grid.Column="1">username</Label>
            <Label Grid.Row="1" Grid.Column="2" HorizontalAlignment="Right">Date:</Label>
            <Label Name="EngCurrentDate" Grid.Row="1" Grid.Column="3">date</Label>
          </Grid>
          <Grid Row="2" ColumnSpan="4">
            <Grid.RowDefinitions>
              <RowDefinition/>
              <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition/>
              <ColumnDefinition/>
              <ColumnDefinition/>
              <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Label Content="Initial" Grid.Row="0" Margin="5,0"/>
            <Label Grid.Row="1" HorizontalAlignment="Right">User:</Label>
            <Label Name="EngInitialUser" Grid.Row="1" Grid.Column="1">username</Label>
            <Label Grid.Row="1" Grid.Column="2" HorizontalAlignment="Right">Date:</Label>
            <Label Name="EngInitialDate" Grid.Row="1" Grid.Column="3">date</Label>
          </Grid>
        </Grid>
      </Border>
      <Border Grid.Row="3" Margin="2" BorderBrush="Gray" BorderThickness=".25">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <TextBlock VerticalAlignment="Center" FontWeight="Bold" HorizontalAlignment="Left" Margin="5,0">Drafting Check</TextBlock>
          <TextBlock VerticalAlignment="Center" Grid.Column="1" Grid.Row="0" TextAlignment="Right" Text="Checked?"
                     Margin="5,0"/>
          <TextBlock Name="DraftingYesNo" VerticalAlignment="Center" Text="NO" Foreground="Red" TextAlignment="Left"
                     Grid.Column="2" Margin="5,0"/>
          <Button Click="DraftChkBtn_Click" Name="DraftChkBtn" Grid.Column="3" Margin="2" Padding="2"
                  VerticalAlignment="Center">Check</Button>
          <Grid Row="1" ColumnSpan="4">
            <Grid.RowDefinitions>
              <RowDefinition/>
              <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition/>
              <ColumnDefinition/>
              <ColumnDefinition/>
              <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Label Content="Current" Grid.Row="0" Margin="5,0"/>
            <Label Grid.Row="1" HorizontalAlignment="Right">User:</Label>
            <Label Name="DraftCurrentUser" Grid.Row="1" Grid.Column="1">username</Label>
            <Label Grid.Row="1" Grid.Column="2" HorizontalAlignment="Right">Date:</Label>
            <Label Name="DraftCurrentDate" Grid.Row="1" Grid.Column="3">date</Label>
          </Grid>
          <Grid Row="2" ColumnSpan="4">
            <Grid.RowDefinitions>
              <RowDefinition/>
              <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition/>
              <ColumnDefinition/>
              <ColumnDefinition/>
              <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Label Content="Initial" Grid.Row="0" Margin="5,0"/>
            <Label Grid.Row="1" HorizontalAlignment="Right">User:</Label>
            <Label Name="DraftInitialUser" Grid.Row="1" Grid.Column="1">username</Label>
            <Label Grid.Row="1" Grid.Column="2" HorizontalAlignment="Right">Date:</Label>
            <Label Name="DraftInitialDate" Grid.Row="1" Grid.Column="3">date</Label>
          </Grid>
        </Grid>
      </Border>
      <Border Grid.Row="4" Margin="2" BorderBrush="Gray" BorderThickness=".25">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <TextBlock VerticalAlignment="Center" FontWeight="Bold" HorizontalAlignment="Left" Margin="5,0">Revisions</TextBlock>
          <TextBlock Name="NeedsRevYesNo" VerticalAlignment="Center" Text="Issued:" Foreground="Green"
                     TextAlignment="Right" Grid.Column="1" Margin="5,0"/>
          <TextBlock Name="RevIssuedDate" VerticalAlignment="Center" Text="2024-09-01-2222222-22222222"
                     Foreground="Green" TextAlignment="Left" Grid.Column="2" Grid.ColumnSpan="2" Margin="5,0"/>
          <Grid ColumnSpan="3" Row="1">
            <Grid.ColumnDefinitions>
              <ColumnDefinition/>
              <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button Click="NeedsRevBtn_Click" Name="NeedsRevBtn" Grid.Row="1" Grid.Column="0" Margin="5,5,20,5"
                    Padding="2" VerticalAlignment="Center">Needs Revision</Button>
            <Button Click="IssueRevBtn_Click" Name="IssueRevBtn" Grid.Row="1" Grid.Column="1" Margin="20,5,5,5"
                    Padding="2" VerticalAlignment="Center">Issue Revision</Button>
          </Grid>
        </Grid>
      </Border>
      <Button Click="DoneBtn_Click" Name="DoneBtn" Grid.Row="6" Margin="7,5">Close</Button>
      <Label Grid.Row="5" FontSize="8" HorizontalAlignment="Left" Foreground="Gray"
             Content="Eng/Drafting Check Utility v1.0" Padding="10,2" Visibility="Collapsed"/>
    </Grid>
  </Border>
</Window>