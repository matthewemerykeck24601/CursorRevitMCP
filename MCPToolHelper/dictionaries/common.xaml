<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:Microsoft_Windows_Themes="clr-namespace:Microsoft.Windows.Themes;assembly=PresentationFramework.Luna">
  <Color x:Key="theAccentColor">#FFA45329</Color>
  <Color x:Key="theBlueColor">#FF007897</Color>
  <Color x:Key="theGreenColor">#FF08A46E</Color>
  <Color x:Key="theBackGroundColor">#FF2d2d2f</Color>
  <Color x:Key="theMagentaColor">#FFA41043</Color>
  <SolidColorBrush x:Key="theBackGround" Color="{StaticResource theBackGroundColor}"/>
  <SolidColorBrush x:Key="theAccent" Color="{StaticResource theAccentColor}"/>
  <SolidColorBrush x:Key="theBlue" Color="{StaticResource theBlueColor}"/>
  <SolidColorBrush x:Key="theGreen" Color="{StaticResource theGreenColor}"/>
  <SolidColorBrush x:Key="theMagenta" Color="{StaticResource theMagentaColor}"/>
  <LinearGradientBrush x:Key="BackgroundBrush4C" StartPoint="0.504,-0.319" EndPoint="0.504,0.351">
    <GradientStop Color="#FFACB8B9" Offset="0.416"/>
    <GradientStop Color="#FFACB8B9" Offset="0.54"/>
  </LinearGradientBrush>
  <LinearGradientBrush x:Key="TextBoxShadow" StartPoint="0.0,0.0" EndPoint="0,1">
    <GradientStop Color="LightGray" Offset="0.0"/>
    <GradientStop Color="White" Offset="0.4"/>
  </LinearGradientBrush>
  <Style x:Key="TabItem1" TargetType="{x:Type TabItem}">
    <Setter Property="Control.Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type TabItem}">
          <Grid>
            <Border Name="Border" Background="Black" BorderBrush="Goldenrod" BorderThickness="1,1,1,1"
                    CornerRadius="6,6,6,6">
              <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header"
                                Margin="12,2,12,2"/>
            </Border>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <ControlTemplate x:Key="TextBoxValidatortemplate">
    <StackPanel Orientation="Horizontal">
      <Border BorderBrush="Red" BorderThickness="3" CornerRadius="4">
        <AdornedElementPlaceholder/>
      </Border>
      <Image Source="/Images/Error.png" Height="36"/>
    </StackPanel>
  </ControlTemplate>
  <ControlTemplate x:Key="TextBoxValidatortemplateSmall">
    <StackPanel Orientation="Horizontal" Visibility="{TemplateBinding UIElement.Visibility}">
      <Border BorderBrush="Red" BorderThickness="2" CornerRadius="4">
        <AdornedElementPlaceholder/>
      </Border>
      <Image Source="/Images/Error.png" Height="24"/>
    </StackPanel>
  </ControlTemplate>
  <ControlTemplate x:Key="TextBoxValidatortemplate2">
    <StackPanel Orientation="Horizontal">
      <Border BorderBrush="Red" BorderThickness="3" CornerRadius="4">
        <AdornedElementPlaceholder/>
      </Border>
    </StackPanel>
  </ControlTemplate>
  <ControlTemplate x:Key="ComboBoxValidatortemplate">
    <StackPanel Orientation="Horizontal">
      <Border BorderBrush="Red" BorderThickness="3" CornerRadius="4">
        <AdornedElementPlaceholder/>
      </Border>
    </StackPanel>
  </ControlTemplate>
  <Style x:Key="InputTextBoxNoGlow" TargetType="{x:Type TextBox}">
    <Setter Property="FrameworkElement.Margin" Value="2,0"/>
    <Setter Property="Control.FontSize" Value="20"/>
    <Setter Property="Control.FontWeight" Value="SemiBold"/>
    <Setter Property="Control.VerticalContentAlignment" Value="Center"/>
    <Setter Property="TextBox.CharacterCasing" Value="Upper"/>
    <Setter Property="Validation.ErrorTemplate" Value="{StaticResource TextBoxValidatortemplateSmall}"/>
    <Style.Triggers>
      <Trigger Property="Validation.HasError" Value="true">
        <Setter Property="FrameworkElement.ToolTip"
                Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}"/>
      </Trigger>
    </Style.Triggers>
  </Style>
  <OuterGlowBitmapEffect x:Key="txtGlow" GlowColor="Goldenrod" GlowSize="6"/>
  <Style x:Key="InputTextBox" TargetType="{x:Type TextBox}">
    <Setter Property="Control.Background" Value="{StaticResource TextBoxShadow}"/>
    <Setter Property="FrameworkElement.Margin" Value="2,0"/>
    <Setter Property="Control.FontSize" Value="20"/>
    <Setter Property="Control.FontWeight" Value="SemiBold"/>
    <Setter Property="Control.VerticalContentAlignment" Value="Center"/>
    <Setter Property="TextBox.CharacterCasing" Value="Upper"/>
    <Style.Triggers>
      <Trigger Property="UIElement.IsFocused" Value="true">
        <Setter Property="UIElement.BitmapEffect" Value="{StaticResource txtGlow}"/>
      </Trigger>
      <Trigger Property="Validation.HasError" Value="true">
        <Setter Property="Validation.ErrorTemplate" Value="{StaticResource TextBoxValidatortemplateSmall}"/>
        <Setter Property="FrameworkElement.ToolTip"
                Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}"/>
      </Trigger>
      <Trigger Property="UIElement.Visibility" Value="Collapsed">
        <Setter Property="Validation.ErrorTemplate" Value="{x:Null}"/>
        <Setter Property="FrameworkElement.ToolTip"
                Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}"/>
      </Trigger>
      <Trigger Property="UIElement.Visibility" Value="Visible">
        <Setter Property="Validation.ErrorTemplate" Value="{StaticResource TextBoxValidatortemplateSmall}"/>
        <Setter Property="FrameworkElement.ToolTip"
                Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}"/>
      </Trigger>
    </Style.Triggers>
  </Style>
  <OuterGlowBitmapEffect x:Key="txtGlowAccent" GlowColor="{StaticResource theAccentColor}" GlowSize="10"/>
  <Style x:Key="InputTextBoxAccent" TargetType="{x:Type TextBox}">
    <Setter Property="Control.Background" Value="{StaticResource TextBoxShadow}"/>
    <Setter Property="FrameworkElement.Margin" Value="2,0"/>
    <Setter Property="Control.FontSize" Value="20"/>
    <Setter Property="Control.FontWeight" Value="SemiBold"/>
    <Setter Property="Control.VerticalContentAlignment" Value="Center"/>
    <Setter Property="TextBox.CharacterCasing" Value="Upper"/>
    <Setter Property="Validation.ErrorTemplate" Value="{StaticResource TextBoxValidatortemplateSmall}"/>
    <Style.Triggers>
      <Trigger Property="UIElement.IsFocused" Value="true">
        <Setter Property="UIElement.BitmapEffect" Value="{StaticResource txtGlowAccent}"/>
      </Trigger>
      <Trigger Property="Validation.HasError" Value="true">
        <Setter Property="FrameworkElement.ToolTip"
                Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}"/>
      </Trigger>
    </Style.Triggers>
  </Style>
  <Style x:Key="LCTextBox" TargetType="{x:Type TextBox}" BasedOn="{StaticResource InputTextBox}">
    <Setter Property="FrameworkElement.Margin" Value="4"/>
    <Setter Property="Control.BorderBrush" Value="Black"/>
  </Style>
  <Style x:Key="InputComboBox" TargetType="{x:Type ComboBox}">
    <Setter Property="Validation.ErrorTemplate" Value="{StaticResource ComboBoxValidatortemplate}"/>
    <Style.Triggers>
      <Trigger Property="UIElement.IsFocused" Value="true">
        <Setter Property="UIElement.BitmapEffect" Value="{StaticResource txtGlow}"/>
      </Trigger>
      <Trigger Property="Validation.HasError" Value="true">
        <Setter Property="FrameworkElement.ToolTip"
                Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}"/>
      </Trigger>
    </Style.Triggers>
  </Style>
  <Style x:Key="PropertyLabel" TargetType="{x:Type Label}">
    <Setter Property="Control.FontSize" Value="16"/>
    <Setter Property="Control.Foreground" Value="Goldenrod"/>
    <Setter Property="FrameworkElement.Margin" Value="0,0,3,0"/>
    <Setter Property="Control.HorizontalContentAlignment" Value="Right"/>
    <Setter Property="Control.VerticalContentAlignment" Value="Center"/>
  </Style>
  <Style x:Key="PropertyTextBlock">
    <Setter Property="Control.FontSize" Value="18"/>
    <Setter Property="Control.Foreground" Value="White"/>
    <Setter Property="FrameworkElement.Margin" Value="0,0,3,0"/>
    <Setter Property="Control.HorizontalContentAlignment" Value="Right"/>
  </Style>
  <Style x:Key="PopupDataLabel" TargetType="{x:Type Label}">
    <Setter Property="Control.FontSize" Value="16"/>
    <Setter Property="Control.Foreground" Value="Goldenrod"/>
    <Setter Property="FrameworkElement.Margin" Value="0,0,3,0"/>
    <Setter Property="Control.HorizontalContentAlignment" Value="Right"/>
    <Setter Property="Control.VerticalContentAlignment" Value="Bottom"/>
  </Style>
  <SolidColorBrush x:Key="ButtonBorder" Color="#FF003C74"/>
  <ControlTemplate x:Key="LCRadioButton" TargetType="{x:Type RadioButton}">
    <BulletDecorator>
      <BulletDecorator.Bullet>
        <Grid Height="24" Width="24" Background="Transparent" Margin="6,0,0,6">
          <Ellipse Stroke="{StaticResource BackgroundBrush4C}" StrokeThickness="2"/>
          <Path Name="pathChecked" Data="M 0,24 L 24,0 M 0,0 L 24,24 " Stroke="Yellow" StrokeThickness="3"
                Opacity="1" Visibility="Collapsed"/>
          <Image Name="imgChecked" Source="/Images/Checkmark.png"/>
        </Grid>
      </BulletDecorator.Bullet>
      <ContentPresenter Margin="12,0,0,6"/>
    </BulletDecorator>
    <ControlTemplate.Triggers>
      <Trigger Property="ToggleButton.IsChecked" Value="True">
        <Setter TargetName="pathChecked" Property="Shape.Stroke" Value="Yellow"/>
        <Setter TargetName="pathChecked" Property="UIElement.Opacity" Value="1"/>
        <Setter TargetName="imgChecked" Property="UIElement.Opacity" Value="1"/>
      </Trigger>
      <Trigger Property="ToggleButton.IsChecked" Value="False">
        <Setter TargetName="pathChecked" Property="UIElement.Opacity" Value="0"/>
        <Setter TargetName="imgChecked" Property="UIElement.Opacity" Value="0"/>
      </Trigger>
      <Trigger Value="{x:Null}" Property="ToggleButton.IsChecked">
        <Setter TargetName="pathChecked" Property="Shape.Stroke" Value="Gray"/>
        <Setter TargetName="pathChecked" Property="UIElement.Opacity" Value="1"/>
        <Setter TargetName="imgChecked" Property="UIElement.Opacity" Value="0"/>
      </Trigger>
    </ControlTemplate.Triggers>
  </ControlTemplate>
  <LinearGradientBrush x:Key="DefaultButtonBackgroundFill" StartPoint="0,1" EndPoint="0,0">
    <GradientStop Color="#FF043F76" Offset="0"/>
    <GradientStop Color="#FF04427C" Offset="1"/>
    <GradientStop Color="#FF5F91C1" Offset="1"/>
  </LinearGradientBrush>
  <LinearGradientBrush x:Key="DefaultToggleButtonBackgroundFill" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#FF00cccc" Offset="0"/>
    <GradientStop Color="#FF000000" Offset="0.25"/>
    <GradientStop Color="#FF000000" Offset="0.75"/>
    <GradientStop Color="#FF00cccc" Offset="1"/>
  </LinearGradientBrush>
  <LinearGradientBrush x:Key="DisabledButtonBackgroundFill" StartPoint="0,1" EndPoint="0,0">
    <GradientStop Color="#FF4B4B32" Offset="0"/>
    <GradientStop Color="#FFAFAF96" Offset="1"/>
  </LinearGradientBrush>
  <Style TargetType="{x:Type Button}">
    <Setter Property="Control.Padding" Value="15,0"/>
    <Setter Property="FrameworkElement.Margin" Value="2"/>
    <Setter Property="FrameworkElement.MinHeight" Value="30"/>
    <Setter Property="FrameworkElement.MaxHeight" Value="72"/>
    <Setter Property="FrameworkElement.MinWidth" Value="50"/>
    <Setter Property="Control.FontFamily" Value="Tahoma"/>
    <Setter Property="Control.FontSize" Value="16"/>
    <Setter Property="Control.Foreground" Value="White"/>
    <Setter Property="FrameworkElement.Cursor" Value="Hand"/>
    <Setter Property="FrameworkElement.FocusVisualStyle">
      <Setter.Value>
        <Style>
          <Setter Property="Control.Template">
            <Setter.Value>
              <ControlTemplate>
                <Rectangle RadiusX="10" RadiusY="10" Stroke="Gold" StrokeThickness="1"/>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Style>
      </Setter.Value>
    </Setter>
    <Setter Property="Control.Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Button}">
          <Grid x:Name="rootGrid" RenderTransformOrigin=".5,.5">
            <FrameworkElement.Resources>
              <SolidColorBrush x:Key="borderBrush" Color="Black"/>
            </FrameworkElement.Resources>
            <UIElement.RenderTransform>
              <TranslateTransform X="0" Y="0"/>
            </UIElement.RenderTransform>
            <Grid.RowDefinitions>
              <RowDefinition/>
              <RowDefinition/>
            </Grid.RowDefinitions>
            <Rectangle x:Name="bottomBorder" Grid.RowSpan="2" RadiusX="10" RadiusY="10"
                       Stroke="{StaticResource borderBrush}" StrokeThickness="2"
                       Fill="{StaticResource DefaultButtonBackgroundFill}">
              <FrameworkElement.Triggers>
                <EventTrigger RoutedEvent="Button.MouseEnter">
                  <BeginStoryboard x:Name="CycleBorder">
                    <Storyboard>
                      <ColorAnimation Storyboard.TargetProperty="Stroke.Color" To="Orange" Duration="0:0:0.5" AutoReverse="true"
                                      RepeatBehavior="Forever"/>
                    </Storyboard>
                  </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="Button.MouseLeave">
                  <StopStoryboard BeginStoryboardName="CycleBorder"/>
                </EventTrigger>
              </FrameworkElement.Triggers>
            </Rectangle>
            <Rectangle x:Name="highlight" Margin="2.5" Fill="White" RadiusX="10" RadiusY="10">
              <UIElement.OpacityMask>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                  <GradientStop Color="#90FFFFFF" Offset="0"/>
                  <GradientStop Color="#00FFFFFF" Offset="1"/>
                </LinearGradientBrush>
              </UIElement.OpacityMask>
            </Rectangle>
            <ContentPresenter x:Name="contentPresenter" Grid.RowSpan="2"
                              HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}"
                              Margin="{TemplateBinding Control.Padding}"
                              SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}" RecognizesAccessKey="true"
                              RenderTransformOrigin="0.5,0.5"/>
          </Grid>
          <FrameworkTemplate.Resources>
            <Storyboard x:Key="buttonDown_Animation">
              <DoubleAnimation Storyboard.TargetName="rootGrid"
                               Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="0" To="0"
                               Duration="0:0:0"/>
            </Storyboard>
          </FrameworkTemplate.Resources>
          <ControlTemplate.Triggers>
            <Trigger Property="ButtonBase.IsPressed" Value="true">
              <Setter TargetName="highlight" Property="UIElement.Visibility" Value="Hidden"/>
              <Setter TargetName="bottomBorder" Property="Shape.Stroke" Value="Black"/>
              <Setter TargetName="bottomBorder" Property="Shape.Fill">
                <Setter.Value>
                  <LinearGradientBrush EndPoint="0,0" StartPoint="0,1">
                    <GradientStop Color="#FF0C4E8B" Offset="0"/>
                    <GradientStop Color="#FF2B4864" Offset="0.42"/>
                    <GradientStop Color="Black" Offset="1"/>
                  </LinearGradientBrush>
                </Setter.Value>
              </Setter>
            </Trigger>
            <Trigger Property="UIElement.IsEnabled" Value="false">
              <Setter TargetName="bottomBorder" Value="{StaticResource DisabledButtonBackgroundFill}"
                      Property="Shape.Fill"/>
              <Setter TargetName="bottomBorder" Property="Shape.Stroke" Value="Silver"/>
              <Setter TargetName="bottomBorder" Property="Shape.StrokeThickness" Value="4"/>
              <Setter TargetName="highlight" Property="Shape.Fill" Value="#20FFFFFF"/>
              <Setter Property="Control.Foreground" Value="#FFAFAFAF"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
