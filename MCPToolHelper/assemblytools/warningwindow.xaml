<Window x:Class="EDGE.AssemblyTools.WarningWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:EDGE.AssemblyTools"
        Title="Warning" Height="260" Width="500" WindowStartupLocation="CenterOwner">
  <FrameworkElement.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>
  </FrameworkElement.Resources>
  <StackPanel Margin="20,20,19.6,7.4">
    <Label FontWeight="Bold">
      Assembly created and all added elements have had their parameters updated.
    </Label>
    <Label FontWeight="Bold" Foreground="Red">Caution:</Label>
    <Label FontWeight="Bold" Foreground="Red">
      Ensure that all elements have been correctly added to the assembly.
    </Label>
    <Label FontWeight="Bold" Foreground="Red"
           Content="Elements may have been omitted due to modeling issues, or due to small"/>
    <Label FontWeight="Bold" Foreground="Red">
      dimension errors generated by the core Revit software modeling kernel.
    </Label>
    <Label FontWeight="Bold" Foreground="Red"/>
    <CheckBox x:Name="cbYes" FontWeight="Bold"
              Visibility="{Binding boolCheckboxOn, Converter={StaticResource BoolToVis}}">
      Do you want to highlight those intersection pieces?
    </CheckBox>
    <Label FontWeight="Bold" Foreground="Red"/>
    <Button Name="btn1" HorizontalAlignment="Center"
            Visibility="{Binding boolCheckboxOn, Converter={StaticResource BoolToVis}}">Continue</Button>
  </StackPanel>
</Window>