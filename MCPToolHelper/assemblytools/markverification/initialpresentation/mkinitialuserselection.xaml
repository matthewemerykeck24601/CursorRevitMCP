<Window x:Class="EDGE.AssemblyTools.MarkVerification.InitialPresentation.MKInitialUserSelection"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:EDGE.AssemblyTools.MarkVerification.InitialPresentation"
        Title="Mark Verification Initial Selection List" Height="300" Width="400" MaxHeight="550"
        MaxWidth="400" MinHeight="300" MinWidth="340" WindowStartupLocation="CenterScreen">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="2*"/>
      <RowDefinition Height="4.5*"/>
      <RowDefinition Height="1*"/>
      <RowDefinition Height="1*"/>
    </Grid.RowDefinitions>
    <TextBlock FontSize="12" Margin="10,10,9.6,0">
      <Run Text="The following structural framming elements are owned by "/>
      <LineBreak/>
      <Run Text="you. Please select the elements that you would like to be "/>
      <LineBreak/>
      <Run Text="processed by Mark Verification:"/>
    </TextBlock>
    <CheckBox Checked="cbAllFeatures_CheckedChanged" Unchecked="cbAllFeatures_CheckedChanged"
              Name="cbAllFeatures" Grid.Row="1" IsThreeState="true" Margin="10,10,245.6,114.2">All</CheckBox>
    <ListBox Name="lbTodoList" Grid.Row="1" Margin="10,29,9.6,10.2">
      <ItemsControl.ItemTemplate>
        <DataTemplate>
          <CheckBox Name="ElementName" Content="{Binding mkNumber}" IsChecked="{Binding IsSelected}"/>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ListBox>
    <CheckBox Click="TraditionalApproach_Click" Name="TraditionalApproach" Grid.Row="2" IsThreeState="false"
              Content="Traditional Approach" VerticalAlignment="Center" HorizontalAlignment="Left"/>
    <CheckBox Click="DetailedApproach_Click" Name="DetailedApproach" Grid.Row="2" IsThreeState="false"
              Content="Detailed Approach" VerticalAlignment="Center" HorizontalAlignment="Center"/>
    <Button Click="btn1_Click" x:Name="btn1" Grid.Row="3" HorizontalAlignment="Left" VerticalAlignment="Center"
            Content="Continue"/>
    <Button Click="canclebtn_Click" x:Name="canclebtn" Grid.Row="4" HorizontalAlignment="Right"
            VerticalAlignment="Center" Content="Cancel the Process"/>
  </Grid>
</Window>