<Window x:Class="EDGE.InsulationTools.PinPlacement.PinFamilySelection"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:EDGE.InsulationTools.PinPlacement"
        Closed="Window_Closed" Name="Window" Title="Pin Placement Family Type Selection" Height="275"
        Width="380" WindowStartupLocation="CenterOwner" MaxHeight="275" MaxWidth="380" MinHeight="275"
        MinWidth="380">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*" MaxHeight="150"/>
      <RowDefinition Height="35"/>
    </Grid.RowDefinitions>
    <TextBlock Name="txtblock" Grid.Row="0" Visibility="Visible" TextWrapping="Wrap" Margin="10,5,5,5"
               FontSize="12"/>
    <ListView SelectionChanged="Pins_SelectionChanged" x:Name="pins" Grid.Row="1" Visibility="Visible"
              HorizontalAlignment="Stretch" VerticalAlignment="Top" SelectionMode="Single"
              Background="Transparent" HorizontalContentAlignment="Left" Cursor="Arrow"/>
    <Button Click="OkButton_Click" Name="okButton" Grid.Row="2" Grid.Column="0" Content="OK"
            Visibility="Visible" IsEnabled="false" HorizontalAlignment="Left" VerticalAlignment="Center"
            Height="26" Width="40" Margin="10,0,0,0" BorderBrush="Black" BorderThickness="1"/>
    <Button Click="Cancel_Click" Name="Cancel" Grid.Row="2" Grid.Column="1" Content="Cancel"
            Visibility="Visible" IsEnabled="true" HorizontalAlignment="Right" VerticalAlignment="Center"
            Height="26" Width="50" Margin="0,0,10,0" BorderBrush="Black" BorderThickness="1"/>
  </Grid>
</Window>