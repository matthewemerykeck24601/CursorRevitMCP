<Window x:Class="EDGE.InsulationTools.InsulationPlacement.InsulationSelection"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:EDGE.InsulationTools.InsulationPlacement"
        Closed="Window_Closed" Name="Window" Title="Insulation Placement Selection" Height="335"
        Width="350" MinHeight="335" MinWidth="370" MaxHeight="335" MaxWidth="370"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="0,0,0,8">
    <Grid.RowDefinitions>
      <RowDefinition Height="58"/>
      <RowDefinition Height="195"/>
      <RowDefinition Height="68"/>
    </Grid.RowDefinitions>
    <TextBlock Name="titleBlock" Grid.Row="0"
               Text="Please select the insulation you would like to place in the structural framing elements in the model"
               TextWrapping="Wrap" Margin="10,5,0,0" FontSize="12"/>
    <ListView SelectionChanged="Insulations_SelectionChanged" x:Name="insulations" Visibility="Visible"
              HorizontalAlignment="Stretch" VerticalAlignment="Top" SelectionMode="Single"
              Background="Transparent" HorizontalContentAlignment="Left" Cursor="Arrow" Grid.Row="1" Height="193"/>
    <Button Click="oKButton_Click" Name="okbutton" Grid.Row="2" Content="OK" Visibility="Visible"
            IsEnabled="false" HorizontalAlignment="Left" VerticalAlignment="Top" Height="26" Width="40"
            Margin="10,9,0,0" BorderBrush="Black" BorderThickness="1"/>
    <Button Click="cancelButton_Click" Grid.Row="2" Content="Cancel" Visibility="Visible"
            HorizontalAlignment="Right" VerticalAlignment="Top" Height="26" Width="50" Margin="0,9,10,0"
            BorderBrush="Black" BorderThickness="1"/>
  </Grid>
</Window>