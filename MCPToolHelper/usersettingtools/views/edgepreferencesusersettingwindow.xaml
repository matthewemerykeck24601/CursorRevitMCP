<Window x:Class="EDGE.UserSettingTools.Views.EdgePreferencesUserSettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:EDGE.UserSettingTools.Views"
        Loaded="Window_Loaded" Title="EDGE Preferences Settings" Height="350" Width="460" MinHeight="250"
        MinWidth="460" WindowStartupLocation="CenterOwner">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="100"/>
      </Grid.RowDefinitions>
      <Expander Name="FolderExpander" Header="Folder Path Settings"
                ToolTip="Please enter the preferred folder path below." Margin="0,0,0.2,0.2" IsExpanded="true">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="248*"/>
            <ColumnDefinition Width="187*"/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <TextBlock Margin="24,0,0,0">
            Ticket Template Settings File Path:
          </TextBlock>
          <TextBox Name="TicketTemplateSettingsFile" Margin="223,0,61,19" Grid.RowSpan="2" Grid.ColumnSpan="2"/>
          <Button Click="TicketTemplateBrowse_Click" Name="TicketTemplateBrowse" Margin="134,0,-1,0" Grid.Column="1">Browse</Button>
          <TextBlock Margin="24,0,0,0" Grid.Row="1">
            HWD Template Settings File Path:
          </TextBlock>
          <TextBox Name="HardwareTemplateSettingsFile" Margin="223,0,61,19" Grid.RowSpan="2" Grid.ColumnSpan="2"
                   Grid.Row="1"/>
          <Button Click="HardwareTemplateBrowse_Click" Name="HardwareTemplateBrowse" Margin="134,0,-1,0"
                  Grid.Column="1" Grid.Row="1">Browse</Button>
          <TextBlock Margin="24,0,0,0" Grid.Row="2">
            Rebar Settings Folder Path:
          </TextBlock>
          <TextBox Name="RebarSettingsFolderPath" Margin="247,0,61,0" Grid.ColumnSpan="2" Grid.Row="2"/>
          <Button Click="RebarSettingFolderBrowse_Click" Name="RebarSettingFolderBrowse" Margin="134,0,-1,0"
                  Grid.Column="1" Grid.Row="2">Browse</Button>
          <TextBlock Margin="24,0,0,0" Grid.Row="3">
            Mark Verification Setting Folder Path:
          </TextBlock>
          <TextBox Name="MarkPrefixFolderPath" Grid.Row="3" Margin="247,0,61,0" Grid.ColumnSpan="2"/>
          <Button Click="MarkPrefixFolderBrowse_Click" Name="MarkPrefixFolderBrowse" Grid.Row="3" Margin="134,0,-1,0"
                  Grid.Column="1">Browse</Button>
          <TextBlock Margin="24,0,0,0" Grid.Row="4">
            Ticket Settings Folder Path:
          </TextBlock>
          <TextBox Name="TicketSettingsFolderPath" Grid.Row="4" Grid.ColumnSpan="2" Margin="247,0,61,0"/>
          <Button Click="AutoTicketSettingsBrowse_Click" Name="AutoTicketSettingsBrowse" Grid.Row="4" Grid.Column="1"
                  Margin="134,0,-1,0">Browse</Button>
          <TextBlock Margin="24,0,0,0" Grid.Row="5">
            Ticket BOM Settings Folder Path:
          </TextBlock>
          <TextBox Name="TKTBOMFolderPath" Grid.Row="5" Margin="247,0,61,0" Grid.ColumnSpan="2"/>
          <Button Click="TKTBOMFolderBrowse_Click" Name="TKTBOMFolderBrowse" Grid.Row="5" Margin="134,0,-1,0"
                  Grid.Column="1" Height="20" VerticalAlignment="Top">Browse</Button>
          <TextBlock Margin="24,0,0,0" Grid.Row="6">
            Title Block Populator Setting Folder Path:
          </TextBlock>
          <TextBox Name="TBPopFolderPath" Grid.Row="6" Margin="247,0,61,0" Grid.ColumnSpan="2"/>
          <Button Click="TBPopFolderBrowse_Click" Name="TBPopFolderBrowse" Grid.Row="6" Margin="134,0,-1,0"
                  Grid.Column="1">Browse</Button>
          <TextBlock Margin="24,0,0,0" Grid.Row="7">
            HWD BOM Settings Folder Path:
          </TextBlock>
          <TextBox Name="HWBOMFolderPath" Grid.Row="7" Margin="247,0,61,0" Grid.ColumnSpan="2"/>
          <Button Click="HWBOMFolderBrowse_Click" Name="HWBOMFolderBrowse" Grid.Row="7" Margin="134,0,-1,0"
                  Grid.Column="1" Height="20" VerticalAlignment="Top">Browse</Button>
          <TextBlock Margin="24,0,0,0" Grid.Row="8">
            HWD Title Block Populator Folder Path:
          </TextBlock>
          <TextBox Name="HWTBPopFolderPath" Grid.Row="8" Margin="247,0,61,0" Grid.ColumnSpan="2"/>
          <Button Click="HWTBPopFolderBrowse_Click" Name="HWTBPopFolderBrowse" Grid.Row="8" Margin="134,0,-1,0"
                  Grid.Column="1">Browse</Button>
          <TextBlock Margin="24,0,0,0" Grid.Row="9">
            Ticket Manager Custom Folder Path:
          </TextBlock>
          <TextBox Name="TMCFolderPath" Grid.Row="9" Margin="247,0,61,0" Grid.ColumnSpan="2"/>
          <Button Click="TMCFolderBrowse_Click" Name="TMCFolderBrowse" Grid.Row="9" Margin="134,0,-1,0"
                  Grid.Column="1">Browse</Button>
          <TextBlock Margin="24,0,0,0" Grid.Row="10">
            CAD Export Settings Folder Path:
          </TextBlock>
          <TextBox Name="CADExFolderPath" Grid.Row="10" Margin="247,0,61,0" Grid.ColumnSpan="2"/>
          <Button Click="CADExFolderBrowse_Click" Name="CADExFolderBrowse" Grid.Row="10" Margin="134,0,-1,0"
                  Grid.Column="1">Browse</Button>
          <TextBlock Margin="24,0,0,0" Grid.Row="11">
            Insulation Drawing Settings Folder Path:
          </TextBlock>
          <TextBox Name="InsulationDrawingSettingsFolderPath" Grid.Row="11" Margin="247,0,61,0" Grid.ColumnSpan="2"/>
          <Button Click="InsulationDrawingSettingsFolderBrowse_Click" Name="InsulationDrawingSettingsFolderBrowse"
                  Grid.Row="11" Margin="134,0,-1,0" Grid.Column="1">Browse</Button>
        </Grid>
      </Expander>
      <Expander Name="RebarExpander" Header="Rebar Settings" Grid.Row="1"
                ToolTip="By checking the check box the parameter will be set to TRUE." IsExpanded="true">
        <Grid>
          <TextBlock Margin="24,0,0,0">
            EDGE Rebar Mark Updater
          </TextBlock>
          <CheckBox Checked="Edge_Rebar_Mark_Updater_Checked" Unchecked="Edge_Rebar_Mark_Updater_UnChecked"
                    Name="Edge_Rebar_Mark_Updater" Margin="222,0,190,0"/>
        </Grid>
      </Expander>
      <Expander Name="RibbonExpander" Header="Ribbon and Tool Display Settings" Grid.Row="3" IsExpanded="true">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <Grid Row="0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Margin="24,0,0,0" FontWeight="DemiBold">Annotation Panel</TextBlock>
            <CheckBox Checked="Annotation_Panel_Checked" Unchecked="Annotation_Panel_UnChecked" Name="Annotation_Panel"
                      Margin="222,0,190,0"/>
            <Grid Name="AnnotationPanelItem" Row="1">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <TextBlock Margin="40,0,0,0" Grid.Row="0" Text="Text Utilities"/>
              <CheckBox Checked="Annotation_TextUtilities_Checked" Unchecked="Annotation_TextUtilities_UnChecked"
                        Name="Annotation_TextUtilities" Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="1" Text="Dimension Utilities"/>
              <CheckBox Checked="Annotation_DimensionUtilities_Checked" Unchecked="Annotation_DimensionUtilities_UnChecked"
                        Name="Annotation_DimensionUtilities" Grid.Row="1" Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="2" Text="Auto-Dimensioning for Erection Drawings"/>
              <CheckBox Checked="Annotation_AutoDim_EDWG_Checked" Unchecked="Annotation_AutoDim_EDWG_UnChecked"
                        Name="Annotation_AutoDim_EDWG" Grid.Row="2" Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="3" Text="Freeze Active View"/>
              <CheckBox Checked="Freeze_Active_View_Checked" Unchecked="Freeze_Active_View_UnChecked"
                        Name="Freeze_Active_View" Grid.Row="3" Margin="280,0,130,0"/>
            </Grid>
          </Grid>
          <Grid Row="1">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Margin="24,0,0,0" FontWeight="DemiBold">Geometry Panel</TextBlock>
            <CheckBox Checked="Geometry_Panel_Checked" Unchecked="Geometry_Panel_UnChecked" Name="Geometry_Panel"
                      Margin="222,0,190,0"/>
            <Grid Name="GeometryPanelItem" Row="1">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <TextBlock Margin="40,0,0,0" Grid.Row="0" Text="Addon Hosting Updater"/>
              <CheckBox Checked="Geometry_AddonHostingUpdater_Checked" Unchecked="Geometry_AddonHostingUpdater_UnChecked"
                        Name="Geometry_AddonHostingUpdater" Grid.Row="0" Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="1">MultiVoidTools</TextBlock>
              <CheckBox Checked="Geometry_MultiVoidTools_Checked" Unchecked="Geometry_MultiVoidTools_UnChecked"
                        Name="Geometry_MultiVoidTools" Grid.Row="1" Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="2" Text="Warped Parameter Copier"/>
              <CheckBox Checked="Geometry_WarpedParameterCopier_Checked"
                        Unchecked="Geometry_WarpedParameterCopier_UnChecked" Name="Geometry_WarpedParameterCopier"
                        Grid.Row="2" Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="3" Text="MarkOpp Tools"/>
              <CheckBox Checked="Geometry_MarkOppTools_Checked" Unchecked="Geometry_MarkOppTools_UnChecked"
                        Name="Geometry_MarkOppTools" Grid.Row="3" Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="4" Text="Mark Verification Initial"/>
              <CheckBox Checked="Geometry_MarkVerificationInitial_Checked"
                        Unchecked="Geometry_MarkVerificationInitial_UnChecked" Name="Geometry_MarkVerificationInitial"
                        Grid.Row="4" Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="5" Text="Mark Verification Existing"/>
              <CheckBox Checked="Geometry_MarkVerificationExisting_Checked"
                        Unchecked="Geometry_MarkVerificationExisting_UnChecked" Name="Geometry_MarkVerificationExisting"
                        Grid.Row="5" Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="6" Text="Void Hosting Updater"/>
              <CheckBox Checked="Geometry_VoidHostingUpdater_Checked" Unchecked="Geometry_VoidHostingUpdater_UnChecked"
                        Name="Geometry_VoidHostingUpdater" Grid.Row="6" Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="7" Text="New Reference Point"/>
              <CheckBox Checked="Geometry_NewReferencePoint_Checked" Unchecked="Geometry_NewReferencePoint_UnChecked"
                        Name="Geometry_NewReferencePoint" Grid.Row="7" Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="8" Text="Get Centroid"/>
              <CheckBox Checked="Geometry_GetCentroid_Checked" Unchecked="Geometry_GetCentroid_UnChecked"
                        Name="Geometry_GetCentroid" Grid.Row="8" Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="9" Text="Auto Warping"/>
              <CheckBox Checked="Geometry_AutoWarping_Checked" Unchecked="Geometry_AutoWarping_UnChecked"
                        Name="Geometry_AutoWarping" Grid.Row="9" Margin="280,0,130,0"/>
            </Grid>
          </Grid>
          <Grid Row="2">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Margin="24,0,0,0" FontWeight="DemiBold">Insulation Panel</TextBlock>
            <CheckBox Checked="Insulation_Panel_Checked" Unchecked="Insulation_Panel_UnChecked" Name="Insulation_Panel"
                      Margin="222,0,190,0"/>
            <Grid Name="InsulationPanelItem" Row="1">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <TextBlock Margin="40,0,0,0" Grid.Row="0" Text="Insulation Removal"/>
              <CheckBox Checked="Insulation_InsulationRemoval_Checked" Unchecked="Insulation_InsulationRemoval_Unchecked"
                        Name="Insulation_InsulationRemoval" Grid.Row="0" Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="1" Text="Automatic Insulation Placement"/>
              <CheckBox Checked="Insulation_AutoInsulationPlacement_Checked"
                        Unchecked="Insulation_AutoInsulationPlacement_Unchecked" Name="Insulation_AutoInsulationPlacement"
                        Grid.Row="1" Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="2" Text="Manual Insulation Placement"/>
              <CheckBox Checked="Insulation_ManualInsulationPlacement_Checked"
                        Unchecked="Insulation_ManualInsulationPlacement_Unchecked"
                        Name="Insulation_ManualInsulationPlacement" Grid.Row="2" Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="3" Text="Automatic Pin Placement"/>
              <CheckBox Checked="Insulation_AutoPinPlacement_Checked" Unchecked="Insulation_AutoPinPlacement_Unchecked"
                        Name="Insulation_AutoPinPlacement" Grid.Row="3" Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="4" Text="Insulation Marking"/>
              <CheckBox Checked="Insulation_InsulationMarking_Checked" Unchecked="Insulation_InsulationMarking_Unchecked"
                        Name="Insulation_InsulationMarking" Grid.Row="4" Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="5" Text="Insulation Export"/>
              <CheckBox Checked="Insulation_InsulationExport_Checked" Unchecked="Insulation_InsulationExport_Unchecked"
                        Name="Insulation_InsulationExport" Grid.Row="5" Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="6" Text="Insulation Drawing - Master"/>
              <CheckBox Checked="Insulation_InsulationDrawingMaster_Checked"
                        Unchecked="Insulation_InsulationDrawingMaster_Unchecked" Name="Insulation_InsulationDrawingMaster"
                        Grid.Row="6" Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="7" Text="Insulation Drawing - Assembly"/>
              <CheckBox Checked="Insulation_InsulationDrawingPerWall_Checked"
                        Unchecked="Insulation_InsulationDrawingPerWall_Unchecked"
                        Name="Insulation_InsulationDrawingPerWall" Grid.Row="7" Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="8" Text="Insulation Drawing - Mark"/>
              <CheckBox Checked="Insulation_InsulationDrawing_Checked" Unchecked="Insulation_InsulationDrawing_Unchecked"
                        Name="Insulation_InsulationDrawing" Grid.Row="8" Margin="280,0,130,0"/>
            </Grid>
          </Grid>
          <TextBlock Grid.Row="3" Margin="24,0,0,0" FontWeight="DemiBold">Visibility Panel</TextBlock>
          <CheckBox Checked="Visibility_Panel_Checked" Unchecked="Visibility_Panel_UnChecked" Name="Visibility_Panel"
                    Margin="222,0,190,0" Grid.Row="3"/>
          <Grid Row="4">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Margin="24,0,0,0" FontWeight="DemiBold" Text="Selection And Pinning Panel"/>
            <CheckBox Checked="SelectionAndPinning_Panel_Checked" Unchecked="SelectionAndPinning_Panel_UnChecked"
                      Name="SelectionAndPinning_Panel" Margin="222,0,190,0"/>
            <Grid Name="SelectionAndPinningPanelItem" Row="1">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <TextBlock Margin="40,0,0,0">Grids</TextBlock>
              <CheckBox Checked="SelectionAndPinning_Grids_Checked" Unchecked="SelectionAndPinning_Grids_UnChecked"
                        Name="SelectionAndPinning_Grids" Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="1">Levels</TextBlock>
              <CheckBox Checked="SelectionAndPinning_Levels_Checked" Unchecked="SelectionAndPinning_Levels_UnChecked"
                        Name="SelectionAndPinning_Levels" Grid.Row="1" Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="2" Text="Select SF Elements"/>
              <CheckBox Checked="SelectionAndPinning_SelectSFElements_Checked"
                        Unchecked="SelectionAndPinning_SelectSFElements_UnChecked"
                        Name="SelectionAndPinning_SelectSFElements" Grid.Row="2" Margin="280,0,130,0"/>
            </Grid>
          </Grid>
          <Grid Row="5">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Margin="24,0,0,0" FontWeight="DemiBold" Text="Scheduling Panel"/>
            <CheckBox Checked="Scheduling_Panel_Checked" Unchecked="Scheduling_Panel_UnChecked" Name="Scheduling_Panel"
                      Margin="222,0,190,0"/>
            <Grid Name="SchedulingPanelItem" Row="1">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <TextBlock Margin="40,0,0,0" Text="Control Number Incrementor"/>
              <CheckBox Checked="Scheduling_ControlNumberIncrementor_Checked"
                        Unchecked="Scheduling_ControlNumberIncrementor_UnChecked"
                        Name="Scheduling_ControlNumberIncrementor" Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="1" Text="Bom Product Hosting"/>
              <CheckBox Checked="Scheduling_BomProductHosting_Checked" Unchecked="Scheduling_BomProductHosting_UnChecked"
                        Name="Scheduling_BomProductHosting" Grid.Row="1" Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="2" Text="Construction Product Hosting"/>
              <CheckBox Checked="Scheduling_ConstructionProductHosting_Checked"
                        Unchecked="Scheduling_ConstructionProductHosting_UnChecked"
                        Name="Scheduling_ConstructionProductHosting" Grid.Row="2" Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="3" Text="Schedule Sequence by View"/>
              <CheckBox Checked="Scheduling_ScheduleSequenceByView_Checked"
                        Unchecked="Scheduling_ScheduleSequenceByView_UnChecked" Name="Scheduling_ScheduleSequenceByView"
                        Grid.Row="3" Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="4" Text="Erection Sequence Tool"/>
              <CheckBox Checked="Scheduling_Erection_Sequence_Checked" Unchecked="Scheduling_Erection_Sequence_UnChecked"
                        Name="Scheduling_Erection_Sequence" Grid.Row="4" Margin="280,0,130,0"/>
            </Grid>
          </Grid>
          <Grid Row="6">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Margin="24,0,0,0" FontWeight="DemiBold">Assembly Panel</TextBlock>
            <CheckBox Checked="Assembly_Panel_Checked" Unchecked="Assembly_Panel_UnChecked" Name="Assembly_Panel"
                      Margin="222,0,190,0"/>
            <Grid Name="AssemblyPanelItem" Row="1">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <TextBlock Margin="40,0,0,0" Text="Creation Updating Renaming"/>
              <CheckBox Checked="Assembly_CreationUpdatingRenaming_Checked"
                        Unchecked="Assembly_CreationUpdatingRenaming_UnChecked" Name="Assembly_CreationUpdatingRenaming"
                        Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="1" Text="Creation Updating Revit"/>
              <CheckBox Checked="Assembly_CreationUpdatingRevit_Checked"
                        Unchecked="Assembly_CreationUpdatingRevit_UnChecked" Name="Assembly_CreationUpdatingRevit"
                        Grid.Row="1" Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="2" Text="Copy Reinforcing"/>
              <CheckBox Checked="Assembly_CopyReinforcing_Checked" Unchecked="Assembly_CopyReinforcing_UnChecked"
                        Name="Assembly_CopyReinforcing" Grid.Row="2" Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="3" Text="Mark As Reinforced"/>
              <CheckBox Checked="Assembly_MarkAsReinforced_Checked" Unchecked="Assembly_MarkAsReinforced_UnChecked"
                        Name="Assembly_MarkAsReinforced" Grid.Row="3" Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="4" Grid.ColumnSpan="2" Text="Top As Cast"/>
              <CheckBox Checked="Assembly_TopAsCast_Checked" Unchecked="Assembly_TopAsCast_UnChecked"
                        Name="Assembly_TopAsCast" Grid.Row="4" Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="5" Grid.ColumnSpan="3" Text="Match Top As Cast"/>
              <CheckBox Checked="Assembly_MatchTopAsCast_Checked" Unchecked="Assembly_MatchTopAsCast_UnChecked"
                        Name="Assembly_MatchTopAsCast" Grid.Row="5" Margin="280,0,130,0"/>
            </Grid>
          </Grid>
          <Grid Row="7">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Margin="24,0,0,0" FontWeight="DemiBold" Text="Ticket Tools Panel"/>
            <CheckBox Checked="TicketTools_Panel_Checked" Unchecked="TicketTools_Panel_UnChecked"
                      Name="TicketTools_Panel" Margin="222,0,190,0"/>
            <Grid Name="TicketToolsPanelItem" Row="1">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <TextBlock Margin="40,0,0,0" Text="Annotate Embed Long"/>
              <CheckBox Checked="TicketTools_AnnotateEmbedLong_Checked" Unchecked="TicketTools_AnnotateEmbedLong_UnChecked"
                        Name="TicketTools_AnnotateEmbedLong" Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="1" Text="Annotate Embed Short"/>
              <CheckBox Checked="TicketTools_AnnotateEmbedShort_Checked"
                        Unchecked="TicketTools_AnnotateEmbedShort_UnChecked" Name="TicketTools_AnnotateEmbedShort"
                        Grid.Row="1" Margin="280,0,130,0"/>
              <TextBlock Margin="40,0,0,0" Grid.Row="2" Text="Control Number Populator"/>
              <CheckBox Checked="TicketTools_ControlNumberPopulator_Checked"
