        <Setter TargetName="imgChecked" Property="UIElement.Opacity" Value="0"/>
      </Trigger>
      <Trigger Value="{x:Null}" Property="ToggleButton.IsChecked">
        <Setter TargetName="pathChecked" Property="Shape.Stroke" Value="Gray"/>
        <Setter TargetName="pathChecked" Property="UIElement.Opacity" Value="1"/>
        <Setter TargetName="imgChecked" Property="UIElement.Opacity" Value="0"/>
      </Trigger>
    </ControlTemplate.Triggers>
  </ControlTemplate>
</ResourceDictionary>