<Window x:Class="EDGE.TicketTools.TicketManager.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:viewModels="clr-namespace:EDGE.TicketTools.TicketManager.ViewModels"
        Height="Auto" MinHeight="300" MaxHeight="575" MaxWidth="900" WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight" Title="{Binding WindowTitle}">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="10"/>
      <ColumnDefinition Width="*" MaxWidth="980"/>
      <ColumnDefinition Width="10"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="10"/>
      <RowDefinition Height="27"/>
      <RowDefinition Height="*" MaxHeight="390"/>
      <RowDefinition Height="22"/>
      <RowDefinition Height="10"/>
    </Grid.RowDefinitions>
    <Label x:Name="DataGridTitle" Grid.Row="1" Grid.Column="1" FontWeight="Bold" VerticalAlignment="Center"
           HorizontalAlignment="Center" Content="{Binding DataGridLabel}"/>
    <DataGrid x:Name="DataGrid" Grid.Row="2" Grid.Column="1" AutoGenerateColumns="false" Margin="0,0,0,10"
              RowHeight="22" MinRowHeight="22" CanUserAddRows="false" CanUserDeleteRows="false" IsReadOnly="true">
      <FrameworkElement.Resources>
        <Style TargetType="{x:Type DataGridColumnHeader}">
          <Setter Property="Control.HorizontalContentAlignment" Value="Center"/>
        </Style>
      </FrameworkElement.Resources>
      <DataGrid.Columns>
        <DataGridTextColumn Header="Edit #" MinWidth="45" Binding="{Binding EditNumber}">
          <DataGridBoundColumn.ElementStyle>
            <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
              <Setter Property="TextBlock.TextAlignment" Value="Center"/>
            </Style>
          </DataGridBoundColumn.ElementStyle>
        </DataGridTextColumn>
        <DataGridTextColumn Header="Action" MinWidth="80" Width="Auto" Binding="{Binding Action}"/>
        <DataGridTextColumn Header="Date" MinWidth="120" Binding="{Binding Date}">
          <DataGridBoundColumn.ElementStyle>
            <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
              <Setter Property="TextBlock.TextAlignment" Value="Center"/>
            </Style>
          </DataGridBoundColumn.ElementStyle>
        </DataGridTextColumn>
        <DataGridTextColumn Header="User" MinWidth="120" Binding="{Binding User}"/>
        <DataGridTextColumn Header="Comments" MinWidth="400" ScrollViewer.CanContentScroll="true"
                            ScrollViewer.HorizontalScrollBarVisibility="Visible" Binding="{Binding Description}">
          <DataGridBoundColumn.ElementStyle>
            <Style TargetType="{x:Type TextBlock}">
              <Setter Property="TextBlock.TextWrapping" Value="Wrap"/>
            </Style>
          </DataGridBoundColumn.ElementStyle>
        </DataGridTextColumn>
      </DataGrid.Columns>
    </DataGrid>
    <Button Grid.Row="3" Grid.Column="1" Width="75" HorizontalAlignment="Right" Content="Close"
            CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}"
            Command="{Binding CloseCommand}"/>
  </Grid>
</Window>