<Window x:Class="EDGE.AssemblyTools.MarkVerification.ResultsPresentation.MKVerificationResults_Existing"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:EDGE.AssemblyTools.MarkVerification.ResultsPresentation"
        Activated="App_Activated" Title="Mark Verification Results" Height="470" Width="675" MinWidth="675"
        MinHeight="470" WindowStartupLocation="CenterScreen">
  <FrameworkElement.Resources>
    <local:ImagePathConverter x:Key="ImagePathConverter"/>
    <local:PassFailColorConverter x:Key="PassFailColorConverter"/>
    <local:IntToVisibilityConverter x:Key="IntToVisibilityConverter"/>
    <local:RotateImagePathConverter x:Key="RotateImagePathConverter"/>
    <local:CountMultiplierImagePathConverter x:Key="CountMultiplierImagePathConverter"/>
    <local:ExclamationConverters x:Key="ExclamationConverters"/>
    <local:OrangeExclamationConverters x:Key="OrangeExclamationConverters"/>
    <local:VisibilityConverter x:Key="VisibilityConverter"/>
  </FrameworkElement.Resources>
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="3.1*"/>
      <ColumnDefinition Width="5*"/>
    </Grid.ColumnDefinitions>
    <Grid Margin="7">
      <Grid.RowDefinitions>
        <RowDefinition Height="30"/>
        <RowDefinition Height="30"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="60"/>
      </Grid.RowDefinitions>
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="3*"/>
          <ColumnDefinition Width="3*"/>
          <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>
        <Button Click="btnpass_Click" Name="Passed" Content="Passed" Height="20" Width="70"
                VerticalAlignment="Bottom"/>
        <Button Click="btnfail_Click" Name="Failed" Grid.Column="1" Content="Failed" Height="20" Width="70"
                VerticalAlignment="Bottom" Background="Red"/>
        <Button Click="btnall_Click" Name="All" Grid.Column="2" Content="All" Height="20" Width="70"
                VerticalAlignment="Bottom"/>
      </Grid>
      <TextBlock VerticalAlignment="Center" Width="230" Text="Filter list by ControlMark..." Foreground="Gray"
                 HorizontalAlignment="Left" Grid.Row="1" Margin="10,7.6,2,6.8"
                 Visibility="{Binding ElementName=SearchBox, Path=Text.Length, Converter={StaticResource IntToVisibilityConverter}}"/>
      <TextBox TextChanged="SearchBox_TextChanged" x:Name="SearchBox" VerticalAlignment="Center"
               FontWeight="Light" HorizontalAlignment="Left" Width="239" Height="24" Grid.Row="1"
               Margin="7,3.6,-4,2.8" Text="{Binding Search, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
               Background="{x:Null}" BorderBrush="{x:Null}">
        <Control.Template>
          <ControlTemplate TargetType="{x:Type TextBox}">
            <ScrollViewer Name="PART_ContentHost"/>
          </ControlTemplate>
        </Control.Template>
      </TextBox>
      <ListBox SelectionChanged="lstResults_SelectionChanged"
               PreviewMouseLeftButtonDown="lstResults_PreviewMouseLeftButtonDown" Name="lstResults" Grid.Row="2"
               Grid.Column="0" HorizontalContentAlignment="Stretch" Margin="7">
        <ItemsControl.ItemContainerStyle>
          <Style>
            <Setter Property="Control.Padding" Value="0"/>
            <Style.Triggers>
              <Trigger Property="ListBoxItem.IsSelected" Value="true">
                <Setter Property="Control.BorderThickness" Value="5"/>
              </Trigger>
            </Style.Triggers>
          </Style>
        </ItemsControl.ItemContainerStyle>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Grid Margin="0" Background="White">
              <Border Margin="4" BorderThickness="0" BorderBrush="Black"
                      Background="{Binding Path=Verified, Converter={StaticResource PassFailColorConverter}}">
                <Grid Margin="3">
                  <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                  </Grid.RowDefinitions>
                  <TextBlock Grid.Row="1" FontWeight="Bold" Text="{Binding Path=ControlMark}"/>
                  <Grid Row="2">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Grid.ColumnSpan="3" Text="{Binding Path=ConstructionProduct}"/>
                    <Image Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Bottom" Height="20" Width="20"
                           Margin="4,0,0,0"
                           Source="{Binding Path=PlateRotated, Converter={StaticResource RotateImagePathConverter}}"
                           Visibility="{Binding Path=PlateRotated, Converter={StaticResource VisibilityConverter}}"/>
                    <Image Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Height="20" Width="20"
                           Margin="4,0,0,0"
                           Source="{Binding Path=UseCountMultiplier, Converter={StaticResource CountMultiplierImagePathConverter}}"
                           Visibility="{Binding Path=UseCountMultiplier, Converter={StaticResource VisibilityConverter}}"/>
                  </Grid>
                </Grid>
              </Border>
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ListBox>
      <TextBlock Grid.Row="3" Margin="32,7.2,7,36.8" FontSize="11" TextWrapping="WrapWithOverflow">
        - ignored embed and precast rotation
      </TextBlock>
      <Image Grid.Row="3" Height="16" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,7.2,0,0"
             Width="16" Source="{Binding Converter={StaticResource ExclamationConverters}}"/>
      <TextBlock Grid.Row="3" Margin="32,26,7,0" FontSize="11" TextWrapping="WrapWithOverflow">
        - ignored embeds configured to multiply for marks
      </TextBlock>
      <Image Grid.Row="3" Height="16" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,26,0,0"
             Width="16" Source="{Binding Converter={StaticResource OrangeExclamationConverters}}"/>
    </Grid>
    <Border Grid.Column="1" Padding="7" Margin="0 0 2 0" BorderBrush="Black" BorderThickness="1"
            Background="Ivory">
      <Grid Name="gridofresults" DataContext="{Binding ElementName=lstResults, Path=SelectedItem}">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="3.5*"/>
          <ColumnDefinition Width="6*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Margin="4">Control Mark</TextBlock>
        <TextBox Margin="4" Grid.Column="1" IsReadOnly="true" Text="{Binding Path=ControlMark}"/>
        <TextBlock Margin="4" Grid.Row="1">
          Construction Product
        </TextBlock>
        <TextBox Margin="4" Grid.Row="1" Grid.Column="1" IsReadOnly="true" Text="{Binding Path=ConstructionProduct}"/>
        <TextBlock Margin="4" Grid.Row="2">Total Piece Count</TextBlock>
        <TextBox Margin="4" Grid.Row="2" Grid.Column="1" IsReadOnly="true" Text="{Binding Path=PieceCount}"/>
        <TextBlock Margin="4" Grid.Row="3">Verified</TextBlock>
        <TextBox Margin="4" Grid.Row="3" Grid.Column="1" IsReadOnly="true" Text="{Binding Path=Verified}"/>
        <ListBox SelectionChanged="lstTestResults_SelectionChanged" Name="lstTestResults" Grid.Row="6"
                 Grid.Column="0" Grid.ColumnSpan="2" Margin="7,3,7,10" HorizontalContentAlignment="Stretch"
                 ItemsSource="{Binding TestResults}">
          <ItemsControl.ItemContainerStyle>
            <Style>
              <Setter Property="Control.Padding" Value="0"/>
              <Style.Triggers>
                <Trigger Property="ListBoxItem.IsSelected" Value="true">
                  <Setter Property="Control.Background" Value="LightGray"/>
                </Trigger>
              </Style.Triggers>
            </Style>
          </ItemsControl.ItemContainerStyle>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Grid Margin="0" Background="White">
                <Border Margin="5" BorderThickness="2" BorderBrush="Black">
                  <Grid Margin="3">
                    <Grid.RowDefinitions>
                      <RowDefinition/>
                      <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Name="TextBlockforCheck" FontWeight="Bold" Text="{Binding Path=TestName}"
                               ToolTip="{Binding Path=TestDescription}"/>
                    <Image HorizontalAlignment="Right" VerticalAlignment="Bottom" Height="20" Width="20"
                           Source="{Binding Path=ImageDecider, BindingGroupName=NotUsed, Converter={StaticResource ImagePathConverter}}"/>
                  </Grid>
                </Border>
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ListBox>
        <Button Click="DetailButton_Click" Name="DetailButton" Grid.Row="7" Grid.Column="0"
                Content="Check Detail Comparison" Visibility="Hidden"/>
        <Button Click="WarningsBUtton_Click" Name="WarningsBUtton" Grid.Row="7" Grid.Column="1"
                Content="Check Warnings" Margin="0,0,50,0" Visibility="Collapsed" HorizontalAlignment="Center"
                Width="97"/>
        <Button Click="ExportButton_Click" Name="ExportButton" Grid.Row="7" Grid.Column="2"
                HorizontalAlignment="Right" Content="Export" Margin="0,0,7,0" Width="56"/>
      </Grid>
    </Border>
  </Grid>
</Window>