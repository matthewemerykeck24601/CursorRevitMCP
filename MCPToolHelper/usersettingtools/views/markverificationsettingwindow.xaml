<Window x:Class="EDGE.UserSettingTools.Views.MarkVerificationSettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:EDGE.UserSettingTools.Views"
        Height="470" Width="700" MinHeight="470" MinWidth="700" Title="Mark Verification Settings Window"
        WindowStartupLocation="CenterScreen">
  <FrameworkElement.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/EDGEforREVIT;component/EDGELogo.xaml"/>
      </ResourceDictionary.MergedDictionaries>
      <local:Converters x:Key="Converter"/>
    </ResourceDictionary>
  </FrameworkElement.Resources>
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="1.6*"/>
      <ColumnDefinition Width="5*"/>
    </Grid.ColumnDefinitions>
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="4*"/>
        <RowDefinition Height="3*"/>
        <RowDefinition Height="1*"/>
      </Grid.RowDefinitions>
      <ListBox SelectionChanged="Setting_Selected" Name="Setting" Margin="0,0,0.2,0.2">
        <ItemsControl.ItemContainerStyle>
          <Style>
            <Setter Property="Control.Padding" Value="0"/>
            <Style.Triggers>
              <Trigger Property="ListBoxItem.IsSelected" Value="true">
                <Setter Property="Control.Background" Value="LightSteelBlue"/>
              </Trigger>
            </Style.Triggers>
          </Style>
        </ItemsControl.ItemContainerStyle>
        <ListBoxItem Margin="5" FontWeight="DemiBold" HorizontalAlignment="Left" Height="25" Width="145"
                     Content="Mark Setting"/>
        <ListBoxItem Margin="5" FontWeight="DemiBold" HorizontalAlignment="Left" Height="25" Width="145"
                     Content="Mark Tolerance Setting"/>
      </ListBox>
      <ContentControl Template="{StaticResource EDGELogoStyle}" Grid.Row="1" HorizontalAlignment="Stretch"
                      VerticalAlignment="Bottom" Height="60" Margin="5,0,0,0"/>
      <Button Click="ApplyButton_Click" Grid.Row="2" VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
              Height="20" Margin="3">Apply Settings</Button>
    </Grid>
    <GridSplitter Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="5"/>
    <Grid Column="1">
      <Border Name="GeneralSettingPanelBorder" Padding="7" Margin="7" Visibility="Visible">
        <Grid Name="GeneralSettingPanel" Visibility="Visible">
          <ScrollViewer VerticalScrollBarVisibility="Visible">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width=".9*"/>
                <ColumnDefinition Width=".9*"/>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width=".75*"/>
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition x:Name="Row1" Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <TextBlock>Incrementor:</TextBlock>
              <RadioButton Checked="NumRadioButton_Checked" x:Name="NumRadioButton" Grid.Column="0" Grid.Row="0"
                           Content="Numerical" Margin="80,2,0,0" GroupName="IncrementorName"/>
              <RadioButton Checked="AlphaRadioButton_Checked" x:Name="AlphaRadioButton" Grid.Column="1" Grid.Row="0"
                           Content="Alphabetical" Margin="0,2,-20,0" GroupName="IncrementorName"/>
              <TextBox Name="NewProductName" Grid.Row="2" Grid.Column="0" VerticalAlignment="Stretch"
                       HorizontalAlignment="Stretch" Margin="0,5">
                <FrameworkElement.Style>
                  <Style xmlns:sys="clr-namespace:System;assembly=mscorlib"
                         TargetType="{x:Type TextBox}">
                    <Style.Resources>
                      <VisualBrush x:Key="CueBannerBrush" AlignmentX="Left" AlignmentY="Center" Stretch="None">
                        <VisualBrush.Visual>
                          <Label Content="Enter New Product Name" Foreground="Gray"/>
                        </VisualBrush.Visual>
                      </VisualBrush>
                    </Style.Resources>
                    <Style.Triggers>
                      <Trigger Property="TextBox.Text" Value="{x:Static sys:String.Empty}">
                        <Setter Property="Control.Background" Value="{StaticResource CueBannerBrush}"/>
                      </Trigger>
                      <Trigger Property="TextBox.Text" Value="{x:Null}">
                        <Setter Property="Control.Background" Value="{StaticResource CueBannerBrush}"/>
                      </Trigger>
                      <Trigger Property="UIElement.IsKeyboardFocused" Value="true">
                        <Setter Property="Control.Background" Value="White"/>
                      </Trigger>
                    </Style.Triggers>
                  </Style>
                </FrameworkElement.Style>
              </TextBox>
              <TextBox PreviewTextInput="MarkPrefix_PreviewTextInput" Name="IncrementorTxt" Grid.Row="1" Grid.Column="0"
                       VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="0,5">
                <FrameworkElement.Style>
                  <Style xmlns:sys="clr-namespace:System;assembly=mscorlib"
                         TargetType="{x:Type TextBox}">
                    <Style.Resources>
                      <VisualBrush x:Key="CueBannerBrush" AlignmentX="Left" AlignmentY="Center" Stretch="None">
                        <VisualBrush.Visual>
                          <Label Content="Min Integer Value" Foreground="Gray"/>
                        </VisualBrush.Visual>
                      </VisualBrush>
                    </Style.Resources>
                    <Style.Triggers>
                      <Trigger Property="TextBox.Text" Value="{x:Static sys:String.Empty}">
                        <Setter Property="Control.Background" Value="{StaticResource CueBannerBrush}"/>
                      </Trigger>
                      <Trigger Property="TextBox.Text" Value="{x:Null}">
                        <Setter Property="Control.Background" Value="{StaticResource CueBannerBrush}"/>
                      </Trigger>
                      <Trigger Property="UIElement.IsKeyboardFocused" Value="true">
                        <Setter Property="Control.Background" Value="White"/>
                      </Trigger>
                    </Style.Triggers>
                  </Style>
                </FrameworkElement.Style>
              </TextBox>
              <Button Name="FakeBtn" Grid.Row="1" Grid.Column="1" VerticalAlignment="Stretch" Visibility="Hidden"
                      Content="Add" Margin="5"/>
              <Button Click="AddNewButton_Click" Name="AddNewAdmin" Grid.Row="2" Grid.Column="1"
                      VerticalAlignment="Stretch" Content="Add" Margin="5"/>
              <Button Click="DeleteButton_Click" Name="DeleteAdmin" Grid.Row="2" Grid.Column="2"
                      VerticalAlignment="Stretch" Content="Delete" Visibility="Hidden" Margin="5"/>
              <DataGrid SelectionChanged="Mark_Prefix_List_SelectionChanged" Name="Mark_Prefix_List"
                        AutoGenerateColumns="false" CanUserAddRows="false" Margin="0,5,0,0" HorizontalAlignment="Left"
                        Grid.Row="3" Grid.ColumnSpan="5">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Product Name" IsReadOnly="true" Width="6*" Binding="{Binding productName}"/>
                  <DataGridTextColumn Header="Mark Prefix" IsReadOnly="false" Width="5*" Binding="{Binding markPrefix}"/>
                  <DataGridTextColumn Header="Mark Suffix" IsReadOnly="false" Width="5*" Binding="{Binding markSuffix}"/>
                </DataGrid.Columns>
              </DataGrid>
            </Grid>
          </ScrollViewer>
        </Grid>
      </Border>
      <Border Name="StraightBarSettingPanelBorder" Padding="7" Margin="7" Visibility="Visible">
        <Grid Name="StraightBarSettingPanel" Visibility="Hidden" MaxWidth="500">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="0.8*"/>
            <ColumnDefinition Width="0.1*"/>
            <ColumnDefinition Width="0.8*"/>
            <ColumnDefinition Width="0.2*"/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <TextBlock Name="FractionToleranceLabel" Margin="10,15,0,0" FontSize="11" FontWeight="Bold"
                     HorizontalAlignment="Left">Fraction Tolerance</TextBlock>
          <TextBlock Grid.Row="1" Margin="10,15,0,0" FontSize="11" FontWeight="DemiBold" HorizontalAlignment="Left">Geometry:</TextBlock>
          <TextBox TextChanged="FracOption_TextChanged" Name="FracOption" Margin="125,11,87,2" Grid.Row="1"
                   Grid.ColumnSpan="2" BorderBrush="Black"/>
          <TextBlock Name="FeetLabel" Grid.Row="1" Grid.Column="1" FontSize="11" FontWeight="DemiBold"
                     VerticalAlignment="Center" HorizontalAlignment="Left" Margin="50,15,0,5">ft</TextBlock>
          <TextBox TextChanged="FracOptionInch_TextChanged" Name="FracOptionInch" Margin="76,11,87,2" Grid.Row="1"
                   Grid.Column="1" Grid.ColumnSpan="3" BorderBrush="Black"/>
          <TextBlock Name="InchLabel" Grid.Row="1" Grid.Column="3" FontSize="11" FontWeight="DemiBold"
                     VerticalAlignment="Center" HorizontalAlignment="Left" Margin="50,15,0,5">inch</TextBlock>
          <TextBlock Grid.Row="2" Margin="10,15,0,0" FontSize="11" FontWeight="DemiBold" HorizontalAlignment="Left">Embed Position:</TextBlock>
          <TextBox TextChanged="FracOption_TextChanged" Name="FracOption2" Margin="125,11,87,2" Grid.Row="2"
                   Grid.ColumnSpan="2" BorderBrush="Black"/>
          <TextBlock Name="FeetLabel2" Grid.Row="2" Grid.Column="1" FontSize="11" FontWeight="DemiBold"
                     VerticalAlignment="Center" HorizontalAlignment="Left" Margin="50,15,0,5">ft</TextBlock>
          <TextBox TextChanged="FracOptionInch_TextChanged" Name="FracOption2Inch" Margin="76,11,87,2" Grid.Row="2"
                   Grid.Column="1" Grid.ColumnSpan="3" BorderBrush="Black"/>
          <TextBlock Name="InchLabel2" Grid.Row="2" Grid.Column="3" FontSize="11" FontWeight="DemiBold"
                     VerticalAlignment="Center" HorizontalAlignment="Left" Margin="50,15,0,5">inch</TextBlock>
          <TextBlock Name="DecimalToleranceLabel" Grid.Row="5" Margin="10,15,0,0" FontSize="11" FontWeight="Bold"
                     HorizontalAlignment="Left">Decimal Tolerance</TextBlock>
          <TextBlock Grid.Row="6" Margin="10,15,0,0" FontSize="11" FontWeight="DemiBold" HorizontalAlignment="Left">Volume:</TextBlock>
          <TextBox TextChanged="DecimalOption_TextChanged" Name="DecimalOption" Margin="125,11,87,2" Grid.Row="6"
                   Grid.ColumnSpan="2" BorderBrush="Black"/>
          <TextBlock Name="VolumeUnitLabel" Grid.Row="6" Grid.Column="1" FontSize="11" FontWeight="DemiBold"
                     VerticalAlignment="Center" Grid.ColumnSpan="2" Margin="50,15,0,5">cubic feet</TextBlock>
          <TextBlock Grid.Row="7" Margin="10,15,0,0" FontSize="11" FontWeight="DemiBold" HorizontalAlignment="Left">Addon Volume:</TextBlock>
          <TextBox TextChanged="DecimalOption_TextChanged" Name="DecimalOption2" Margin="125,11,87,2" Grid.Row="7"
                   Grid.ColumnSpan="2" BorderBrush="Black"/>
          <TextBlock Name="VolumeUnitLabel2" Grid.Row="7" Grid.Column="1" FontSize="11" FontWeight="DemiBold"
                     VerticalAlignment="Center" Grid.ColumnSpan="2" Margin="50,15,0,5">cubic feet</TextBlock>
          <TextBlock Grid.Row="8" Margin="10,15,0,0" FontSize="11" FontWeight="DemiBold" HorizontalAlignment="Left">Finish Area:</TextBlock>
          <TextBox TextChanged="DecimalOption_TextChanged" Name="DecimalOption4" Margin="125,11,87,2" Grid.Row="8"
                   Grid.ColumnSpan="2" BorderBrush="Black"/>
          <TextBlock Name="AreaUnitLabel" Grid.Row="8" Grid.Column="1" FontSize="11" FontWeight="DemiBold"
                     VerticalAlignment="Center" Grid.ColumnSpan="2" Margin="50,15,0,5">sq feet</TextBlock>
          <TextBlock Grid.Row="9" Margin="10,15,0,0" FontSize="11" FontWeight="DemiBold" HorizontalAlignment="Left">Weight:</TextBlock>
          <TextBox TextChanged="DecimalOption_TextChanged" Name="DecimalOption5" Margin="125,11,87,2" Grid.Row="9"
                   Grid.ColumnSpan="2" BorderBrush="Black"/>
          <TextBlock Name="WeightUnitLabel" Grid.Row="9" Grid.Column="1" FontSize="11" FontWeight="DemiBold"
                     VerticalAlignment="Center" Grid.ColumnSpan="2" Margin="50,15,0,5">pound</TextBlock>
          <TextBlock Grid.Row="10" Margin="10,15,0,0" FontSize="11" FontWeight="DemiBold" HorizontalAlignment="Left">
            Plate/Addon Rotation:
          </TextBlock>
          <TextBox TextChanged="DecimalOption_TextChanged" Name="DecimalOption6" Margin="125,11,87,2" Grid.Row="10"
                   Grid.ColumnSpan="2" BorderBrush="Black"/>
          <TextBlock Grid.Row="10" Grid.Column="1" FontSize="11" FontWeight="DemiBold" VerticalAlignment="Center"
                     Grid.ColumnSpan="2" Margin="50,15,0,5">degrees</TextBlock>
          <Button Click="UnitChangeButton_Click" Name="UnitChangeButton" Grid.Row="11" Grid.Column="0"
                  Visibility="Hidden" Width="95" Margin="10,20,84,-20">Change Units</Button>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Window>