<Window x:Class="EDGE.UserSettingTools.Views.RebarUserSettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:EDGE.UserSettingTools.Views"
        Activated="App_Activated" Height="480" Width="800" MinHeight="500" MinWidth="800"
        Title="Rebar Settings Window" WindowStartupLocation="CenterScreen">
  <FrameworkElement.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/EDGEforREVIT;component/EDGELogo.xaml"/>
      </ResourceDictionary.MergedDictionaries>
      <local:Converters x:Key="Converter"/>
    </ResourceDictionary>
  </FrameworkElement.Resources>
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="1.4*"/>
      <ColumnDefinition Width="5*"/>
    </Grid.ColumnDefinitions>
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="4*"/>
        <RowDefinition Height="3*"/>
        <RowDefinition Height="1*"/>
      </Grid.RowDefinitions>
      <ListBox SelectionChanged="Setting_Selected" Name="Setting" Margin="0,0,0.2,0.2">
        <ItemsControl.ItemContainerStyle>
          <Style>
            <Setter Property="Control.Padding" Value="0"/>
            <Style.Triggers>
              <Trigger Property="ListBoxItem.IsSelected" Value="true">
                <Setter Property="Control.Background" Value="LightSteelBlue"/>
              </Trigger>
            </Style.Triggers>
          </Style>
        </ItemsControl.ItemContainerStyle>
        <ListBoxItem Margin="5" FontWeight="DemiBold" HorizontalAlignment="Left" Height="25" Width="145">Bent Rebar Settings</ListBoxItem>
        <ListBoxItem Margin="5" FontWeight="DemiBold" HorizontalAlignment="Left" Height="25" Width="145">
          Straight Rebar Settings
        </ListBoxItem>
        <ListBoxItem Margin="5" FontWeight="DemiBold" HorizontalAlignment="Left" Height="25" Width="145">
          Standard Rebar Settings
        </ListBoxItem>
      </ListBox>
      <ContentControl Template="{StaticResource EDGELogoStyle}" Grid.Row="1" HorizontalAlignment="Stretch" Height="60"
                      VerticalAlignment="Bottom" Margin="5,0,0,0"/>
      <Button Click="ApplyButton_Click" Grid.Row="2" HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
              Height="20" Margin="3">Apply Settings</Button>
    </Grid>
    <GridSplitter Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="5"/>
    <Grid Column="1">
      <Border Name="GeneralSettingPanelBorder" Padding="7" Margin="7" Visibility="Visible">
        <Grid Name="GeneralSettingPanel" Visibility="Visible">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="40*"/>
            <ColumnDefinition Width="40*"/>
            <ColumnDefinition Width="150*"/>
            <ColumnDefinition Width="59*"/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <TextBlock Margin="0,7,6.6,6.6" FontSize="11" FontWeight="DemiBold" HorizontalAlignment="Right"
                     Grid.Column="1">Manufacturer</TextBlock>
          <TextBox Name="manufacturer" Margin="5.4,5,4.6,4.6" Grid.Column="2" IsReadOnly="true" BorderBrush="Black"/>
          <TextBlock Name="UseMetricLabel" Margin="0,7.4,6.6,6.2" Grid.Row="3" FontSize="11" FontWeight="DemiBold"
                     HorizontalAlignment="Right" Grid.ColumnSpan="2">Use Metric</TextBlock>
          <CheckBox Checked="useMetricEuropean_Checked" Unchecked="useMetricEuropean_Unchecked"
                    Name="useMetricCanadian" Margin="7,7.2,6.6,7.2" Grid.Column="2" Grid.Row="3" BorderBrush="Black">
            <FrameworkElement.ToolTip>
              <ToolTip Width="480">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>
                  <TextBlock>
                    By checking the checkbox, the value of the parameter is set to be true. Otherwise false.
                  </TextBlock>
                  <TextBlock Grid.Row="1">
                    TRUE = bar sizes will be in US Metric 10,13,19 etc.
                  </TextBlock>
                  <TextBlock Grid.Row="2">
                    FALSE = bar sizes will be in US Imperial 3,4,5 etc.
                  </TextBlock>
                </Grid>
              </ToolTip>
            </FrameworkElement.ToolTip>
          </CheckBox>
          <TextBlock Margin="0,7,6.6,6.6" Grid.Row="4" FontSize="11" FontWeight="DemiBold" HorizontalAlignment="Right"
                     Grid.Column="1">Mark Prefix</TextBlock>
          <TextBox Name="markPrefix" Margin="5.4,5,4.6,4.6" Grid.Column="2" Grid.Row="4" BorderBrush="Black"/>
          <TextBlock Margin="0,7,6.6,6.6" Grid.Row="5" FontSize="11" FontWeight="DemiBold" HorizontalAlignment="Right"
                     Grid.Column="1">Mark Suffix</TextBlock>
          <TextBox Name="markSuffix" Margin="5.4,5,4.6,4.6" Grid.Column="2" Grid.Row="5" BorderBrush="Black"/>
          <TextBlock Margin="0,7.4,6.6,6.2" Grid.Row="6" FontSize="11" FontWeight="DemiBold" HorizontalAlignment="Right"
                     Grid.ColumnSpan="2">
            Leading Zero for Diameter
          </TextBlock>
          <CheckBox Checked="padBarSizesWithLeadingZero_Checked" Unchecked="padBarSizesWithLeadingZero_Unchecked"
                    Name="padBarSizesWithLeadingZero" Margin="7.4,7.4,6.6,7.2" Grid.Column="2" Grid.Row="6"
                    BorderBrush="Black">
            <FrameworkElement.ToolTip>
              <ToolTip Width="480">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>
                  <TextBlock>
                    By checking the checkbox, the value of the parameter is set to be true. Otherwise false.
                  </TextBlock>
                  <TextBlock Grid.Row="1">
                    e.g. If TRUE a #6 will be 06 in control marks instead of 6.
                  </TextBlock>
                  <TextBlock Grid.Row="2">
                    And number signs will not be included in control marks.
                  </TextBlock>
                </Grid>
              </ToolTip>
            </FrameworkElement.ToolTip>
          </CheckBox>
          <TextBlock Margin="0,7,6.6,6.6" Grid.Row="7" FontSize="11" FontWeight="DemiBold" HorizontalAlignment="Right"
                     Grid.ColumnSpan="2">Min Integer Value</TextBlock>
          <TextBox Name="markPrefixIntMinValue" Margin="5.4,5,4.6,4.6" Grid.Column="2" Grid.Row="7"
                   BorderBrush="Black">
            <FrameworkElement.ToolTip>
              <ToolTip Width="480">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>
                  <TextBlock>
                    Min Integer Value should be the minimum integer value of marks to generate,
                  </TextBlock>
                  <TextBlock Grid.Row="1">
                    provide padding zeros to the left to indicate level of zero padding.
                  </TextBlock>
                  <TextBlock Grid.Row="2">
                    e.g. 005 will have marks 006, 099, 999, 1000,etc.
                  </TextBlock>
                </Grid>
              </ToolTip>
            </FrameworkElement.ToolTip>
          </TextBox>
          <TextBlock Margin="0,7.4,6.6,6.2" Grid.Row="8" FontSize="11" FontWeight="DemiBold" HorizontalAlignment="Right"
                     Grid.Column="1">Galvanized</TextBlock>
          <TextBox Name="markFinishGalvanized" Margin="5.4,5.4,4.6,4.2" Grid.Column="2" Grid.Row="8"
                   BorderBrush="Black" ToolTip="Galvanized can be anything but must begin with a letter."/>
          <TextBlock Margin="0,6.8,6.6,6.8" Grid.Row="9" FontSize="11" FontWeight="DemiBold" HorizontalAlignment="Right"
                     Grid.Column="1">Epoxy</TextBlock>
          <TextBox Name="markFinishEpoxy" Margin="5.4,4.8,4.6,4.8" Grid.Column="2" Grid.Row="9" BorderBrush="Black"
                   ToolTip="Epoxy can be anything but must begin with a letter."/>
        </Grid>
      </Border>
      <Border Name="StraightBarSettingPanelBorder" Padding="7" Margin="7" Visibility="Hidden">
        <Grid Name="StraightBarSettingPanel" Visibility="Hidden">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.5*"/>
            <ColumnDefinition Width="2.5*"/>
            <ColumnDefinition Width="1*"/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <TextBlock Margin="7" FontSize="11" FontWeight="DemiBold" HorizontalAlignment="Right">Straight Bar Prefix</TextBlock>
          <TextBox Name="straightBarMarkPrefix" Margin="5" Grid.Column="1" BorderBrush="Black"/>
          <TextBlock Margin="7" Grid.Row="1" FontSize="11" FontWeight="DemiBold" HorizontalAlignment="Right">Length Option</TextBlock>
          <ComboBox Loaded="straightBarLengthOption_Loaded" SelectionChanged="straightBarLengthOption_Selected"
                    Name="straightBarLengthOption" Margin="5" Grid.Column="1" Grid.Row="1">
            <FrameworkElement.ToolTip>
              <ToolTip Width="680">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>
                  <TextBlock>Options:</TextBlock>
                  <TextBlock Name="ToolTipLine1" Grid.Row="1">
                    FEETANDINCHES = show straight bar control marks with feet and inches. E.g., a 10 foot #3 bar = 31000 (10 feet and 0 inches).
                  </TextBlock>
                  <TextBlock Name="ToolTipLine2" Grid.Row="2">
                    INCHES = show straight bars in inches only. E.g., a 10 foot #3 bar = 3120.
                  </TextBlock>
                  <TextBlock Name="ToolTipLine3" Grid.Row="3">
                    NONE = show only the bar size. E.g., a 10 foot #3 bar = 3.
                  </TextBlock>
                  <TextBlock Name="ToolTipLine4" Grid.Row="4" Visibility="Collapsed">
                    NONE = show only the bar size. E.g., a 5 Meter #6 bar = 6.
                  </TextBlock>
                </Grid>
              </ToolTip>
            </FrameworkElement.ToolTip>
          </ComboBox>
          <TextBlock Name="straightBarLengthZeroPaddingTextblock" Margin="7" Grid.Row="2" FontSize="11"
                     FontWeight="DemiBold" HorizontalAlignment="Right" Visibility="Hidden">
            Minimum Length Unit Count
          </TextBlock>
          <TextBox Name="straightBarLengthZeroPadding" Margin="5" Grid.Column="1" Grid.Row="2" BorderBrush="Black"
                   Visibility="Hidden">
            <FrameworkElement.ToolTip>
              <ToolTip Width="550" Height="Auto">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>
                  <TextBlock>
                    This settings allows you to specify provided padding zeros to the left of straight length.
                  </TextBlock>
                  <TextBlock Grid.Row="1">
                    To indicate level of zero padding enter what a number 1 (one inch) should look like in the mark.
                  </TextBlock>
                  <TextBlock Grid.Row="2">
                    e.g. 01 will have inch lengths shown 01, 09, 99, 100, ...
                  </TextBlock>
                  <TextBlock Grid.Row="3">
                    001 will display 001, 099, 999, 1000, ...
                  </TextBlock>
                </Grid>
              </ToolTip>
            </FrameworkElement.ToolTip>
          </TextBox>
        </Grid>
      </Border>
      <Border Name="StandardBarSettingPanelBorder" Padding="7" Margin="7" Visibility="Hidden">
        <Grid Name="StandardBarSettingPanel" Visibility="Visible" Margin="10,0,0,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="5*"/>
            <RowDefinition Height="7*"/>
          </Grid.RowDefinitions>
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="1*"/>
              <RowDefinition Height="6*"/>
            </Grid.RowDefinitions>
            <TextBlock FontWeight="DemiBold" Width="100" HorizontalAlignment="Left">Existing Items:</TextBlock>
            <Button Click="DeleteItem_Click" Name="DeleteItem" Width="74" HorizontalAlignment="Right"
                    Margin="0,0,7.6,0.4">Delete Item</Button>
            <DataGrid SelectionChanged="NotUseMetricDataGrid_SelectionChanged" MouseDown="DataGrid_MouseDown"
                      TargetUpdated="existingSettingNotUseMetric_TargetUpdated" Name="existingSettingNotUseMetric"
                      Margin="0,6,6,6" Grid.Row="1" AutoGenerateColumns="false" Visibility="Visible">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Diameter" Width="Auto" IsReadOnly="true" Binding="{Binding rebarDiameter}"/>
                <DataGridTextColumn Header="Shape" Width="Auto" IsReadOnly="true" Binding="{Binding rebarShape}"/>
                <DataGridTextColumn Header="Mark" Width="Auto" IsReadOnly="true"
                                    Binding="{Binding rebarMark, NotifyOnTargetUpdated=true}"/>
                <DataGridTextColumn Header="A" Width="Auto" IsReadOnly="true" Binding="{Binding rebarA}"/>
                <DataGridTextColumn Header="B" Width="Auto" IsReadOnly="true" Binding="{Binding rebarB}"/>
                <DataGridTextColumn Header="C" Width="Auto" IsReadOnly="true" Binding="{Binding rebarC}"/>
                <DataGridTextColumn Header="D" Width="Auto" IsReadOnly="true" Binding="{Binding rebarD}"/>
                <DataGridTextColumn Header="E" Width="Auto" IsReadOnly="true" Binding="{Binding rebarE}"/>
                <DataGridTextColumn Header="F" Width="Auto" IsReadOnly="true" Binding="{Binding rebarF}"/>
                <DataGridTextColumn Header="G" Width="Auto" IsReadOnly="true" Binding="{Binding rebarG}"/>
                <DataGridTextColumn Header="H" Width="Auto" IsReadOnly="true" Binding="{Binding rebarH}"/>
                <DataGridTextColumn Header="J" Width="Auto" IsReadOnly="true" Binding="{Binding rebarJ}"/>
                <DataGridTextColumn Header="K" Width="Auto" IsReadOnly="true" Binding="{Binding rebarK}"/>
                <DataGridTextColumn Header="O" Width="Auto" IsReadOnly="true" Binding="{Binding rebarO}"/>
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
          <Border Name="editingItemBorder" Grid.Row="1" BorderThickness="1" BorderBrush="SteelBlue"
                  Visibility="Visible"/>
          <Grid Name="editingItemPanelNotUseMatric" Row="1" Visibility="Visible">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="2.5*"/>
              <ColumnDefinition Width="3*"/>
              <ColumnDefinition Width="1*"/>
              <ColumnDefinition Width="3*"/>
              <ColumnDefinition Width="1*"/>
              <ColumnDefinition Width="2*"/>
              <ColumnDefinition Width="3*"/>
              <ColumnDefinition Width="1*"/>
              <ColumnDefinition Width="3*"/>
              <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Margin="0,7,6,6.8" HorizontalAlignment="Right">Diameter*:</TextBlock>
            <ComboBox Loaded="barSizeBoxNotUseMetric_Loaded" Name="barSizeBoxNotUseMetric" Grid.Column="1"
                      Margin="5,5,10.4,4.8" Grid.ColumnSpan="2"/>
            <TextBlock Margin="7" Grid.Row="1" HorizontalAlignment="Right">Shape*:</TextBlock>
            <TextBox Name="ShapTextBoxNotUseMetric" Margin="5,5,10,5" Grid.Row="1" Grid.Column="1" IsReadOnly="true"
                     Grid.ColumnSpan="2"/>
            <Button Click="ShapeButton_Click" Name="ShapeButtonNotUseMetric" Grid.Row="1" Grid.Column="3" Margin="5">Browse...</Button>
            <TextBlock Margin="7" Grid.Row="2" HorizontalAlignment="Right">Mark*:</TextBlock>
            <TextBox Name="MarkTextBoxNotUseMetric" Margin="5,4.8,10.4,4.6" Grid.Row="2" Grid.Column="1"
                     Grid.ColumnSpan="2"/>
            <TextBlock Margin="7" Grid.Row="3" HorizontalAlignment="Right">A:</TextBlock>
            <TextBox Name="ATextBoxFeet" Margin="5" Grid.Row="3" Grid.Column="1"/>
            <TextBlock Name="ALabelFeet" Margin="0,7.2,0,0" Grid.Row="3" Grid.Column="2" HorizontalAlignment="Left"
                       Height="17" VerticalAlignment="Top">ft</TextBlock>
            <TextBox Name="ATextBoxInch" Margin="5" Grid.Row="3" Grid.Column="3"/>
            <TextBlock Name="ALabelInch" Margin="0,7.2,0,0" Grid.Row="3" Grid.Column="4" HorizontalAlignment="Left"
                       Height="17" VerticalAlignment="Top">in</TextBlock>
            <TextBlock Margin="7" Grid.Row="4" HorizontalAlignment="Right">B:</TextBlock>
            <TextBox Name="BTextBoxFeet" Margin="5" Grid.Row="4" Grid.Column="1"/>
            <TextBlock Name="BLabelFeet" Margin="0,7.2,0,0" Grid.Row="4" Grid.Column="2" HorizontalAlignment="Left"
                       Height="17" VerticalAlignment="Top">ft</TextBlock>
            <TextBox Name="BTextBoxInch" Margin="5" Grid.Row="4" Grid.Column="3"/>
            <TextBlock Name="BLabelInch" Margin="0,7.2,0,0" Grid.Row="4" Grid.Column="4" HorizontalAlignment="Left"
                       Height="17" VerticalAlignment="Top">in</TextBlock>
            <TextBlock Margin="7" Grid.Row="5" HorizontalAlignment="Right">C:</TextBlock>
            <TextBox Name="CTextBoxFeet" Margin="5" Grid.Row="5" Grid.Column="1"/>
            <TextBlock Name="CLabelFeet" Margin="0,7.2,0,0" Grid.Row="5" Grid.Column="2" HorizontalAlignment="Left"
                       Height="17" VerticalAlignment="Top">ft</TextBlock>
            <TextBox Name="CTextBoxInch" Margin="5" Grid.Row="5" Grid.Column="3"/>
            <TextBlock Name="CLabelInch" Margin="0,7.2,0,0" Grid.Row="5" Grid.Column="4" HorizontalAlignment="Left"
                       Height="17" VerticalAlignment="Top">in</TextBlock>
            <TextBlock Margin="7" Grid.Row="6" HorizontalAlignment="Right">D:</TextBlock>
            <TextBox Name="DTextBoxFeet" Margin="5" Grid.Row="6" Grid.Column="1"/>
            <TextBlock Name="DLabelFeet" Margin="0,7.2,0,0" Grid.Row="6" Grid.Column="2" HorizontalAlignment="Left"
                       Height="17" VerticalAlignment="Top">ft</TextBlock>
            <TextBox Name="DTextBoxInch" Margin="5" Grid.Row="6" Grid.Column="3"/>
            <TextBlock Name="DLabelInch" Margin="0,7.2,0,0" Grid.Row="6" Grid.Column="4" HorizontalAlignment="Left"
                       Height="17" VerticalAlignment="Top">in</TextBlock>
            <TextBlock Margin="7" Grid.Column="5" HorizontalAlignment="Right">E:</TextBlock>
            <TextBox Name="ETextBoxFeet" Margin="5" Grid.Column="6"/>
            <TextBlock Name="ELabelFeet" Margin="0,7.2,0,0" Grid.Column="7" HorizontalAlignment="Left" Height="17"
                       VerticalAlignment="Top">ft</TextBlock>
            <TextBox Name="ETextBoxInch" Margin="5" Grid.Column="8"/>
            <TextBlock Name="ELabelInch" Margin="0,7.2,0,0" Grid.Column="9" HorizontalAlignment="Left" Height="17"
                       VerticalAlignment="Top">in</TextBlock>
            <TextBlock Margin="7" Grid.Row="1" Grid.Column="5" HorizontalAlignment="Right">F:</TextBlock>
            <TextBox Name="FTextBoxFeet" Margin="5" Grid.Row="1" Grid.Column="6"/>
            <TextBlock Name="FLabelFeet" Margin="0,7.2,0,0" Grid.Row="1" Grid.Column="7" HorizontalAlignment="Left"
                       Height="17" VerticalAlignment="Top">ft</TextBlock>
            <TextBox Name="FTextBoxInch" Margin="5" Grid.Row="1" Grid.Column="8"/>
            <TextBlock Name="FLabelInch" Margin="0,7.2,0,0" Grid.Row="1" Grid.Column="9" HorizontalAlignment="Left"
                       Height="17" VerticalAlignment="Top">in</TextBlock>
            <TextBlock Margin="7" Grid.Row="2" Grid.Column="5" HorizontalAlignment="Right">G:</TextBlock>
            <TextBox Name="GTextBoxFeet" Margin="5" Grid.Row="2" Grid.Column="6"/>
            <TextBlock Name="GLabelFeet" Margin="0,7.2,0,0" Grid.Row="2" Grid.Column="7" HorizontalAlignment="Left"
                       Height="17" VerticalAlignment="Top">ft</TextBlock>
            <TextBox Name="GTextBoxInch" Margin="5" Grid.Row="2" Grid.Column="8"/>
            <TextBlock Name="GLabelInch" Margin="0,7.2,0,0" Grid.Row="2" Grid.Column="9" HorizontalAlignment="Left"
                       Height="17" VerticalAlignment="Top">in</TextBlock>
            <TextBlock Margin="7" Grid.Row="3" Grid.Column="5" HorizontalAlignment="Right">H:</TextBlock>
            <TextBox Name="HTextBoxFeet" Margin="5" Grid.Row="3" Grid.Column="6"/>
            <TextBlock Name="HLabelFeet" Margin="0,7.2,0,0" Grid.Row="3" Grid.Column="7" HorizontalAlignment="Left"
                       Height="17" VerticalAlignment="Top">ft</TextBlock>
            <TextBox Name="HTextBoxInch" Margin="5" Grid.Row="3" Grid.Column="8"/>
            <TextBlock Name="HLabelInch" Margin="0,7.2,0,0" Grid.Row="3" Grid.Column="9" HorizontalAlignment="Left"
                       Height="17" VerticalAlignment="Top">in</TextBlock>
            <TextBlock Margin="7" Grid.Row="4" Grid.Column="5" HorizontalAlignment="Right">J:</TextBlock>
            <TextBox Name="JTextBoxFeet" Margin="5" Grid.Row="4" Grid.Column="6"/>
            <TextBlock Name="JLabelFeet" Margin="0,7.2,0,0" Grid.Row="4" Grid.Column="7" HorizontalAlignment="Left"
                       Height="17" VerticalAlignment="Top">ft</TextBlock>
            <TextBox Name="JTextBoxInch" Margin="5" Grid.Row="4" Grid.Column="8"/>
            <TextBlock Name="JLabelInch" Margin="0,7.2,0,0" Grid.Row="4" Grid.Column="9" HorizontalAlignment="Left"
                       Height="17" VerticalAlignment="Top">in</TextBlock>
            <TextBlock Margin="7" Grid.Row="5" Grid.Column="5" HorizontalAlignment="Right">K:</TextBlock>
            <TextBox Name="KTextBoxFeet" Margin="5" Grid.Row="5" Grid.Column="6"/>
            <TextBlock Name="KLabelFeet" Margin="0,7.2,0,0" Grid.Row="5" Grid.Column="7" HorizontalAlignment="Left"
                       Height="17" VerticalAlignment="Top">ft</TextBlock>
            <TextBox Name="KTextBoxInch" Margin="5" Grid.Row="5" Grid.Column="8"/>
            <TextBlock Name="KLabelInch" Margin="0,7.2,0,0" Grid.Row="5" Grid.Column="9" HorizontalAlignment="Left"
                       Height="17" VerticalAlignment="Top">in</TextBlock>
            <TextBlock Margin="7" Grid.Row="6" Grid.Column="5" HorizontalAlignment="Right">O:</TextBlock>
            <TextBox Name="OTextBoxFeet" Margin="5" Grid.Row="6" Grid.Column="6"/>
            <TextBlock Name="OLabelFeet" Margin="0,7.2,0,0" Grid.Row="6" Grid.Column="7" HorizontalAlignment="Left"
                       Height="17" VerticalAlignment="Top">ft</TextBlock>
            <TextBox Name="OTextBoxInch" Margin="5" Grid.Row="6" Grid.Column="8"/>
            <TextBlock Name="OLabelInch" Margin="0,7.2,0,0" Grid.Row="6" Grid.Column="9" HorizontalAlignment="Left"
                       Height="17" VerticalAlignment="Top">in</TextBlock>
            <Button Click="SaveAndAddButton_Click" Grid.Row="7" Grid.Column="8" HorizontalAlignment="Left"
                    Margin="4,4,0,5" Grid.ColumnSpan="2" Width="88">Save and Add</Button>
          </Grid>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Window>