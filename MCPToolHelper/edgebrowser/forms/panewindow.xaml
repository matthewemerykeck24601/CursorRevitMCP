<Page x:Class="EDGE.EDGEBrowser.Forms.PaneWindow"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Loaded="Window_Loaded" Name="MainPaneWindow" Background="WhiteSmoke" Height="auto" Width="auto"
      HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
  <FrameworkElement.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/EDGEforREVIT;component/EDGELogo.xaml"/>
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </FrameworkElement.Resources>
  <Grid Name="TopGrid" Background="WhiteSmoke" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
        Height="auto" Width="auto">
    <Grid x:Name="ContentGrid" Background="WhiteSmoke" HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch" Height="auto" Width="auto">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="5*"/>
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="13*"/>
        <RowDefinition Height="95*"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <StackPanel Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Top">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="105"/>
            <RowDefinition/>
          </Grid.RowDefinitions>
          <Button Click="HomeButton_Click" x:Name="MainIcon" Grid.Row="1" IsEnabled="false" BorderThickness="0"
                  BorderBrush="Transparent" Foreground="Transparent" Background="Transparent">
            <ContentControl Template="{StaticResource EDGELogoStyle}" HorizontalAlignment="Center" Margin="2,5,2,5"
                            VerticalAlignment="Top" Width="200" Height="90" MinWidth="200"/>
            <FrameworkElement.Resources>
              <Style x:Key="MainIcon" TargetType="{x:Type Button}">
                <Setter Property="FrameworkElement.OverridesDefaultStyle" Value="true"/>
                <Setter Property="Control.Background" Value="Transparent"/>
                <Setter Property="Control.Foreground" Value="Transparent"/>
                <Setter Property="Control.BorderBrush" Value="Transparent"/>
                <Setter Property="Control.Template">
                  <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                      <Grid Background="Transparent">
                        <ContentPresenter x:Name="MyContentPresenter" Content="{TemplateBinding ContentControl.Content}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      </Grid>
                    </ControlTemplate>
                  </Setter.Value>
                </Setter>
                <Style.Triggers>
                  <Trigger Property="UIElement.IsEnabled" Value="false">
                    <Setter Property="Control.Background" Value="Transparent"/>
                    <Setter Property="Control.Foreground" Value="Transparent"/>
                    <Setter Property="Control.BorderBrush" Value="Transparent"/>
                  </Trigger>
                </Style.Triggers>
              </Style>
            </FrameworkElement.Resources>
          </Button>
          <TextBox GotFocus="FindBar_GotFocus" LostFocus="FindBar_LostFocus" ContentElement.KeyDown="OnKeyHandler"
                   x:Name="FindBar" Grid.Row="2" HorizontalAlignment="Stretch" Height="Auto" Margin="2,1,2,5"
                   TextWrapping="Wrap" Text="Search" VerticalAlignment="Top" MaxWidth="300" FontSize="14">
            <FrameworkElement.Resources>
              <Style TargetType="{x:Type Border}">
                <Setter Property="Border.CornerRadius" Value="5"/>
              </Style>
            </FrameworkElement.Resources>
          </TextBox>
          <TextBlock x:Name="dlTextBlock" Grid.Row="0" Visibility="Collapsed" Text="File Name: Download Progress 0 %"
                     HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="10" TextWrapping="Wrap"/>
          <Button Click="CancelDownload_Click" x:Name="CancelDownload" Grid.Row="0" Visibility="Collapsed"
                  Height="12" Width="15" HorizontalAlignment="Right" VerticalAlignment="Top"
                  BorderBrush="Transparent" Background="Transparent">
            <TextBlock FontFamily="Segoe UI Symbol" Text="" VerticalAlignment="Center" HorizontalAlignment="Center"
                       FontSize="10" Margin="2, 0, 0, 0"/>
          </Button>
        </Grid>
      </StackPanel>
      <WebBrowser x:Name="ContactBrowser" HorizontalAlignment="Center" Visibility="Collapsed" IsEnabled="false"
                  VerticalAlignment="Center" Grid.Row="2"/>
      <TextBlock x:Name="ContactTextBlock" Width="Auto" Visibility="Collapsed" HorizontalAlignment="Center"
                 VerticalAlignment="Top" Grid.Row="2" FontSize="15" TextWrapping="Wrap">
        Phone: (251)340-2473
        <LineBreak/>
        Contact Email:
        <Hyperlink RequestNavigate="Hyperlink_RequestNavigate"
                   NavigateUri="mailto:edge@ptac.com?subject=EDGE^R Contact&amp;">edge@ptac.com</Hyperlink>
        <LineBreak/>
        Support Email:
        <Hyperlink RequestNavigate="Hyperlink_RequestNavigate"
                   NavigateUri="mailto:edgesupport@ptac.com?subject=EDGE^R Support&amp;">
          edgesupport@ptac.com
        </Hyperlink>
        <LineBreak/>
        Website: www.edge.ptac.com
        <LineBreak/>
      </TextBlock>
      <ScrollViewer Name="WrapScroller" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                    HorizontalAlignment="Center" VerticalAlignment="Top" Grid.Row="1" Margin="15,4,15,4"
                    Grid.RowSpan="4">
        <StackPanel x:Name="HomeButtonPanel" Orientation="Vertical">
          <Button Click="TrainingButton_Click" x:Name="TrainingExpander" HorizontalContentAlignment="Stretch"
                  FontSize="25" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="4,5,4,5" Padding="4,4,4,4"
                  Grid.RowSpan="3"
                  Width="{Binding Path=ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}">
            <Control.Background>
              <SolidColorBrush Color="Transparent"/>
            </Control.Background>
            <Control.BorderBrush>
              <SolidColorBrush Color="Transparent"/>
            </Control.BorderBrush>
            <FrameworkElement.Resources>
              <Style TargetType="{x:Type Border}">
                <Setter Property="Border.CornerRadius" Value="3"/>
              </Style>
            </FrameworkElement.Resources>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
              <TextBlock FontFamily="Segoe UI Symbol" Text=" Training" VerticalAlignment="Center"
                         HorizontalAlignment="Stretch" FontSize="25"/>
            </StackPanel>
          </Button>
          <Button Click="FamToolsButton_Click" x:Name="FamilyExpander" HorizontalContentAlignment="Stretch"
                  FontSize="25" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="4,5,4,5" Padding="4,4,4,4"
                  Grid.RowSpan="3"
                  Width="{Binding Path=ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}">
            <FrameworkElement.Resources>
              <Style TargetType="{x:Type Border}">
                <Setter Property="Border.CornerRadius" Value="3"/>
              </Style>
            </FrameworkElement.Resources>
            <Control.BorderBrush>
              <SolidColorBrush Color="Transparent"/>
            </Control.BorderBrush>
            <Control.Background>
              <SolidColorBrush Color="Transparent"/>
            </Control.Background>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
              <TextBlock FontFamily="Segoe UI Symbol" Text=" Families" VerticalAlignment="Center" FontSize="25"/>
            </StackPanel>
          </Button>
          <Button Click="ToolsButton_Click" x:Name="ManualsButton" Visibility="Collapsed"
                  HorizontalContentAlignment="Stretch" HorizontalAlignment="Stretch" VerticalAlignment="Top"
                  Margin="4,0,4,0" Padding="4,4,4,4" FontSize="25"
                  Width="{Binding Path=ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}">
            <FrameworkElement.Resources>
              <Style TargetType="{x:Type Border}">
                <Setter Property="Border.CornerRadius" Value="3"/>
              </Style>
            </FrameworkElement.Resources>
            <Control.BorderBrush>
              <SolidColorBrush Color="Transparent"/>
            </Control.BorderBrush>
            <Control.Background>
              <SolidColorBrush Color="Transparent"/>
            </Control.Background>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
              <TextBlock FontFamily="Segoe UI Symbol" Text="📕 Manuals" VerticalAlignment="Center"
                         HorizontalAlignment="Stretch" FontSize="25"/>
            </StackPanel>
          </Button>
          <Button Click="VideosButton_Click" x:Name="VideosButton" Visibility="Collapsed"
                  HorizontalContentAlignment="Stretch" HorizontalAlignment="Stretch" VerticalAlignment="Top"
                  Margin="4,0,4,0" Padding="4,4,4,4" FontSize="25"
                  Width="{Binding Path=ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}">
            <FrameworkElement.Resources>
              <Style TargetType="{x:Type Border}">
                <Setter Property="Border.CornerRadius" Value="3"/>
              </Style>
            </FrameworkElement.Resources>
            <Control.BorderBrush>
              <SolidColorBrush Color="Transparent"/>
            </Control.BorderBrush>
            <Control.Background>
              <SolidColorBrush Color="Transparent"/>
            </Control.Background>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
              <TextBlock FontFamily="Segoe UI Symbol" Text=" Videos" VerticalAlignment="Center"
                         HorizontalAlignment="Stretch" FontSize="25"/>
            </StackPanel>
          </Button>
          <Button Click="RefreshButton_Click" x:Name="RefreshButton" Visibility="Collapsed"
                  HorizontalContentAlignment="Stretch" FontSize="25" HorizontalAlignment="Left"
                  VerticalAlignment="Top" Margin="4,5,4,5" Padding="4,4,4,4" Grid.RowSpan="3"
                  Width="{Binding Path=ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}">
            <Control.Background>
              <SolidColorBrush Color="Transparent"/>
            </Control.Background>
            <Control.BorderBrush>
              <SolidColorBrush Color="Transparent"/>
            </Control.BorderBrush>
            <FrameworkElement.Resources>
              <Style TargetType="{x:Type Border}">
                <Setter Property="Border.CornerRadius" Value="3"/>
              </Style>
            </FrameworkElement.Resources>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
              <TextBlock FontFamily="Segoe UI Symbol" Text=" Load Content" VerticalAlignment="Center"
                         HorizontalAlignment="Stretch" FontSize="25"/>
            </StackPanel>
          </Button>
          <Button Click="ContactButton_Click" x:Name="ContactButton" HorizontalContentAlignment="Stretch"
                  HorizontalAlignment="Stretch" VerticalAlignment="Top" Margin="4,5,4,5" Padding="4,4,4,4"
                  FontSize="25"
                  Width="{Binding Path=ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}">
            <FrameworkElement.Resources>
              <Style TargetType="{x:Type Border}">
                <Setter Property="Border.CornerRadius" Value="3"/>
              </Style>
            </FrameworkElement.Resources>
            <Control.BorderBrush>
              <SolidColorBrush Color="Transparent"/>
            </Control.BorderBrush>
            <Control.Background>
              <SolidColorBrush Color="Transparent"/>
            </Control.Background>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
              <TextBlock FontFamily="Segoe UI Symbol" Text=" Contact Us" VerticalAlignment="Center"
                         HorizontalAlignment="Stretch" FontSize="25"/>
            </StackPanel>
          </Button>
        </StackPanel>
      </ScrollViewer>
      <MediaElement MediaOpened="MediaElement_MediaOpened" x:Name="MediaElement" Visibility="Collapsed"
                    Stretch="Uniform" Grid.Row="1" Grid.RowSpan="2" HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"/>
      <ScrollViewer x:Name="TrainingScrollViewer" Visibility="Collapsed" VerticalScrollBarVisibility="Disabled"
                    Grid.Row="1" HorizontalScrollBarVisibility="Disabled" Grid.RowSpan="2">
        <TreeView x:Name="TrainingTreeView" Visibility="Collapsed" HorizontalAlignment="Stretch"
                  VerticalAlignment="Top" Background="Transparent" MaxHeight="1000" MaxWidth="800" Cursor="Arrow"
                  BorderBrush="{x:Null}"/>
      </ScrollViewer>
      <ScrollViewer x:Name="VideoScrollViewer" Visibility="Collapsed" VerticalScrollBarVisibility="Disabled"
                    Grid.Row="1" HorizontalScrollBarVisibility="Disabled" Grid.RowSpan="2">
        <TreeView x:Name="TrainingVideosTreeView" Visibility="Collapsed" HorizontalAlignment="Stretch"
                  VerticalAlignment="Top" Background="Transparent" MaxHeight="1000" MaxWidth="800"
                  BorderBrush="{x:Null}"/>
      </ScrollViewer>
      <ScrollViewer PreviewMouseWheel="previewMouseWheel" x:Name="SearchScrollViewer" Visibility="Collapsed"
                    VerticalScrollBarVisibility="Auto" Grid.Row="1" HorizontalScrollBarVisibility="Auto"
                    UseLayoutRounding="true" Padding="0" Margin="0,40,0,0" FontSize="14" Grid.RowSpan="2">
        <TreeView x:Name="SearchTreeView" HorizontalAlignment="Stretch" VerticalAlignment="Top" Height="Auto"
                  MaxWidth="800" Visibility="Collapsed" Background="Transparent" BorderBrush="Transparent"
                  VerticalContentAlignment="Top" ScrollViewer.VerticalScrollBarVisibility="Disabled"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
      </ScrollViewer>
      <TextBlock x:Name="FindBarValueHolder" Visibility="Collapsed" Grid.Row="1" Height="Auto" Width="Auto"
                 HorizontalAlignment="Stretch" VerticalAlignment="Top" Margin="5,1,2,0" Background="Transparent"
                 TextAlignment="Center" FontSize="14" TextWrapping="Wrap"/>
      <ScrollViewer x:Name="FamilyScrollViewer" Visibility="Collapsed" VerticalScrollBarVisibility="Disabled"
                    Grid.Row="1" HorizontalScrollBarVisibility="Disabled" Grid.RowSpan="2">
        <TreeView x:Name="FamilyTreeView" Visibility="Collapsed" HorizontalAlignment="Stretch"
                  VerticalAlignment="Top" Background="Transparent" MaxHeight="1000" MaxWidth="800"
                  BorderBrush="{x:Null}">
          <FrameworkElement.Resources>
            <ContextMenu x:Key="DownloadContext" StaysOpen="false">
              <MenuItem Click="DownloadFamily_RightButtonDown" Header="Download"/>
              <MenuItem Click="FamilyTreeView_Click" Header="Load Family Into Project"/>
            </ContextMenu>
          </FrameworkElement.Resources>
        </TreeView>
      </ScrollViewer>
      <DataGrid x:Name="TrainingFolderDataGrid" Visibility="Collapsed" Grid.Row="2" HorizontalAlignment="Stretch"
                VerticalAlignment="Center" Margin="0,58.322,0,84" ItemsSource="{Binding}"/>
      <DataGrid x:Name="SublFolderDataGrid" Visibility="Collapsed" Grid.Row="2" HorizontalAlignment="Stretch"
                VerticalAlignment="Center" Margin="0,58.322,0,84" ItemsSource="{Binding}"/>
      <DataGrid x:Name="ContentDataGrid" Visibility="Collapsed" HorizontalAlignment="Left" Height="151"
                Margin="10,10,-14,0" VerticalAlignment="Top" Width="210" Grid.RowSpan="3"/>
      <DocumentViewer x:Name="xps" Grid.Row="0" TextOptions.TextFormattingMode="Display" HorizontalAlignment="Stretch"
                      Visibility="Collapsed" VerticalAlignment="Top" Grid.RowSpan="3">
        <UIElement.CacheMode>
          <BitmapCache/>
        </UIElement.CacheMode>
        <Control.Template>
          <ControlTemplate TargetType="{x:Type DocumentViewer}">
            <Border BorderBrush="{TemplateBinding Control.BorderBrush}"
                    BorderThickness="{TemplateBinding Control.BorderThickness}">
              <Grid Background="{TemplateBinding Control.Background}" KeyboardNavigation.TabNavigation="Local"
                    SnapsToDevicePixels="true">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="*"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ToolBar ToolBarTray.IsLocked="true" KeyboardNavigation.TabNavigation="Continue">
                  <Button Command="ApplicationCommands.Print"
                          CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                      <TextBlock FontFamily="Segoe UI Symbol" Text="" ToolTip="Print" VerticalAlignment="Center"
                                 HorizontalAlignment="Stretch" FontSize="25"/>
                    </StackPanel>
                  </Button>
                  <Separator/>
                  <Button Command="NavigationCommands.IncreaseZoom"
                          CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                      <TextBlock FontFamily="Segoe UI Symbol" Text="" ToolTip="Zoom In" VerticalAlignment="Center"
                                 HorizontalAlignment="Stretch" FontSize="20"/>
                    </StackPanel>
                  </Button>
                  <Button Command="NavigationCommands.DecreaseZoom"
                          CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                      <TextBlock FontFamily="Segoe UI Symbol" Text="" ToolTip="Zoom Out" VerticalAlignment="Center"
                                 HorizontalAlignment="Stretch" FontSize="18"/>
                    </StackPanel>
                  </Button>
                  <Separator/>
                  <Button Command="NavigationCommands.Zoom" CommandParameter="100.0"
                          CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                      <TextBlock FontFamily="Segoe UI Symbol" Text="" VerticalAlignment="Center" ToolTip="Zoom To Actual Width"
                                 HorizontalAlignment="Stretch" FontSize="20"/>
                    </StackPanel>
                  </Button>
                  <Button Command="DocumentViewer.FitToWidthCommand"
                          CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                      <TextBlock FontFamily="Segoe UI Symbol" Text="" VerticalAlignment="Top" ToolTip="Fit to Pane Width"
                                 HorizontalAlignment="Stretch" FontSize="30"/>
                    </StackPanel>
                  </Button>
                  <Button Command="DocumentViewer.FitToMaxPagesAcrossCommand" CommandParameter="1"
                          CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                      <TextBlock FontFamily="Segoe UI Symbol" Text="" VerticalAlignment="Center" ToolTip="Fit to One Page"
                                 HorizontalAlignment="Stretch" FontSize="25"/>
                    </StackPanel>
                  </Button>
                  <Button Command="DocumentViewer.FitToMaxPagesAcrossCommand" CommandParameter="2"
                          CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                      <TextBlock FontFamily="Segoe UI Symbol" Text="" VerticalAlignment="Center" ToolTip="Fit to Two Pages"
                                 HorizontalAlignment="Stretch" FontSize="35"/>
                    </StackPanel>
                  </Button>
                </ToolBar>
                <ScrollViewer x:Name="PART_ContentHost" CanContentScroll="true" Grid.Column="0"
                              HorizontalScrollBarVisibility="Auto" IsTabStop="true" Grid.Row="1" TabIndex="1" Width="Auto"
                              Height="Auto" PanningMode="None">
                  <Control.Template>
                    <ControlTemplate TargetType="{x:Type ScrollViewer}">
                      <Grid x:Name="Grid" Background="{TemplateBinding Control.Background}">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="25" MaxWidth="Infinity"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                          <RowDefinition Height="*"/>
                          <RowDefinition Height="25"/>
                        </Grid.RowDefinitions>
                        <Rectangle x:Name="Corner" Grid.Column="1" Fill="{DynamicResource {x:Static JetSystemColors.ControlBrushKey}}"
                                   Grid.Row="1"/>
                        <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                CanContentScroll="{TemplateBinding ScrollViewer.CanContentScroll}" CanHorizontallyScroll="false"
                                                CanVerticallyScroll="false" ContentTemplate="{TemplateBinding ContentControl.ContentTemplate}"
                                                Content="{TemplateBinding ContentControl.Content}" Grid.Column="0" Margin="0" Grid.Row="0"
                                                SnapsToDevicePixels="false"/>
                        <ScrollBar x:Name="PART_VerticalScrollBar" AutomationProperties.AutomationId="VerticalScrollBar"
                                   Cursor="Arrow" Grid.Column="1" Maximum="{TemplateBinding ScrollViewer.ScrollableHeight}"
                                   Minimum="0" Grid.Row="0"
                                   Visibility="{TemplateBinding ScrollViewer.ComputedVerticalScrollBarVisibility}"
                                   ViewportSize="{TemplateBinding ScrollViewer.ViewportHeight}" Width="2" Height="Auto"
                                   Value="{Binding VerticalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                        <ScrollBar x:Name="PART_HorizontalScrollBar" AutomationProperties.AutomationId="HorizontalScrollBar"
                                   Cursor="Arrow" Grid.Column="0" Maximum="{TemplateBinding ScrollViewer.ScrollableWidth}" Minimum="0"
                                   Orientation="Horizontal" Grid.Row="1"
                                   Visibility="{TemplateBinding ScrollViewer.ComputedHorizontalScrollBarVisibility}"
                                   ViewportSize="{TemplateBinding ScrollViewer.ViewportWidth}" Height="2" Width="Auto"
                                   Value="{Binding HorizontalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                      </Grid>
                    </ControlTemplate>
                  </Control.Template>
                </ScrollViewer>
                <DockPanel Grid.Row="1">
                  <FrameworkElement DockPanel.Dock="Right"
                                    Width="{DynamicResource {x:Static SystemParameters.VerticalScrollBarWidthKey}}"/>
                  <Rectangle Height="10" Visibility="Visible" VerticalAlignment="Top">
                    <Shape.Fill>
                      <LinearGradientBrush EndPoint="0,1" StartPoint="0,0">
                        <GradientStop Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                      </LinearGradientBrush>
                    </Shape.Fill>
                  </Rectangle>
                </DockPanel>
                <ContentControl x:Name="PART_FindToolBarHost" Grid.Column="0" Focusable="{TemplateBinding UIElement.Focusable}"
                                Grid.Row="2" TabIndex="2" IsEnabled="true">
                  <Control.Template>
                    <ControlTemplate TargetType="{x:Type ContentControl}">
                      <ContentPresenter ContentTemplate="{TemplateBinding ContentControl.ContentTemplate}"
                                        ContentStringFormat="{TemplateBinding ContentControl.ContentStringFormat}" IsEnabled="true"
                                        ContentSource="Content"/>
                    </ControlTemplate>
                  </Control.Template>
                </ContentControl>
              </Grid>
            </Border>
          </ControlTemplate>
        </Control.Template>
      </DocumentViewer>
      <TextBlock x:Name="CurrentTime" Grid.Row="3" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                 Padding="4,0,4,0" Margin="4,10,0,10" Text="00:00" FontSize="12" Visibility="Collapsed"/>
      <TextBlock x:Name="TotalTime" Grid.Row="3" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                 Padding="4,0,4,0" Margin="0,10,4,10" Text="00:00" FontSize="12" Visibility="Collapsed"/>
      <StackPanel x:Name="sliderPanel" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Grid.Row="3"
                  Margin="40,10,40,10" Visibility="Collapsed">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
          </Grid.RowDefinitions>
          <ProgressBar x:Name="mediaProgressBar" Grid.Column="0" Grid.Row="0" HorizontalAlignment="Stretch" MinWidth="150"/>
          <Slider Thumb.DragStarted="sliderBar_DragStarted" Thumb.DragCompleted="sliderBar_DragCompleted"
                  x:Name="sliderBar" Grid.Column="0" Grid.Row="1" HorizontalAlignment="Stretch" MaxHeight="18"/>
        </Grid>
      </StackPanel>
      <WrapPanel Grid.Row="4" HorizontalAlignment="Center" VerticalAlignment="Bottom" Grid.RowSpan="2">
        <Button Click="MediaBackButton_Click" x:Name="MediaBackButton" IsEnabled="false" Margin="2,0,2,0"
                Visibility="Collapsed" FontFamily="Segoe UI Symbol" Content="" HorizontalContentAlignment="Center"
                Padding="4,0,4,0" HorizontalAlignment="Left" VerticalAlignment="Bottom" Width="23" FontSize="12"
                Height="20"/>
        <Button Click="TrainingBackButton_Click" x:Name="TrainingBackButton" IsEnabled="false" Margin="2,0,2,0"
                Visibility="Collapsed" FontFamily="Segoe UI Symbol" Content="" HorizontalContentAlignment="Center"
                Padding="4,0,4,0" HorizontalAlignment="Left" VerticalAlignment="Bottom" Width="23" FontSize="12"
                Height="20"/>
        <Button Click="XPSBackButton_Click" x:Name="XPSBackButton" Margin="2,0,2,0" FontFamily="Segoe UI Symbol"
                Content="" IsEnabled="false" Padding="4,0,4,0" HorizontalContentAlignment="Center"
                HorizontalAlignment="Left" VerticalAlignment="Bottom" Width="23" FontSize="12" Height="20"
                Visibility="Collapsed"/>
        <Button Click="HomeButton_Click" x:Name="HomeButton" Margin="2,0,2,0" IsEnabled="true"
                HorizontalContentAlignment="Center" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Width="65" FontSize="12" Height="20" Visibility="Collapsed">
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
            <TextBlock FontFamily="Segoe UI Symbol" Text=" " HorizontalAlignment="Right"/>
            <ContentControl Template="{StaticResource EDGEButtonStyle}" VerticalAlignment="Center"
                            HorizontalAlignment="Stretch" Width="41" Height="17"/>
          </StackPanel>
        </Button>
        <WrapPanel x:Name="MediaButtonPanel" Margin="2,0,2,0" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                   Visibility="Collapsed">
          <Button Click="btnPlay_Click" x:Name="btnPlay" FontFamily="Segoe UI Symbol" Content=""
                  HorizontalContentAlignment="Center" VerticalAlignment="Bottom" Padding="4,0,4,0" Width="25"
                  FontSize="12" Height="20"/>
          <Button Click="btnPause_Click" x:Name="btnPause" FontFamily="Segoe UI Symbol" Content=""
                  HorizontalContentAlignment="Center" VerticalAlignment="Bottom" Padding="4,0,4,0" Width="25"
                  FontSize="12" Height="20"/>
          <Button Click="btnStop_Click" x:Name="btnStop" FontFamily="Segoe UI Symbol" Content=""
                  HorizontalContentAlignment="Center" VerticalAlignment="Bottom" Padding="4,0,4,0" Width="25"
                  FontSize="12" Height="20"/>
          <Button Click="btnMute_Click" Name="btnMute" FontFamily="Segoe UI Symbol" Content=""
                  HorizontalContentAlignment="Center" VerticalAlignment="Bottom" Padding="4,0,4,0" Width="25"
                  FontSize="12" Height="20"/>
          <ComboBox SelectionChanged="QualityBox_SelectionChanged" x:Name="qualityBox" VerticalAlignment="Bottom"
                    Padding="4,0,4,0" Height="20" Width="60" FontSize="12">
            <ComboBoxItem>480p</ComboBoxItem>
            <ComboBoxItem>720p</ComboBoxItem>
            <ComboBoxItem>1080p</ComboBoxItem>
          </ComboBox>
          <Button Click="btnDownloadVideo_Click" Name="btnDownload" FontFamily="Segoe UI Symbol" Content=""
                  HorizontalContentAlignment="Center" VerticalAlignment="Bottom" Padding="4,0,4,0" Width="25"
                  FontSize="12" Height="20"/>
          <Button Click="btnPopOut_Click" Name="btnPopOut" FontFamily="Segoe UI Symbol" Content=""
                  HorizontalContentAlignment="Center" VerticalAlignment="Bottom" Padding="4,0,4,0" Width="25"
                  FontSize="12" Height="20"/>
        </WrapPanel>
      </WrapPanel>
    </Grid>
    <Label Name="LoadingLbl" Content="Loading..." FontSize="20" HorizontalAlignment="Center"
           VerticalAlignment="Center" Visibility="Hidden"/>
  </Grid>
</Page>