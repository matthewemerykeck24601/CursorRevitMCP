<Window x:Class="EDGE.AssemblyTools.MarkVerification.ResultsPresentation.PlateWarnings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:EDGE.AssemblyTools.MarkVerification.ResultsPresentation"
        Closed="Window_Closed" Title="Mark Verification Warnings" MinHeight="370" MinWidth="475"
        Height="370" Width="475" MaxHeight="450" MaxWidth="600" WindowStartupLocation="CenterScreen">
  <Grid Name="theGrid" Margin="0,15,7,15">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="26*"/>
      <ColumnDefinition Width="205*"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition x:Name="plateRotationRow" Height="*  "/>
      <RowDefinition Height="Auto"/>
      <RowDefinition x:Name="MultiplyByMarksRow" Height="*"/>
    </Grid.RowDefinitions>
    <TextBlock x:Name="PlateRotationWarning" Grid.Row="0" TextWrapping="Wrap" FontSize="12" Margin="10,0,0,0"
               Grid.ColumnSpan="2" Visibility="Collapsed">
      <Run Text="The below family types were detected as having rotations or mirroring within the selected mark. Offending element ID's are listed for each family type. Please review this list to ensure the accuracy of this mark. Rotation or mirroring of non-symmetric family types could cause undesired results."/>
    </TextBlock>
    <ScrollViewer x:Name="FamilyScrollBar" Visibility="Collapsed" VerticalScrollBarVisibility="Disabled"
                  HorizontalScrollBarVisibility="Disabled" Grid.Row="1" Grid.ColumnSpan="2">
      <TreeView x:Name="FamilyName" Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Top"
                Background="Transparent" Cursor="Arrow" BorderBrush="{x:Null}"/>
    </ScrollViewer>
    <TextBlock x:Name="MultiplyByMarksWarning" Grid.Row="2" TextWrapping="Wrap" FontSize="12" Margin="10,0,0,0"
               Grid.ColumnSpan="2" Visibility="Collapsed">
      <Run Text="The below family types have one or more instances that have the MULTIPY_FOR_MARKS parameter value of yes. Offending element ID's are listed for each family type. Please review this list to ensure the accuracy of this mark. Any embeds with a MULTIPY_FOR_MARKS parameter value of yes (and their shared subcomponents) are excluded from mark verification comparisions."/>
    </TextBlock>
    <ScrollViewer x:Name="MultiplyByMarksFamilyScrollBar" Visibility="Collapsed"
                  VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Disabled" Grid.Row="3"
                  Grid.ColumnSpan="2">
      <TreeView x:Name="MultiplyByMarksFamilyName" Visibility="Collapsed" HorizontalAlignment="Stretch"
                VerticalAlignment="Top" Background="Transparent" Cursor="Arrow" BorderBrush="{x:Null}"/>
    </ScrollViewer>
  </Grid>
</Window>