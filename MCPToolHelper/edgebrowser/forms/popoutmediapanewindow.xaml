<Window x:Class="EDGE.EDGEBrowser.Forms.PopOutMediaPaneWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:EDGE.EDGEBrowser.Forms"
        Background="{DynamicResource {x:Static JetSystemColors.ControlBrushKey}}" Height="auto"
        Width="auto" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
  <Grid x:Name="MediaGrid" Background="{DynamicResource {x:Static JetSystemColors.ControlBrushKey}}"
        HorizontalAlignment="Stretch" Focusable="true" VerticalAlignment="Stretch" Height="auto"
        Width="auto">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="5*"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="8*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <MediaElement MediaOpened="MediaElement_MediaOpened" x:Name="MediaElement" Stretch="Uniform" Grid.Row="0"
                  HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
    <TextBlock x:Name="CurrentTime" Grid.Row="1" HorizontalAlignment="Left" Padding="4,0,4,0" Margin="4,10,4,10"
               Text="00:00" FontSize="12"/>
    <TextBlock x:Name="TotalTime" Grid.Row="1" HorizontalAlignment="Right" Padding="4,0,4,0" Margin="4,10,4,10"
               Text="00:00" FontSize="12"/>
    <StackPanel x:Name="sliderPanel" Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
                Margin="40,10,40,10">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ProgressBar x:Name="mediaProgressBar" Grid.Column="0" Grid.Row="0" HorizontalAlignment="Stretch" MinWidth="150"/>
        <Slider Thumb.DragStarted="sliderBar_DragStarted" Thumb.DragCompleted="sliderBar_DragCompleted"
                x:Name="sliderBar" Grid.Column="0" Grid.Row="1" HorizontalAlignment="Stretch" MaxHeight="18"/>
      </Grid>
    </StackPanel>
    <WrapPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Bottom">
      <WrapPanel x:Name="MediaButtonPanel" Margin="4,0,4,0" HorizontalAlignment="Center" VerticalAlignment="Bottom">
        <Button Click="btnPlay_Click" x:Name="btnPlay" FontFamily="Segoe UI Symbol" Content=""
                HorizontalContentAlignment="Center" VerticalAlignment="Bottom" Padding="4,0,4,0" Width="25"
                FontSize="12" Height="20"/>
        <Button Click="btnPause_Click" x:Name="btnPause" FontFamily="Segoe UI Symbol" Content=""
                HorizontalContentAlignment="Center" VerticalAlignment="Bottom" Padding="4,0,4,0" Width="25"
                FontSize="12" Height="20"/>
        <Button Click="btnStop_Click" x:Name="btnStop" FontFamily="Segoe UI Symbol" Content=""
                HorizontalContentAlignment="Center" VerticalAlignment="Bottom" Padding="4,0,4,0" Width="25"
                FontSize="12" Height="20"/>
        <Button Click="btnMute_Click" Name="btnMute" FontFamily="Segoe UI Symbol" Content=""
                HorizontalContentAlignment="Center" VerticalAlignment="Bottom" Padding="4,0,4,0" Width="25"
                FontSize="12" Height="20"/>
        <ComboBox SelectionChanged="QualityBox_SelectionChanged" x:Name="qualityBox" VerticalAlignment="Bottom"
                  Padding="4,0,4,0" Height="20" Width="60" FontSize="12">
          <ComboBoxItem>480p</ComboBoxItem>
          <ComboBoxItem>720p</ComboBoxItem>
          <ComboBoxItem>1080p</ComboBoxItem>
        </ComboBox>
        <Button Click="btnFullscreen_Click" Name="btnFullscreen" FontFamily="Segoe UI Symbol" Content=""
                HorizontalContentAlignment="Center" VerticalAlignment="Bottom" Padding="4,0,4,0" Width="25"
                FontSize="12" Height="20"/>
        <Button Click="btnFullscreen_Click" Name="btnUnFullscreen" Visibility="Collapsed"
                FontFamily="Segoe UI Symbol" Content="" HorizontalContentAlignment="Center"
                VerticalAlignment="Bottom" Padding="4,0,4,0" Width="25" FontSize="12" Height="20"/>
      </WrapPanel>
    </WrapPanel>
    <StackPanel Grid.Row="3" HorizontalAlignment="Stretch" VerticalAlignment="Top">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="dlTextBlock" Grid.Row="0" Visibility="Collapsed" Text="File Name: Download Progress 0 %"
                   HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="10" TextWrapping="Wrap"/>
      </Grid>
    </StackPanel>
  </Grid>
</Window>