<Window x:Class="EDGE.QATools.RegTestGen_Command.RegTestConfig_Form"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:EDGE.QATools.RegTestGen_Command"
        Height="AUto" Width="391" MinWidth="330">
  <FrameworkElement.Resources>
    <Style TargetType="{x:Type Label}">
      <Setter Property="Control.FontSize" Value="14"/>
      <Setter Property="Control.FontFamily" Value="Arial"/>
      <Setter Property="FrameworkElement.Margin" Value="5 10 0 0"/>
    </Style>
    <Style TargetType="{x:Type TextBox}">
      <Setter Property="Control.Background" Value="BlanchedAlmond"/>
    </Style>
  </FrameworkElement.Resources>
  <StackPanel>
    <Label Content="Reg Test Top Level Folder"/>
    <WrapPanel>
      <TextBox x:Name="txtRegTestsRootFolder" Text="C:\Users\Ken\Dropbox\RegTests" MinWidth="300" Margin="5 0 0 0"/>
      <Button Click="btnBrowseMainFolder_Click" x:Name="btnBrowseMainFolder" Content="..." Width="20" Height="20"/>
    </WrapPanel>
    <StackPanel Margin="0 10">
      <Label Content="New Reg Test Folder Path"/>
      <WrapPanel>
        <TextBox x:Name="txtNewRegTestsFolder" MinWidth="300" Margin="5 0 0 0"/>
        <Button Click="btnBrowseTestFolder_Click" x:Name="btnBrowseTestFolder" Content="..." Width="20" Height="20"/>
      </WrapPanel>
      <Label Content="Test Name"/>
      <TextBox x:Name="txtNewTestName" Margin="5 0 0 0"/>
      <Label Content="Test Description"/>
      <TextBox x:Name="txtNewTestDescription" Height="100" Margin="5 0 0 0"/>
      <Label Content="Tags (Comma Separated List)"/>
      <TextBox x:Name="txtTags" MinWidth="300" Margin="5 0 0 0"/>
      <Label Content="Time Out (in whole seconds)"/>
      <TextBox x:Name="txtTimeout" MinWidth="300" Margin="5 0 0 0"/>
      <Button Click="btnMakeTest_Click" x:Name="btnMakeTest" FontSize="20" FontFamily="Arial" FontWeight="Bold"
              Content="Create Test" Margin="5 20 0 5"/>
    </StackPanel>
  </StackPanel>
</Window>