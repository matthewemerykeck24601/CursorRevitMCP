<Window x:Class="EDGE.TicketTools.AutoDimensioning.EnhancementSpreadSheet"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:spreadsheetdata="clr-namespace:EDGE.TicketTools.AutoDimensioning"
        MinHeight="326" Height="485" Width="630" ResizeMode="NoResize"
        Title="Dimension and Callout Customization">
  <Grid Name="MainGrid">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="10"/>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="10"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="10"/>
      <RowDefinition Height="40"/>
      <RowDefinition MinHeight="10" Height="22*"/>
      <RowDefinition Height="49"/>
    </Grid.RowDefinitions>
    <Grid Row="1" Column="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="70"/>
        <ColumnDefinition Width="80*"/>
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" Text="Assembly :" VerticalAlignment="Center" HorizontalAlignment="Left"
                 Margin="2,0, 0,0" FontSize="12" FontWeight="Bold"/>
      <ComboBox SelectionChanged="DataGrid_SelectionChanged" Name="assemblydropdown" Grid.Column="1"
                VerticalAlignment="Center" Margin="0,0,0,0" MinWidth="150" MaxWidth="200"
                HorizontalAlignment="Left" HorizontalContentAlignment="Left" IsSynchronizedWithCurrentItem="True"
                BorderBrush="Black" BorderThickness="1" ItemsSource="{Binding Assemblies}"/>
    </Grid>
    <Grid Column="1" Row="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="22"/>
        <RowDefinition Height="40*"/>
      </Grid.RowDefinitions>
      <DataGrid Name="DataGrid" Grid.Column="0" Grid.Row="0" AutoGenerateColumns="false" SelectionMode="Extended"
                CanUserAddRows="false" CanUserDeleteRows="false" IsReadOnly="false"
                VerticalScrollBarVisibility="Visible" VerticalAlignment="Stretch" CanUserResizeColumns="true"
                CanUserResizeRows="false" RowHeight="22" SnapsToDevicePixels="true" HorizontalAlignment="Left"
                BorderBrush="Black" BorderThickness="1" Grid.RowSpan="2" Margin="0,0, 0, 0"
                CanUserReorderColumns="false" SelectionUnit="Cell">
        <FrameworkElement.Resources>
          <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Control.HorizontalContentAlignment" Value="Center"/>
          </Style>
        </FrameworkElement.Resources>
        <DataGrid.Columns>
          <DataGridTextColumn Header="CONTROL__MARK" IsReadOnly="true" CanUserResize="true" Visibility="Visible" MinWidth="120"
                              Width="Auto" Binding="{Binding Name}">
            <DataGridBoundColumn.ElementStyle>
              <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="FrameworkElement.HorizontalAlignment" Value="Stretch"/>
                <Setter Property="FrameworkElement.Width" Value="Auto"/>
              </Style>
            </DataGridBoundColumn.ElementStyle>
          </DataGridTextColumn>
          <DataGridCheckBoxColumn IsReadOnly="false" CanUserResize="false" Header="DIM__T__B" MinWidth="50" Width="70"
                                  Binding="{Binding Path=DimTopBottom, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
            <DataGridBoundColumn.ElementStyle>
              <Style TargetType="{x:Type CheckBox}" BasedOn="{StaticResource {x:Type CheckBox}}">
                <Setter Property="FrameworkElement.HorizontalAlignment" Value="Center"/>
                <Style.Triggers>
                  <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                      <Condition Binding="{Binding Path=DimTopBottom}" Value="{x:Null}"/>
                      <Condition Binding="{Binding Path=bTopBottomDiscrepency}" Value="False"/>
                    </MultiDataTrigger.Conditions>
                    <MultiDataTrigger.Setters>
                      <Setter Property="UIElement.SnapsToDevicePixels" Value="true"/>
                      <Setter Property="FrameworkElement.OverridesDefaultStyle" Value="true"/>
                      <Setter Property="FrameworkElement.FocusVisualStyle" Value="{x:Null}"/>
                      <Setter Property="Control.Template">
                        <Setter.Value>
                          <ControlTemplate TargetType="{x:Type CheckBox}">
                            <BulletDecorator>
                              <BulletDecorator.Bullet>
                                <Border x:Name="Border" Width="14" Height="14" CornerRadius="0" BorderThickness="1" BorderBrush="#404040"
                                        Background="White" Padding="1,0,0,0">
                                  <Path x:Name="CheckMark" Width="14" Height="10" SnapsToDevicePixels="false" Stroke="Gray"
                                        StrokeThickness="2" Data="M 1,4.5 L 4,8.5 M 4,8.5 L 8,1 "/>
                                </Border>
                              </BulletDecorator.Bullet>
                              <ContentPresenter VerticalAlignment="Center" RecognizesAccessKey="true" HorizontalAlignment="Left"/>
                            </BulletDecorator>
                          </ControlTemplate>
                        </Setter.Value>
                      </Setter>
                    </MultiDataTrigger.Setters>
                  </MultiDataTrigger>
                  <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                      <Condition Binding="{Binding Path=DimTopBottom}" Value="True"/>
                      <Condition Binding="{Binding Path=bTopBottomDiscrepency}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <MultiDataTrigger.Setters>
                      <Setter Property="Control.Background" Value="LightGray"/>
                    </MultiDataTrigger.Setters>
                  </MultiDataTrigger>
                  <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                      <Condition Binding="{Binding Path=DimTopBottom}" Value="False"/>
                      <Condition Binding="{Binding Path=bTopBottomDiscrepency}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <MultiDataTrigger.Setters>
                      <Setter Property="Control.Background" Value="LightGray"/>
                    </MultiDataTrigger.Setters>
                  </MultiDataTrigger>
                </Style.Triggers>
              </Style>
            </DataGridBoundColumn.ElementStyle>
          </DataGridCheckBoxColumn>
          <DataGridCheckBoxColumn IsReadOnly="false" CanUserResize="false" Header="DIM__F__B" MinWidth="50" Width="70"
                                  Binding="{Binding Path=DimFrontBack, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
            <DataGridBoundColumn.ElementStyle>
              <Style TargetType="{x:Type CheckBox}" BasedOn="{StaticResource {x:Type CheckBox}}">
                <Setter Property="FrameworkElement.HorizontalAlignment" Value="Center"/>
                <Style.Triggers>
                  <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                      <Condition Binding="{Binding Path=DimFrontBack}" Value="{x:Null}"/>
                      <Condition Binding="{Binding Path=bFrontBackDiscrepency}" Value="False"/>
                    </MultiDataTrigger.Conditions>
                    <MultiDataTrigger.Setters>
                      <Setter Property="UIElement.SnapsToDevicePixels" Value="true"/>
                      <Setter Property="FrameworkElement.OverridesDefaultStyle" Value="true"/>
                      <Setter Property="FrameworkElement.FocusVisualStyle" Value="{x:Null}"/>
                      <Setter Property="Control.Template">
                        <Setter.Value>
                          <ControlTemplate TargetType="{x:Type CheckBox}">
                            <BulletDecorator>
                              <BulletDecorator.Bullet>
                                <Border x:Name="Border" Width="14" Height="14" CornerRadius="0" BorderThickness="1" BorderBrush="#404040"
                                        Background="White" Padding="1,0,0,0">
                                  <Path x:Name="CheckMark" Width="14" Height="10" SnapsToDevicePixels="false" Stroke="Gray"
                                        StrokeThickness="2" Data="M 1,4.5 L 4,8.5 M 4,8.5 L 8,1 "/>
                                </Border>
                              </BulletDecorator.Bullet>
                              <ContentPresenter VerticalAlignment="Center" RecognizesAccessKey="true" HorizontalAlignment="Left"/>
                            </BulletDecorator>
                          </ControlTemplate>
                        </Setter.Value>
                      </Setter>
                    </MultiDataTrigger.Setters>
                  </MultiDataTrigger>
                  <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                      <Condition Binding="{Binding Path=DimFrontBack}" Value="True"/>
                      <Condition Binding="{Binding Path=bFrontBackDiscrepency}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <MultiDataTrigger.Setters>
                      <Setter Property="Control.Background" Value="LightGray"/>
                    </MultiDataTrigger.Setters>
                  </MultiDataTrigger>
                  <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                      <Condition Binding="{Binding Path=DimFrontBack}" Value="False"/>
                      <Condition Binding="{Binding Path=bFrontBackDiscrepency}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <MultiDataTrigger.Setters>
                      <Setter Property="Control.Background" Value="LightGray"/>
                    </MultiDataTrigger.Setters>
                  </MultiDataTrigger>
                </Style.Triggers>
              </Style>
            </DataGridBoundColumn.ElementStyle>
          </DataGridCheckBoxColumn>
          <DataGridCheckBoxColumn IsReadOnly="false" CanUserResize="false" Header="DIM__L__R" MinWidth="50" Width="70"
                                  Binding="{Binding Path=DimLeftRight, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
            <DataGridBoundColumn.ElementStyle>
              <Style TargetType="{x:Type CheckBox}" BasedOn="{StaticResource {x:Type CheckBox}}">
                <Setter Property="FrameworkElement.HorizontalAlignment" Value="Center"/>
                <Style.Triggers>
                  <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                      <Condition Binding="{Binding Path=DimLeftRight}" Value="{x:Null}"/>
                      <Condition Binding="{Binding Path=bLeftRightDiscrepency}" Value="False"/>
                    </MultiDataTrigger.Conditions>
                    <MultiDataTrigger.Setters>
                      <Setter Property="UIElement.SnapsToDevicePixels" Value="true"/>
                      <Setter Property="FrameworkElement.OverridesDefaultStyle" Value="true"/>
                      <Setter Property="FrameworkElement.FocusVisualStyle" Value="{x:Null}"/>
                      <Setter Property="Control.Template">
                        <Setter.Value>
                          <ControlTemplate TargetType="{x:Type CheckBox}">
                            <BulletDecorator>
                              <BulletDecorator.Bullet>
                                <Border x:Name="Border" Width="14" Height="14" CornerRadius="0" BorderThickness="1" BorderBrush="#404040"
                                        Background="White" Padding="1,0,0,0">
                                  <Path x:Name="CheckMark" Width="14" Height="10" SnapsToDevicePixels="false" Stroke="Gray"
                                        StrokeThickness="2" Data="M 1,4.5 L 4,8.5 M 4,8.5 L 8,1 "/>
                                </Border>
                              </BulletDecorator.Bullet>
                              <ContentPresenter VerticalAlignment="Center" RecognizesAccessKey="true" HorizontalAlignment="Left"/>
                            </BulletDecorator>
                          </ControlTemplate>
                        </Setter.Value>
                      </Setter>
                    </MultiDataTrigger.Setters>
                  </MultiDataTrigger>
                  <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                      <Condition Binding="{Binding Path=DimLeftRight}" Value="True"/>
                      <Condition Binding="{Binding Path=bLeftRightDiscrepency}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <MultiDataTrigger.Setters>
                      <Setter Property="Control.Background" Value="LightGray"/>
                    </MultiDataTrigger.Setters>
                  </MultiDataTrigger>
                  <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                      <Condition Binding="{Binding Path=DimLeftRight}" Value="False"/>
                      <Condition Binding="{Binding Path=bLeftRightDiscrepency}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <MultiDataTrigger.Setters>
                      <Setter Property="Control.Background" Value="LightGray"/>
                    </MultiDataTrigger.Setters>
                  </MultiDataTrigger>
                </Style.Triggers>
              </Style>
            </DataGridBoundColumn.ElementStyle>
          </DataGridCheckBoxColumn>
          <DataGridCheckBoxColumn IsReadOnly="false" CanUserResize="false" Header="CALLOUT__ALWAYS" MinWidth="120" Width="120"
                                  Binding="{Binding Path=CalloutAlways, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
            <DataGridBoundColumn.ElementStyle>
              <Style TargetType="{x:Type CheckBox}" BasedOn="{StaticResource {x:Type CheckBox}}">
                <Setter Property="FrameworkElement.HorizontalAlignment" Value="Center"/>
                <Style.Triggers>
                  <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                      <Condition Binding="{Binding Path=AlwaysCalloutReadOnly}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <MultiDataTrigger.Setters>
                      <Setter Property="UIElement.IsEnabled" Value="false"/>
                    </MultiDataTrigger.Setters>
                  </MultiDataTrigger>
                  <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                      <Condition Binding="{Binding Path=CalloutAlways}" Value="{x:Null}"/>
                      <Condition Binding="{Binding Path=bCalloutAlwaysDiscrepency}" Value="False"/>
                      <Condition Binding="{Binding Path=AlwaysCalloutReadOnly}" Value="False"/>
                    </MultiDataTrigger.Conditions>
                    <MultiDataTrigger.Setters>
                      <Setter Property="UIElement.SnapsToDevicePixels" Value="true"/>
                      <Setter Property="FrameworkElement.OverridesDefaultStyle" Value="true"/>
                      <Setter Property="FrameworkElement.FocusVisualStyle" Value="{x:Null}"/>
                      <Setter Property="Control.Template">
                        <Setter.Value>
                          <ControlTemplate TargetType="{x:Type CheckBox}">
                            <BulletDecorator>
                              <BulletDecorator.Bullet>
                                <Border x:Name="Border" Width="14" Height="14" CornerRadius="0" BorderThickness="1" BorderBrush="#404040"
                                        Background="White" Padding="1,0,0,0">
                                  <Path x:Name="CheckMark" Width="14" Height="10" SnapsToDevicePixels="false" Stroke="Gray"
                                        StrokeThickness="2" Data="M 1,4.5 L 4,8.5 M 4,8.5 L 8,1 "/>
                                </Border>
                              </BulletDecorator.Bullet>
                              <ContentPresenter VerticalAlignment="Center" RecognizesAccessKey="true" HorizontalAlignment="Left"/>
                            </BulletDecorator>
                          </ControlTemplate>
                        </Setter.Value>
                      </Setter>
                    </MultiDataTrigger.Setters>
                  </MultiDataTrigger>
                  <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                      <Condition Binding="{Binding Path=CalloutAlways}" Value="True"/>
                      <Condition Binding="{Binding Path=bCalloutAlwaysDiscrepency}" Value="True"/>
                      <Condition Binding="{Binding Path=AlwaysCalloutReadOnly}" Value="False"/>
                    </MultiDataTrigger.Conditions>
                    <MultiDataTrigger.Setters>
                      <Setter Property="Control.Background" Value="LightGray"/>
                    </MultiDataTrigger.Setters>
                  </MultiDataTrigger>
                  <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                      <Condition Binding="{Binding Path=CalloutAlways}" Value="False"/>
                      <Condition Binding="{Binding Path=bCalloutAlwaysDiscrepency}" Value="True"/>
                      <Condition Binding="{Binding Path=AlwaysCalloutReadOnly}" Value="False"/>
                    </MultiDataTrigger.Conditions>
                    <MultiDataTrigger.Setters>
                      <Setter Property="Control.Background" Value="LightGray"/>
                    </MultiDataTrigger.Setters>
                  </MultiDataTrigger>
                </Style.Triggers>
              </Style>
            </DataGridBoundColumn.ElementStyle>
          </DataGridCheckBoxColumn>
          <DataGridCheckBoxColumn Header="CALLOUT__DIM" IsReadOnly="false" CanUserResize="false" MinWidth="120" Width="120"
                                  Binding="{Binding Path=CalloutDim, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
            <DataGridBoundColumn.ElementStyle>
              <Style TargetType="{x:Type CheckBox}" BasedOn="{StaticResource {x:Type CheckBox}}">
                <Setter Property="FrameworkElement.HorizontalAlignment" Value="Center"/>
                <Style.Triggers>
                  <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                      <Condition Binding="{Binding Path=CalloutReadOnly}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <MultiDataTrigger.Setters>
                      <Setter Property="UIElement.IsEnabled" Value="false"/>
                    </MultiDataTrigger.Setters>
                  </MultiDataTrigger>
                  <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                      <Condition Binding="{Binding Path=CalloutDim}" Value="{x:Null}"/>
                      <Condition Binding="{Binding Path=bCalloutDimDiscrepency}" Value="False"/>
                    </MultiDataTrigger.Conditions>
                    <MultiDataTrigger.Setters>
                      <Setter Property="UIElement.SnapsToDevicePixels" Value="true"/>
                      <Setter Property="FrameworkElement.OverridesDefaultStyle" Value="true"/>
                      <Setter Property="FrameworkElement.FocusVisualStyle" Value="{x:Null}"/>
                      <Setter Property="Control.Template">
                        <Setter.Value>
                          <ControlTemplate TargetType="{x:Type CheckBox}">
                            <BulletDecorator>
                              <BulletDecorator.Bullet>
                                <Border x:Name="Border" Width="14" Height="14" CornerRadius="0" BorderThickness="1" BorderBrush="#404040"
                                        Background="White" Padding="1,0,0,0">
                                  <Path x:Name="CheckMark" Width="14" Height="10" SnapsToDevicePixels="false" Stroke="Gray"
                                        StrokeThickness="2" Data="M 1,4.5 L 4,8.5 M 4,8.5 L 8,1 "/>
                                </Border>
                              </BulletDecorator.Bullet>
                              <ContentPresenter VerticalAlignment="Center" RecognizesAccessKey="true" HorizontalAlignment="Left"/>
                            </BulletDecorator>
                          </ControlTemplate>
                        </Setter.Value>
                      </Setter>
                    </MultiDataTrigger.Setters>
                  </MultiDataTrigger>
                  <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                      <Condition Binding="{Binding Path=CalloutDim}" Value="True"/>
                      <Condition Binding="{Binding Path=bCalloutDimDiscrepency}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <MultiDataTrigger.Setters>
                      <Setter Property="Control.Background" Value="LightGray"/>
                    </MultiDataTrigger.Setters>
                  </MultiDataTrigger>
                  <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                      <Condition Binding="{Binding Path=CalloutDim}" Value="False"/>
                      <Condition Binding="{Binding Path=bCalloutDimDiscrepency}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <MultiDataTrigger.Setters>
                      <Setter Property="Control.Background" Value="LightGray"/>
                    </MultiDataTrigger.Setters>
                  </MultiDataTrigger>
                </Style.Triggers>
              </Style>
            </DataGridBoundColumn.ElementStyle>
          </DataGridCheckBoxColumn>
        </DataGrid.Columns>
      </DataGrid>
    </Grid>
    <Grid Column="1" Row="3">
      <Button Click="Ok_Click" x:Name="ok" Content="OK" HorizontalAlignment="Left" VerticalAlignment="Center"
              Width="80" Height="35" BorderBrush="Black" BorderThickness="1" Margin="150,0,0,0"/>
      <Button Click="Cancel_Click" x:Name="cancel" Content="Cancel" HorizontalAlignment="Right"
              VerticalAlignment="Center" Width="80" BorderBrush="Black" BorderThickness="1" Height="35"
              Margin="0,0,150,0"/>
    </Grid>
  </Grid>
</Window>