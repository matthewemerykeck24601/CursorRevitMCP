<Window x:Class="EDGE.__Testing.ProgressReporter.ProgressMonitor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:EDGE.__Testing.ProgressReporter"
        Width="300" Height="130">
  <Grid>
    <ProgressBar Name="pProgress" HorizontalAlignment="Left" Height="19" Margin="32,39,0,0" VerticalAlignment="Top"
                 Width="220"/>
    <TextBlock x:Name="tbStatus" HorizontalAlignment="Left" Margin="32,10,0,0" TextWrapping="Wrap"
               Text="TextBlock" VerticalAlignment="Top"/>
    <Button Click="btnCancel_Click" x:Name="btnCancel" Content="Cancel" HorizontalAlignment="Left"
            Margin="96,69,0,0" VerticalAlignment="Top" Width="75"/>
  </Grid>
</Window>