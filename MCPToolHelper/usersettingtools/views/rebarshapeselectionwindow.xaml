<Window x:Class="EDGE.UserSettingTools.Views.RebarShapeSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:EDGE.UserSettingTools.Views"
        Title="Rebar Shape Selection Window" Height="400" Width="300">
  <FrameworkElement.Resources>
    <local:RebarShapeConverter x:Key="RebarShapeConverter"/>
  </FrameworkElement.Resources>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <ListBox Name="rebarShapeListBox" Margin="10" BorderThickness="2" HorizontalContentAlignment="Stretch"
             Height="280" Width="250">
      <ItemsControl.ItemTemplate>
        <DataTemplate>
          <Border Margin="5" BorderThickness="0" BorderBrush="LightSteelBlue">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="5*"/>
              </Grid.ColumnDefinitions>
              <TextBlock Margin="10" FontWeight="Bold" Text="{Binding Path=RebarName}"/>
              <Image Grid.Column="1" HorizontalAlignment="Left" Margin="5" Width="120" Height="50"
                     Source="{Binding Path=RebarName, Converter={StaticResource RebarShapeConverter}}"/>
            </Grid>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ListBox>
    <Grid Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="5*"/>
        <ColumnDefinition Width="5*"/>
      </Grid.ColumnDefinitions>
      <TextBlock Margin="10,7,7,6.8">User Defined Shape:</TextBlock>
      <TextBox Name="TextBox" Margin="6.6,7,0,6.8" Grid.Column="1" HorizontalAlignment="Left" Width="131"/>
    </Grid>
    <Button Click="Button_Click" Grid.Row="2" HorizontalAlignment="Left" Margin="128,6.8,0,6.8" Width="45">select</Button>
  </Grid>
</Window>