<Window x:Class="EDGE.TicketTools.TicketManager.Views.EditIdentCommentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:viewModels="clr-namespace:EDGE.TicketTools.TicketManager.ViewModels"
        Height="541.922" MinHeight="300" MaxHeight="300" MaxWidth="900" WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight" Width="498.787" Title="{Binding WindowTitle}">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="4.8"/>
      <ColumnDefinition MaxWidth="980"/>
      <ColumnDefinition Width="10"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="10"/>
      <RowDefinition Height="27"/>
      <RowDefinition MaxHeight="390"/>
      <RowDefinition Height="110.4"/>
      <RowDefinition Height="0"/>
    </Grid.RowDefinitions>
    <Label x:Name="DataGridTitle" Grid.Row="1" Grid.Column="1" FontWeight="Bold" VerticalAlignment="Center"
           HorizontalAlignment="Center" Height="9" Margin="231.2,9.6,235.6,8.6" Width="10"
           Content="{Binding DataGridLabel}"/>
    <Button Click="ConfirmButton_Click" Grid.Row="3" Grid.Column="1" Width="74" HorizontalAlignment="Left"
            Content="Save" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
            Margin="1.2,53,0,29.4" RenderTransformOrigin="0.452,2.902"
            CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}"/>
    <Button Click="CancelButton_Click" Grid.Row="3" Grid.Column="1" Width="75" HorizontalAlignment="Right"
            Content="Cancel" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
            Margin="0,53,2.6,29.4" RenderTransformOrigin="0.44,-0.288"
            CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}"/>
    <Label x:Name="label" Content="Edit Identity Comment for MARK NUMBER and click save to commit changes:"
           HorizontalAlignment="Left" Margin="3.4,1.6,0,0" Grid.Row="1" VerticalAlignment="Top" Width="424"
           Height="26" Grid.Column="1" Grid.RowSpan="2"/>
    <TextBox x:Name="identCommentTextBox" TabIndex="8" Grid.Column="1" HorizontalAlignment="Left" Height="23"
             Margin="6,57.4,0,0" Grid.Row="2" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="457"/>
    <Label x:Name="label1" Content="" Visibility="Hidden" Grid.Column="1" HorizontalContentAlignment="Left"
           HorizontalAlignment="Left" Margin="9.2,53,0,0" Grid.Row="3" VerticalAlignment="Top" Width="452"
           Height="26" RenderTransformOrigin="0.505,0.169"/>
    <Label x:Name="identCommentLabel" Content="Identity Comment" HorizontalContentAlignment="Left"
           HorizontalAlignment="Left" Margin="3.4,34.4,0,0" Grid.Row="2" VerticalAlignment="Top"
           RenderTransformOrigin="-0.737,-0.287" Width="391" Grid.ColumnSpan="2" Height="26"/>
    <Label x:Name="label2_Copy3" Content="Update Identity Comment to continue" Foreground="Red"
           Visibility="Hidden" Grid.Column="1" HorizontalAlignment="Left" Margin="188.2,2.4,0,0" Grid.Row="2"
           VerticalAlignment="Top" RenderTransformOrigin="-0.737,-0.287" Height="26" Width="213"/>
    <Button Click="ClearAllButton_Click" Grid.Row="3" Grid.Column="1" Width="75" HorizontalAlignment="Left"
            Content="Clear" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
            Margin="314.2,53,0,29.4" RenderTransformOrigin="0.573,1.855"
            CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}"/>
  </Grid>
</Window>