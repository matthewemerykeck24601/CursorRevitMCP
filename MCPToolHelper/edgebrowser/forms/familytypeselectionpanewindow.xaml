<Window x:Class="EDGE.EDGEBrowser.Forms.FamilyTypeSelectionPaneWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:EDGE.EDGEBrowser.Forms"
        xmlns:forms="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
        Background="{DynamicResource {x:Static JetSystemColors.ControlBrushKey}}" MinWidth="700"
        Height="450" Width="Auto" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
  <Grid Background="{DynamicResource {x:Static JetSystemColors.ControlBrushKey}}"
        HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Height="auto" Width="auto">
    <Grid.ColumnDefinitions>
      <ColumnDefinition/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="5*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <TextBlock x:Name="txtLabel" Text="Please select the type of Family you wish to import:" Margin="4,4,4,6"
               FontSize="20" Grid.Row="0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
    <DataGrid x:Name="FamilyTypeSelectionDataGrid" CanUserAddRows="false" Grid.Row="1"
              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" CanUserDeleteRows="false"
              IsReadOnly="true" SelectionUnit="FullRow" SelectionMode="Extended" HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"/>
    <WrapPanel HorizontalAlignment="Center" Orientation="Horizontal" VerticalAlignment="Bottom" Grid.Row="2">
      <Button Click="btnSelectAll_Click" Name="btnSelectAll" Grid.Row="2" Content="Select All"
              HorizontalAlignment="Left" HorizontalContentAlignment="Center" VerticalAlignment="Bottom"
              Margin="10,0,4,4" Padding="4,0,4,0" Width="125" FontSize="16" Height="30"/>
      <Button Click="btnDeselectAll_Click" Name="btnDeselectAll" Grid.Row="2" FontFamily="Segoe UI Symbol"
              HorizontalAlignment="Left" Content="Deselect All" HorizontalContentAlignment="Center"
              Margin="4,0,60,4" VerticalAlignment="Bottom" Padding="4,0,4,0" Width="125" FontSize="16"
              Height="30"/>
      <Button Click="btnConfirm_Click" Name="btnConfirm" Grid.Row="2" Content="Confirm"
              HorizontalAlignment="Right" HorizontalContentAlignment="Center" VerticalAlignment="Bottom"
              Margin="60,0,4,4" Padding="4,0,4,0" Width="125" FontSize="16" Height="30"/>
      <Button Click="btnCancel_Click" Name="btnCancel" Grid.Row="2" FontFamily="Segoe UI Symbol"
              HorizontalAlignment="Right" Content="Cancel" HorizontalContentAlignment="Center"
              VerticalAlignment="Bottom" Margin="4,0,4,4" Padding="4,0,4,0" Width="125" FontSize="16" Height="30"/>
    </WrapPanel>
  </Grid>
</Window>