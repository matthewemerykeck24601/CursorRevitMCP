<Window x:Class="EDGE.TicketTools.CloneTicket.BOMFormattingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:EDGE.TicketTools.CloneTicket"
        Height="350" Width="700" ResizeMode="NoResize" Title="BOM Format Settings" Background="LightGray">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="10"/>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="10"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="10"/>
      <RowDefinition Height="1.25*"/>
      <RowDefinition Height=".75*"/>
      <RowDefinition Height=".4*"/>
      <RowDefinition Height="10"/>
    </Grid.RowDefinitions>
    <DataGrid Name="dataGrid" Grid.Column="1" Grid.Row="1" CanUserAddRows="false" CanUserDeleteRows="false"
              IsReadOnly="true" VerticalScrollBarVisibility="Visible" VerticalAlignment="Stretch"
              CanUserResizeColumns="false" CanUserResizeRows="false" BorderBrush="Black" BorderThickness="1"
              AutoGenerateColumns="false" HorizontalScrollBarVisibility="Disabled" Panel.ZIndex="1"
              ItemsSource="{Binding SheetList}">
      <FrameworkElement.Resources>
        <Style TargetType="{x:Type DataGridColumnHeader}">
          <Setter Property="Control.HorizontalContentAlignment" Value="Center"/>
        </Style>
      </FrameworkElement.Resources>
      <DataGrid.Columns>
        <DataGridTextColumn Header="Sheet" Width="240" Binding="{Binding SheetID}"/>
        <DataGridTemplateColumn Header="BOM Alignment" Width="200">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <ComboBox ItemsSource="{Binding AlignmentList}"
                        SelectedValue="{Binding AlignmentSelection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTemplateColumn Header="BOM Stacking" Width="200">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <ComboBox ItemsSource="{Binding StackingList}"
                        SelectedItem="{Binding StackingSelection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
      </DataGrid.Columns>
    </DataGrid>
    <Grid Row="2" Column="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="5"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="5"/>
      </Grid.RowDefinitions>
      <Border Grid.Column="0" Grid.Row="1" BorderThickness="2" CornerRadius="3">
        <Border Grid.Column="2" BorderBrush="Black" BorderThickness="1" CornerRadius="3">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="*"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Button Click="TopButton_Click" x:Name="TopButton" Content="Top" Panel.ZIndex="0" Grid.Row="0" Height="22"
                    VerticalAlignment="Center" Width="150" HorizontalAlignment="Center" Margin="0,10,0,0"/>
            <Button Click="BottomButton_Click" x:Name="BottomButton" Panel.ZIndex="1" Content="Bottom" Grid.Row="1"
                    Height="22" VerticalAlignment="Center" Width="150" HorizontalAlignment="Center" Margin="0,0,0,10"
                    Padding="2"/>
          </Grid>
        </Border>
      </Border>
      <Label Grid.Column="0" Panel.ZIndex="1" Background="LightGray" Grid.RowSpan="2" Content="BOM Alignment"
             Margin="66,-6,62,71" Height="28"/>
      <Label Grid.Row="1" Grid.Column="0" Panel.ZIndex="0" Background="LightGray" Content="Apply To All"
             Margin="76,65,73,-6" Grid.RowSpan="2"/>
      <Border Grid.Column="2" Grid.Row="1" BorderThickness="2" CornerRadius="3">
        <Border Grid.Column="2" BorderBrush="Black" BorderThickness="1" CornerRadius="3">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="*"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Button Click="StackButton_Click" x:Name="StackButton" Content="Stack" Panel.ZIndex="0" Grid.Row="0"
                    Height="22" VerticalAlignment="Center" Width="150" HorizontalAlignment="Center" Margin="0,10,0,0"/>
            <Button Click="IndependentButton_Click" x:Name="IndependentButton" Panel.ZIndex="1" Content="Independent"
                    Grid.Row="1" Height="22" VerticalAlignment="Center" Width="150" HorizontalAlignment="Center"
                    Margin="0,0,0,10" Padding="2"/>
          </Grid>
        </Border>
      </Border>
      <Label Grid.Column="2" Panel.ZIndex="1" Background="LightGray" Grid.RowSpan="2" Content="BOM Stacking"
             Margin="71,-6,67,71" Height="28"/>
      <Label Grid.Row="1" Grid.Column="2" Panel.ZIndex="0" Background="LightGray" Content="Apply To All"
             Margin="76,65,73,-6" Grid.RowSpan="2"/>
    </Grid>
    <Grid Column="1" Row="3" ZIndex="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <Button Click="ContinueButton_Click" Name="ContinueButton" Grid.Column="0" Content="OK" Margin="80,10,80,0"/>
      <Button Click="CancelButton_Click" Name="CancelButton" Grid.Column="1" Content="Cancel" Margin="80,10,80,0"/>
    </Grid>
  </Grid>
</Window>