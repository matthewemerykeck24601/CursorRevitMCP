APS_CLIENT_ID=your_aps_client_id
APS_CLIENT_SECRET=your_aps_client_secret
APS_CALLBACK_URL=http://localhost:3000/auth/callback
# Monty iOS native OAuth — must match APS Custom URL callback (default monty://autodesk-oauth)
APS_NATIVE_REDIRECT_URI=monty://autodesk-oauth
APP_BASE_URL=http://localhost:3000
APS_SCOPE=data:read data:write data:create data:search user:read offline_access viewables:read account:read
AI_PROVIDER=xai
# direct | firebase_functions
AI_GATEWAY_MODE=direct
# required when AI_GATEWAY_MODE=firebase_functions
AI_GATEWAY_FUNCTION_URL=
# required when AI_GATEWAY_MODE=firebase_functions; requests fail closed without it
AI_GATEWAY_SHARED_SECRET=
XAI_API_KEY=
XAI_MODEL=grok-4.20-multi-agent-0309
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
CHAT_LOG_LEVEL=full
APS_ISSUES_CONTAINER_ID=
APS_ISSUES_DEFAULT_TYPE_ID=
APS_DESIGN_FILES_BUCKET=
# Admin data-ingest/cache policy
# true: never trigger Data Connector extraction jobs from app flows; only read latest completed extraction
ADMIN_DATA_CONNECTOR_READ_ONLY_LATEST_EXTRACTION=true
# emergency override (keep false in production)
ADMIN_ALLOW_DATA_CONNECTOR_REQUEST_CREATION=false
# lookup store backend phase-in target
ADMIN_LOOKUP_STORE_BACKEND=oss_local

# Design Automation (optional): POST workitems when trigger_design_automation_mark_update runs with confirm=true
# Requires APS app with code:all scope for client_credentials
DA_ENABLED=false
DA_REGION=us-east
DA_ACTIVITY_ID=
# Optional: dedicated SaveAsCloudModel activity for create_revit_cloud_workshared_model
# DA_ACTIVITY_ID_CREATE_MODEL=
# Optional: version-specific activity routing (recommended if you support both net48 and net8+ appbundles)
# DA_ACTIVITY_ID_2024=
# DA_ACTIVITY_ID_2025=
# DA_ACTIVITY_ID_2026=
# DA_ACTIVITY_ID_2027=
# Optional runtime-track aliases:
# DA_ACTIVITY_ID_NET8=
# DA_ACTIVITY_ID_NET10=
# Optional: skip GET /workitems/:id immediately after submit
# DA_SKIP_WORKITEM_POLL=false
# Bounded polling after submit and on status follow-ups (1–4 attempts, delay in ms)
# DA_POLL_MAX_ATTEMPTS=2
# DA_POLL_DELAY_MS=2000

