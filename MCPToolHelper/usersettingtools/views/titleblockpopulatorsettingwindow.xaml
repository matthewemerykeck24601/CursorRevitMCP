<Window x:Class="EDGE.UserSettingTools.Views.TitleBlockPopulatorSettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:EDGE.UserSettingTools.Views"
        WindowStartupLocation="CenterOwner" Height="500" Width="500" Title="Title Block Populator Settings"
        MinHeight="450" MinWidth="500" MaxWidth="500">
  <FrameworkElement.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/EDGEforREVIT;component/EDGELogo.xaml"/>
      </ResourceDictionary.MergedDictionaries>
      <local:Converters x:Key="Converter"/>
      <local:FontColorConverter x:Key="FontColorConverter"/>
    </ResourceDictionary>
  </FrameworkElement.Resources>
  <Grid Margin="15">
    <Grid.RowDefinitions>
      <RowDefinition Height="66"/>
      <RowDefinition Height="25"/>
      <RowDefinition Height="40"/>
      <RowDefinition Height="40"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="40"/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition/>
      <ColumnDefinition/>
    </Grid.ColumnDefinitions>
    <ContentControl Grid.ColumnSpan="2" Template="{StaticResource EDGELogoStyle}" HorizontalAlignment="Stretch"
                    VerticalAlignment="Bottom" Height="60"/>
    <TextBlock VerticalAlignment="Bottom" HorizontalAlignment="Center" Grid.Row="1">Source Parameter:</TextBlock>
    <ComboBox SelectionChanged="MappingFromList_SelectionChanged" Name="MappingFromList"
              HorizontalAlignment="Stretch" VerticalAlignment="Top" Grid.Row="2" Margin="20,5"/>
    <TextBlock VerticalAlignment="Bottom" HorizontalAlignment="Center" Grid.Column="1" Grid.Row="1">Sheet Parameter:</TextBlock>
    <ComboBox SelectionChanged="MappingToList_SelectionChanged" Name="MappingToList" Grid.Column="1" Grid.Row="2"
              HorizontalAlignment="Stretch" VerticalAlignment="Top" Margin="20,5"/>
    <Button Click="AddRow_Click" Name="AddRow" Grid.Row="3" HorizontalAlignment="Stretch" Content="Add Mapping"
            Margin="20,10"/>
    <Button Click="DeleteButton_Click" Name="Delete" Grid.Row="3" Grid.Column="1" Visibility="Visible"
            Margin="20,10" HorizontalAlignment="Stretch">Delete Mapping</Button>
    <DataGrid Name="TBMapping_List" Grid.ColumnSpan="2" AutoGenerateColumns="false" CanUserAddRows="false"
              HorizontalAlignment="Stretch" Grid.Row="4">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Source Parameter" IsReadOnly="true" Width=".6*" Binding="{Binding mappingFromParam}">
          <DataGridBoundColumn.ElementStyle>
            <Style TargetType="{x:Type TextBlock}">
              <Setter Property="TextBlock.TextWrapping" Value="Wrap"/>
              <Setter Property="TextBlock.Foreground"
                      Value="{Binding Path=canDeleteParam, Converter={StaticResource FontColorConverter}}"/>
            </Style>
          </DataGridBoundColumn.ElementStyle>
          <DataGridBoundColumn.EditingElementStyle>
            <Style TargetType="{x:Type TextBox}">
              <Setter Property="TextBox.TextWrapping" Value="Wrap"/>
              <Setter Property="TextBoxBase.AcceptsReturn" Value="true"/>
            </Style>
          </DataGridBoundColumn.EditingElementStyle>
        </DataGridTextColumn>
        <DataGridTextColumn Header="Sheet Parameter" IsReadOnly="true" Width=".4*" Binding="{Binding mappingToParam}">
          <DataGridBoundColumn.ElementStyle>
            <Style TargetType="{x:Type TextBlock}">
              <Setter Property="TextBlock.Foreground"
                      Value="{Binding Path=canDeleteParam, Converter={StaticResource FontColorConverter}}"/>
            </Style>
          </DataGridBoundColumn.ElementStyle>
        </DataGridTextColumn>
      </DataGrid.Columns>
    </DataGrid>
    <Button Click="SaveButton_Click" Grid.Row="5" Grid.Column="0" Margin="5" HorizontalAlignment="Center"
            VerticalAlignment="Bottom" Content="Save" Width="100"/>
    <Button Click="CancelButton_Click" Grid.Row="5" Grid.Column="1" Margin="5" HorizontalAlignment="Center"
            VerticalAlignment="Bottom" Content="Cancel" Width="100"/>
  </Grid>
</Window>