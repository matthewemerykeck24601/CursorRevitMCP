<Window x:Class="EDGE.UserSettingTools.Views.AutoTicketSettings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:EDGE.UserSettingTools.Views"
        Title="Ticket and Dimension Settings" Height="350" Width="650" ResizeMode="NoResize">
  <Grid Background="WhiteSmoke">
    <Grid.RowDefinitions>
      <RowDefinition Height="1*"/>
      <RowDefinition Height="8*"/>
      <RowDefinition Height="1.2*"/>
    </Grid.RowDefinitions>
    <TabControl SelectionChanged="TabPanel_SelectionChanged" Grid.Row="0" IsEnabled="true">
      <TabItem Header="Auto Ticket Generation" Height="27" Padding="0,0,0,0" Width="130"/>
      <TabItem Header="Ticket Auto-dimension" Height="27" Padding="0,0,0,0" Width="130"/>
      <TabItem Header="Erection Drawing Auto-dimension" Height="27" Padding="0,0,0,0" Width="185"/>
      <TabItem Header="Clone Ticket" Height="27" Padding="0,0,0,0" Width="80"/>
      <TabItem Header="Hardware Details" Height="27" Padding="0,0,0,0" Width="100"/>
    </TabControl>
    <Grid Row="1" RowSpan="2" Visibility="Visible">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="185" MinWidth="185" MaxWidth="185"/>
        <ColumnDefinition Width="415" MaxWidth="415" MinWidth="415"/>
      </Grid.ColumnDefinitions>
      <GridSplitter Name="GridSpliter" Grid.Column="1" Width="5" VerticalAlignment="Stretch" HorizontalAlignment="Left"/>
      <Border Name="AutoTicketTab" Visibility="Hidden" Grid.Column="0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="7*"/>
            <RowDefinition Height="3*"/>
          </Grid.RowDefinitions>
          <ListBox SelectionChanged="Setting_SelectedTicketGeneration" Name="SettingTicketGeneration">
            <ItemsControl.ItemContainerStyle>
              <Style>
                <Setter Property="Control.Padding" Value="0"/>
                <Style.Triggers>
                  <Trigger Property="ListBoxItem.IsSelected" Value="true">
                    <Setter Property="Control.Background" Value="LightSteelBlue"/>
                    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
                  </Trigger>
                </Style.Triggers>
              </Style>
            </ItemsControl.ItemContainerStyle>
            <ListBoxItem Margin="5" FontWeight="DemiBold" HorizontalAlignment="Left" Height="25" Width="169">
              Callout, Dimensions, and Text
            </ListBoxItem>
            <ListBoxItem Margin="5" FontWeight="DemiBold" HorizontalAlignment="Left" Height="25" Width="115">Append String</ListBoxItem>
            <ListBoxItem Margin="5" FontWeight="DemiBold" HorizontalAlignment="Left" Height="25" Width="150">
              Minimum Dimension Value
            </ListBoxItem>
            <ListBoxItem Margin="5" FontWeight="DemiBold" HorizontalAlignment="Left" Height="25" Width="136">
              Precast Dimension Text
            </ListBoxItem>
          </ListBox>
        </Grid>
      </Border>
      <Border Grid.Column="1">
        <Grid Name="StyleTabTicketGeneration" Visibility="Hidden">
          <TextBlock HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,5,0,0">
            Select the desired families for Callouts, Dimension Strings, and Text
          </TextBlock>
          <TextBlock FontWeight="DemiBold" HorizontalAlignment="Left" Margin="8,40,0,0" VerticalAlignment="Top">Callout Family</TextBlock>
          <ComboBox Name="CalloutStyleComboBoxTicketGeneration" Margin="83,40,0,0" Height="20" Width="200"
                    IsEditable="false" HorizontalAlignment="Center" VerticalAlignment="Top"/>
          <TextBlock FontWeight="DemiBold" HorizontalAlignment="Left" Margin="8,-115,0,0" VerticalAlignment="Center">
            Overall Dimension Style
          </TextBlock>
          <ComboBox Name="DimensionStyleComboBoxTicketGeneration" Margin="83,-115,0,0" Height="20" Width="200"
                    IsEditable="false" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          <TextBlock FontWeight="DemiBold" HorizontalAlignment="Left" Margin="8,-35,0,0" VerticalAlignment="Center">General Dimension</TextBlock>
          <ComboBox Name="OtherDimensionStyleComboBoxTicketGeneration" Margin="83,-35,0,0" Height="20" Width="200"
                    IsEditable="false" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          <CheckBox Name="CheckBoxEqualityFormula" Margin="12,0,0,125" HorizontalAlignment="Center"
                    VerticalAlignment="Bottom" IsChecked="True">
            Use Equality Formula
          </CheckBox>
          <TextBlock FontWeight="DemiBold" HorizontalAlignment="Left" Margin="8,0,0,95" VerticalAlignment="Bottom">Text Style</TextBlock>
          <ComboBox Name="TextStyleComboBoxTicketGeneration" Margin="83,0,0,95" Height="20" Width="200"
                    HorizontalAlignment="Center" IsEditable="false" VerticalAlignment="Bottom"/>
        </Grid>
      </Border>
      <Border Grid.Column="1">
        <Grid Name="AppendStringTabTicketGeneration" Visibility="Hidden">
          <Grid.RowDefinitions>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="2.5*"/>
          </Grid.RowDefinitions>
          <TextBlock HorizontalAlignment="Center" Padding="5,0,10,0" VerticalAlignment="Top" Margin="0,5,0,0"
                     TextWrapping="Wrap" TextAlignment="Justify">
            Move your cursor to the desired Append String location. Define the desired parameter from the dropdown. Select the + button to add the new parameter definition at your cursor's current location.
          </TextBlock>
          <TextBlock FontWeight="DemiBold" HorizontalAlignment="Left" Margin="28,10,0,0" VerticalAlignment="Center"
                     Grid.Row="0">Append String</TextBlock>
          <RichTextBox DataObject.Pasting="AppendStringTextBox_Pasting"
                       PreviewTextInput="AppendStringTextBox_PreviewTextInput"
                       TextChanged="AppendStringTextBoxTicketGeneration_TextChanged"
                       Name="AppendStringTextBoxTicketGeneration" Width="200" Height="35" HorizontalAlignment="Center"
                       VerticalAlignment="Center" Margin="80,13,5,0" Grid.Row="0" VerticalScrollBarVisibility="Auto"/>
          <TextBlock FontWeight="DemiBold" HorizontalAlignment="Left" Margin="28,90,0,0" VerticalAlignment="Center"
                     Grid.Row="0">Example Result</TextBlock>
          <TextBox Name="ExampleResultTextBoxTicketGeneration" Foreground="Gray" IsReadOnly="true" TextWrapping="Wrap"
                   ScrollViewer.VerticalScrollBarVisibility="Auto" Width="200" Height="35"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="80,95,5,0" Grid.Row="0"
                   AcceptsReturn="false"/>
          <Border BorderThickness="2" BorderBrush="Black" Width="325" Margin="0,0,0,0" Height="115" Grid.Row="1">
            <Grid Name="ParameterDefinitionBlockTicketGeneration" Visibility="Visible">
              <TextBlock FontWeight="DemiBold" HorizontalAlignment="Center" VerticalAlignment="Top" Foreground="Black"
                         Margin="0,3,0,0">
                Parameter Definition
              </TextBlock>
              <ComboBox SelectionChanged="ParameterValuesList_SelectionChanged" Name="ParameterValuesListTicketGeneration"
                        FontWeight="DemiBold" Width="200" Height="20" HorizontalAlignment="Left" VerticalAlignment="Top"
                        Margin="30,26,0,0"/>
              <Button Click="AddButton_Click" Name="AddButtonTicketGeneration" FontWeight="DemiBold" Height="20"
                      Width="60" Padding="0,-3,0,0" VerticalAlignment="Top" HorizontalAlignment="Right"
                      Margin="0,26,30,0" Foreground="Blue" FontSize="13"/>
              <TextBlock FontWeight="DemiBold" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="30,20,0,0">Prefix</TextBlock>
              <TextBox DataObject.Pasting="AppendStringTextBox_Pasting"
                       PreviewTextInput="AppendStringTextBox_PreviewTextInput" TextChanged="PrePostTextBox_TextChanged"
                       x:Name="PrefixTextBoxTicketGeneration" FontWeight="DemiBold" Height="20" Width="40"
                       HorizontalAlignment="Left" VerticalAlignment="Center" Margin="63,20,0,0"/>
              <TextBlock FontWeight="DemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20,75,0">Suffix</TextBlock>
              <TextBox DataObject.Pasting="AppendStringTextBox_Pasting"
                       PreviewTextInput="AppendStringTextBox_PreviewTextInput" TextChanged="PrePostTextBox_TextChanged"
                       x:Name="SuffixTextBoxTicketGeneration" FontWeight="DemiBold" Height="20" Width="40"
                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20,0,0"/>
              <TextBlock FontWeight="DemiBold" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,20,102,0">Result</TextBlock>
              <TextBox x:Name="ResultTextBoxTicketGeneration" FontWeight="DemiBold" Height="20" Width="69"
                       HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,20,30,0" IsEnabled="false"/>
              <TextBlock Name="ApplicableTextTicketGeneration" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                         Foreground="Gray" Margin="0,0,35,15" FontWeight="DemiBold" FontSize="11" Visibility="Hidden">
                *This field will only appear when applicable
              </TextBlock>
            </Grid>
          </Border>
        </Grid>
      </Border>
      <Border Grid.Column="1">
        <Grid Name="CustomValuesTabTicketGeneration" Visibility="Hidden">
          <TextBlock HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,5,0,0" TextWrapping="Wrap">
            Customize the labels for Overall, Contour, and Blockout dimension strings
          </TextBlock>
          <TextBlock FontWeight="DemiBold" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="38,55,0,0">OVERALL</TextBlock>
          <TextBox CommandManager.PreviewExecuted="customTextBoxTicketGeneration_PreviewExecuted"
                   PreviewTextInput="customTextBoxTicketGeneration_PreviewTextInput"
                   Name="overallTextBoxTicketGeneration" Width="200" Height="20" HorizontalAlignment="Center"
                   VerticalAlignment="Top" Margin="80,55,0,0"/>
          <TextBlock FontWeight="DemiBold" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="38,-60,0,0">CONTOUR</TextBlock>
          <TextBox CommandManager.PreviewExecuted="customTextBoxTicketGeneration_PreviewExecuted"
                   PreviewTextInput="customTextBoxTicketGeneration_PreviewTextInput"
                   Name="contourTextBoxTicketGeneration" Width="200" Height="20" HorizontalAlignment="Center"
                   VerticalAlignment="Center" Margin="80,-60,0,0"/>
          <TextBlock FontWeight="DemiBold" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="38,0,0,110">BLOCKOUT</TextBlock>
          <TextBox CommandManager.PreviewExecuted="customTextBoxTicketGeneration_PreviewExecuted"
                   PreviewTextInput="customTextBoxTicketGeneration_PreviewTextInput"
                   Name="blockoutTextBoxTicketGeneration" Width="200" Height="20" HorizontalAlignment="Center"
                   VerticalAlignment="Bottom" Margin="80,0,0,110"/>
        </Grid>
      </Border>
      <Border Grid.Column="1" Margin="0.2,0,-0.4,0.4">
        <Grid Name="MinDimTabTicketGeneration" Visibility="Hidden">
          <TextBlock HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,5,0,0">
            Set the desired minimum spacing for elements in a dimension string
          </TextBlock>
          <TextBlock FontWeight="DemiBold" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="38,40,0,0">Dimension</TextBlock>
          <TextBox Name="MinDimFeetTextBoxTicketGeneration" Width="70" Height="20" HorizontalAlignment="Center"
                   VerticalAlignment="Top" HorizontalContentAlignment="Right" Margin="0,40,80,0"/>
          <TextBlock Name="MinDimFeetLabelTicketGeneration" HorizontalAlignment="Center" VerticalAlignment="Top"
                     Margin="88,40,80,0">ft</TextBlock>
          <TextBox Name="MinDimInchTextBoxTicketGeneration" Width="70" Height="20" HorizontalAlignment="Center"
                   VerticalAlignment="Top" HorizontalContentAlignment="Right" Margin="170,40,70,0"/>
          <TextBlock Name="MinDimInchLabelTicketGeneration" HorizontalAlignment="Center" VerticalAlignment="Top"
                     Margin="255,40,70,0">in</TextBlock>
          <Button Click="ChangeUnitsButtonTicketGeneration_Click" Name="ChangeUnitsButtonTicketGeneration" Width="80"
                  Height="20" Visibility="Hidden" HorizontalAlignment="Left" VerticalAlignment="Top"
                  Margin="27,75,0,0">Change Units</Button>
        </Grid>
      </Border>
      <Border Name="AutoDimensionTab" Visibility="Hidden" Grid.Column="0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="7*"/>
            <RowDefinition Height="3*"/>
          </Grid.RowDefinitions>
          <ListBox SelectionChanged="Setting_SelectedTicketGeneration" Name="SettingAutoDimension">
            <ItemsControl.ItemContainerStyle>
              <Style>
                <Setter Property="Control.Padding" Value="0"/>
                <Style.Triggers>
                  <Trigger Property="ListBoxItem.IsSelected" Value="true">
                    <Setter Property="Control.Background" Value="LightSteelBlue"/>
                  </Trigger>
                </Style.Triggers>
              </Style>
            </ItemsControl.ItemContainerStyle>
            <ListBoxItem Margin="5" FontWeight="DemiBold" HorizontalAlignment="Left" Height="25" Width="169">
              Dimension and Text Styles
            </ListBoxItem>
            <ListBoxItem Margin="5" FontWeight="DemiBold" HorizontalAlignment="Left" Height="25" Width="115">Append String</ListBoxItem>
            <ListBoxItem Margin="5" FontWeight="DemiBold" HorizontalAlignment="Left" Height="25" Width="150">
              Minimum Dimension Value
            </ListBoxItem>
          </ListBox>
        </Grid>
      </Border>
      <Border Grid.Column="1">
        <Grid Name="StyleTabAutoDimension" Visibility="Hidden">
          <TextBlock HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,5,0,0">
            Select the desired families for Dimension Strings and Text
          </TextBlock>
          <TextBlock FontWeight="DemiBold" HorizontalAlignment="Left" Margin="8,40,0,0" VerticalAlignment="Top">Dimension Style</TextBlock>
          <ComboBox Name="DimensionStyleComboBoxAutoDimension" Margin="83,40,0,0" Height="20" Width="200"
                    IsEditable="false" HorizontalAlignment="Center" VerticalAlignment="Top"/>
          <TextBlock FontWeight="DemiBold" HorizontalAlignment="Left" Margin="8,-100,0,0" VerticalAlignment="Center">Text Style</TextBlock>
          <ComboBox Name="TextStyleComboBoxAutoDimension" Margin="83,-100,0,0" Height="20" Width="200"
                    HorizontalAlignment="Center" IsEditable="false" VerticalAlignment="Center"/>
        </Grid>
      </Border>
      <Border Grid.Column="1">
        <Grid Name="AppendStringTabAutoDimension" Visibility="Hidden">
          <Grid.RowDefinitions>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="2.5*"/>
          </Grid.RowDefinitions>
          <TextBlock HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,5,0,0" Padding="5,0,10,0"
                     TextWrapping="Wrap" TextAlignment="Justify">
            Move your cursor to the desired Append String location. Define the desired parameter from the dropdown. Select the + button to add the new parameter definition at your cursor's current location.
          </TextBlock>
          <TextBlock FontWeight="DemiBold" HorizontalAlignment="Left" Margin="28,10,0,0" VerticalAlignment="Center"
                     Grid.Row="0">Append String</TextBlock>
          <RichTextBox DataObject.Pasting="AppendStringTextBox_Pasting"
                       PreviewTextInput="AppendStringTextBox_PreviewTextInput"
                       TextChanged="AppendStringTextBoxAutoDimension_TextChanged" Name="AppendStringTextBoxAutoDimension"
                       Width="200" Height="35" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="80,13,5,0"
                       Grid.Row="0" VerticalScrollBarVisibility="Auto"/>
          <TextBlock FontWeight="DemiBold" HorizontalAlignment="Left" Margin="28,90,0,0" VerticalAlignment="Center"
                     Grid.Row="0">Example Result</TextBlock>
          <TextBox Name="ExampleResultTextBoxAutoDimension" Foreground="Gray" IsReadOnly="true" TextWrapping="Wrap"
                   ScrollViewer.VerticalScrollBarVisibility="Auto" Width="200" Height="35"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="80,95,5,0" Grid.Row="0"/>
          <Border BorderThickness="2" BorderBrush="Black" Width="325" Margin="0,0,0,0" Height="115" Grid.Row="1">
            <Grid Name="ParameterDefinitionBockAutoDimension" Visibility="Visible">
              <TextBlock FontWeight="DemiBold" HorizontalAlignment="Center" VerticalAlignment="Top" Foreground="Black"
                         Margin="0,3,0,0">
                Parameter Definition
              </TextBlock>
              <ComboBox SelectionChanged="ParameterValuesList_SelectionChanged" Name="ParameterValuesListAutoDimension"
                        FontWeight="DemiBold" Width="200" Height="20" HorizontalAlignment="Left" VerticalAlignment="Top"
                        Margin="30,26,0,0"/>
              <Button Click="AddButton_Click" Name="AddButtonAutoDimension" FontWeight="DemiBold" Height="20" Width="60"
                      Padding="0,-3,0,0" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,26,30,0"
                      Foreground="Blue" FontSize="13"/>
              <TextBlock FontWeight="DemiBold" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="30,20,0,0">Prefix</TextBlock>
              <TextBox DataObject.Pasting="AppendStringTextBox_Pasting"
                       PreviewTextInput="AppendStringTextBox_PreviewTextInput" TextChanged="PrePostTextBox_TextChanged"
                       x:Name="PrefixTextBoxAutoDimension" FontWeight="DemiBold" Height="20" Width="40"
                       HorizontalAlignment="Left" VerticalAlignment="Center" Margin="63,20,0,0"/>
              <TextBlock FontWeight="DemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20,75,0">Suffix</TextBlock>
              <TextBox DataObject.Pasting="AppendStringTextBox_Pasting"
                       PreviewTextInput="AppendStringTextBox_PreviewTextInput" TextChanged="PrePostTextBox_TextChanged"
                       x:Name="SuffixTextBoxAutoDimension" FontWeight="DemiBold" Height="20" Width="40"
                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20,0,0"/>
              <TextBlock FontWeight="DemiBold" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,20,102,0">Result</TextBlock>
              <TextBox x:Name="ResultTextBoxAutoDimension" FontWeight="DemiBold" Height="20" Width="69"
                       HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,20,30,0" IsEnabled="false"/>
              <TextBlock Name="ApplicableTextAutoDimension" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                         Foreground="Gray" Margin="0,0,35,15" FontWeight="DemiBold" FontSize="11" Visibility="Hidden">
                *This field will only appear when applicable
              </TextBlock>
            </Grid>
          </Border>
        </Grid>
      </Border>
      <Border Grid.Column="1" Margin="0.2,0,-0.4,0.4">
        <Grid Name="MinDimTabAutoDimension" Visibility="Hidden">
          <TextBlock HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,5,0,0">
            Set the desired minimum spacing for elements in a dimension string
          </TextBlock>
          <TextBlock FontWeight="DemiBold" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="38,40,0,0">Dimension</TextBlock>
          <TextBox Name="MinDimFeetTextBoxAutoDimension" Width="70" Height="20" HorizontalAlignment="Center"
                   VerticalAlignment="Top" HorizontalContentAlignment="Right" Margin="0,40,80,0"/>
          <TextBlock Name="MinDimFeetLabelAutoDimension" HorizontalAlignment="Center" VerticalAlignment="Top"
                     Margin="88,40,80,0">ft</TextBlock>
          <TextBox Name="MinDimInchTextBoxAutoDimension" Width="70" Height="20" HorizontalAlignment="Center"
                   VerticalAlignment="Top" HorizontalContentAlignment="Right" Margin="170,40,70,0"/>
          <TextBlock Name="MinDimInchLabelAutoDimension" HorizontalAlignment="Center" VerticalAlignment="Top"
                     Margin="255,40,70,0">in</TextBlock>
          <Button Click="ChangeUnitsButtonAutoDimension_Click" Name="ChangeUnitsButtonAutoDimension" Width="80"
                  Height="20" Visibility="Hidden" HorizontalAlignment="Left" VerticalAlignment="Top"
                  Margin="27,75,0,0">Change Units</Button>
        </Grid>
      </Border>
      <Border Name="AutoDimensionEDrawingTab" Grid.Column="0" Visibility="Hidden">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="7*"/>
            <RowDefinition Height="3*"/>
          </Grid.RowDefinitions>
          <ListBox SelectionChanged="Setting_SelectedTicketGeneration" Name="SettingAutoDimensionEDrawing">
            <ItemsControl.ItemContainerStyle>
              <Style>
                <Setter Property="Control.Padding" Value="0"/>
                <Style.Triggers>
                  <Trigger Property="ListBoxItem.IsSelected" Value="true">
                    <Setter Property="Control.Background" Value="LightSteelBlue"/>
                  </Trigger>
                </Style.Triggers>
              </Style>
            </ItemsControl.ItemContainerStyle>
            <ListBoxItem Margin="5" FontWeight="DemiBold" HorizontalAlignment="Left" Height="25" Width="169">
              Dimension and Text Styles
            </ListBoxItem>
            <ListBoxItem Margin="5" FontWeight="DemiBold" HorizontalAlignment="Left" Height="25" Width="115">Append String</ListBoxItem>
          </ListBox>
        </Grid>
      </Border>
      <Border Grid.Column="1">
        <Grid Name="StyleTabAutoDimensionEDrawing" Visibility="Hidden">
          <TextBlock HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,5,0,0">
            Select the desired families for Dimension Strings and Text
          </TextBlock>
          <TextBlock FontWeight="DemiBold" HorizontalAlignment="Left" Margin="8,40,0,0" VerticalAlignment="Top">Dimension Style</TextBlock>
          <ComboBox Name="DimensionStyleComboBoxAutoDimensionEDrawing" Margin="83,40,0,0" Height="20" Width="200"
                    IsEditable="false" HorizontalAlignment="Center" VerticalAlignment="Top"/>
          <TextBlock FontWeight="DemiBold" HorizontalAlignment="Left" Margin="8,-100,0,0" VerticalAlignment="Center">Text Style</TextBlock>
          <ComboBox Name="TextStyleComboBoxAutoDimensionEDrawing" Margin="83,-100,0,0" Height="20" Width="200"
                    HorizontalAlignment="Center" IsEditable="false" VerticalAlignment="Center"/>
        </Grid>
      </Border>
      <Border Grid.Column="1">
        <Grid Name="AppendStringTabAutoDimensionEDrawing" Visibility="Hidden">
          <Grid.RowDefinitions>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="2.5*"/>
          </Grid.RowDefinitions>
          <TextBlock HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,5,0,0" Padding="5,0,10,0"
                     TextWrapping="Wrap" TextAlignment="Justify">
            Move your cursor to the desired Append String location. Define the desired parameter from the dropdown. Select the + button to add the new parameter definition at your cursor's current location.
          </TextBlock>
          <TextBlock FontWeight="DemiBold" HorizontalAlignment="Left" Margin="28,10,0,0" VerticalAlignment="Center"
                     Grid.Row="0">Append String</TextBlock>
          <RichTextBox DataObject.Pasting="AppendStringTextBox_Pasting"
                       PreviewTextInput="AppendStringTextBox_PreviewTextInput"
                       TextChanged="AppendStringTextBoxAutoDimensionEDrawing_TextChanged"
                       Name="AppendStringTextBoxAutoDimensionEDrawing" Width="200" Height="35"
                       VerticalScrollBarVisibility="Auto" HorizontalAlignment="Center" VerticalAlignment="Center"
                       Margin="80,13,5,0" Grid.Row="0"/>
          <TextBlock FontWeight="DemiBold" HorizontalAlignment="Left" Margin="28,90,0,0" VerticalAlignment="Center"
                     Grid.Row="0">Example Result</TextBlock>
          <TextBox Name="ExampleResultTextBoxAutoDimensionEDrawing" Foreground="Gray" IsReadOnly="true"
                   TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Auto" Width="200" Height="35"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="80,95,5,0" Grid.Row="0"/>
          <Border BorderThickness="2" BorderBrush="Black" Width="325" Margin="0,00,0,0" Height="115" Grid.Row="1">
            <Grid Name="ParameterDefinitionBockAutoDimensionEDrawing" Visibility="Visible">
              <TextBlock FontWeight="DemiBold" HorizontalAlignment="Center" VerticalAlignment="Top" Foreground="Black"
                         Margin="0,3,0,0">
                Parameter Definition
              </TextBlock>
              <ComboBox SelectionChanged="ParameterValuesList_SelectionChanged"
                        Name="ParameterValuesListAutoDimensionEDrawing" FontWeight="DemiBold" Width="200" Height="20"
                        HorizontalAlignment="Left" VerticalAlignment="Top" Margin="30,26,0,0"/>
              <Button Click="AddButton_Click" Name="AddButtonAutoDimensionEDrawing" FontWeight="DemiBold" Height="20"
                      Width="60" Padding="0,-3,0,0" VerticalAlignment="Top" HorizontalAlignment="Right"
                      Margin="0,26,30,0" Foreground="Blue" FontSize="13"/>
              <TextBlock FontWeight="DemiBold" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="30,20,0,0">Prefix</TextBlock>
              <TextBox DataObject.Pasting="AppendStringTextBox_Pasting"
                       PreviewTextInput="AppendStringTextBox_PreviewTextInput" TextChanged="PrePostTextBox_TextChanged"
                       x:Name="PrefixTextBoxAutoDimensionEDrawing" FontWeight="DemiBold" Height="20" Width="40"
                       HorizontalAlignment="Left" VerticalAlignment="Center" Margin="63,20,0,0"/>
              <TextBlock FontWeight="DemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20,75,0">Suffix</TextBlock>
              <TextBox DataObject.Pasting="AppendStringTextBox_Pasting"
                       PreviewTextInput="AppendStringTextBox_PreviewTextInput" TextChanged="PrePostTextBox_TextChanged"
                       x:Name="SuffixTextBoxAutoDimensionEDrawing" FontWeight="DemiBold" Height="20" Width="40"
                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20,0,0"/>
              <TextBlock FontWeight="DemiBold" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,20,102,0">Result</TextBlock>
              <TextBox x:Name="ResultTextBoxAutoDimensionEDrawing" FontWeight="DemiBold" Height="20" Width="69"
                       HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,20,30,0" IsEnabled="false"/>
              <TextBlock Name="ApplicableTextAutoDimensionEDrawing" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                         Foreground="Gray" Margin="0,0,35,15" FontWeight="DemiBold" FontSize="11" Visibility="Hidden">
                *This field will only appear when applicable
              </TextBlock>
            </Grid>
          </Border>
        </Grid>
      </Border>
      <Border Name="CloneTicketTab" Grid.Column="0" Visibility="Hidden">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="7*"/>
            <RowDefinition Height="3*"/>
          </Grid.RowDefinitions>
          <ListBox SelectionChanged="Setting_SelectedTicketGeneration" Name="SettingCloneTicket">
            <ItemsControl.ItemContainerStyle>
              <Style>
                <Setter Property="Control.Padding" Value="0"/>
                <Style.Triggers>
                  <Trigger Property="ListBoxItem.IsSelected" Value="true">
                    <Setter Property="Control.Background" Value="LightSteelBlue"/>
                  </Trigger>
                </Style.Triggers>
              </Style>
            </ItemsControl.ItemContainerStyle>
            <ListBoxItem Margin="5" FontWeight="DemiBold" HorizontalAlignment="Left" Height="25" Width="169">
              Same Point Tolerance
            </ListBoxItem>
          </ListBox>
        </Grid>
      </Border>
      <Border Grid.Column="1">
        <Grid x:Name="SamePointToleranceTabCloneTicket" Visibility="Hidden">
          <TextBlock HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,5,0,0">
            Set the desired tolerance for location matching
          </TextBlock>
          <TextBlock FontWeight="DemiBold" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,40,0,0">
            Same Point Tolerance
          </TextBlock>
          <TextBox Name="SamePointToleranceFeetTextBox" Width="70" Height="20" HorizontalAlignment="Center"
                   VerticalAlignment="Top" HorizontalContentAlignment="Right" Margin="20,40,80,0"/>
          <TextBlock Name="SamePointToleranceFeetLabel" HorizontalAlignment="Center" VerticalAlignment="Top"
                     Margin="108,40,80,0">ft</TextBlock>
          <TextBox Name="SamePointToleranceInchTextBox" Width="70" Height="20" HorizontalAlignment="Center"
                   VerticalAlignment="Top" HorizontalContentAlignment="Right" Margin="190,40,70,0"/>
          <TextBlock Name="SamePointToleranceInchLabel" HorizontalAlignment="Center" VerticalAlignment="Top"
                     Margin="275,40,70,0">in</TextBlock>
        </Grid>
      </Border>
      <Border Name="HardwareDetailTab" Grid.Column="0" Visibility="Hidden">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="7*"/>
            <RowDefinition Height="3*"/>
          </Grid.RowDefinitions>
          <ListBox SelectionChanged="Setting_SelectedTicketGeneration" Name="SettingHardwareDetail">
            <ItemsControl.ItemContainerStyle>
              <Style>
                <Setter Property="Control.Padding" Value="0"/>
                <Style.Triggers>
                  <Trigger Property="ListBoxItem.IsSelected" Value="true">
                    <Setter Property="Control.Background" Value="LightSteelBlue"/>
                  </Trigger>
                </Style.Triggers>
              </Style>
            </ItemsControl.ItemContainerStyle>
            <ListBoxItem Margin="5" FontWeight="DemiBold" HorizontalAlignment="Left" Height="25" Width="169">
              Callout, Text, and Dimensions
            </ListBoxItem>
            <ListBoxItem Margin="5" FontWeight="DemiBold" HorizontalAlignment="Left" Height="25" Width="115">Append String</ListBoxItem>
            <ListBoxItem Margin="5" FontWeight="DemiBold" HorizontalAlignment="Left" Height="25" Width="169">
              Minimum Dimension Value
            </ListBoxItem>
          </ListBox>
        </Grid>
      </Border>
      <Border Grid.Column="1">
        <Grid Name="StyleTabHardwareDetail" Visibility="Hidden">
          <TextBlock HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,5,0,0">
            Select the desired families for Callouts and Text
          </TextBlock>
          <TextBlock FontWeight="DemiBold" HorizontalAlignment="Left" Margin="8,40,0,0" VerticalAlignment="Top">Callout Family</TextBlock>
          <ComboBox Name="CalloutStyleComboBoxHardwareDetail" Margin="83,40,0,0" Height="20" Width="200"
                    IsEditable="false" HorizontalAlignment="Center" VerticalAlignment="Top"/>
          <TextBlock FontWeight="DemiBold" HorizontalAlignment="Left" Margin="8,-115,0,0" VerticalAlignment="Center">
            Overall Dimension Style
          </TextBlock>
          <ComboBox Name="DimensionStyleComboBoxHardwareDetail" Margin="83,-115,0,0" Height="20" Width="200"
                    IsEditable="false" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          <TextBlock FontWeight="DemiBold" HorizontalAlignment="Left" Margin="8,-35,0,0" VerticalAlignment="Center">General Dimension</TextBlock>
          <ComboBox Name="OtherDimensionStyleComboBoxHardwareDetail" Margin="83,-35,0,0" Height="20" Width="200"
                    IsEditable="false" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          <TextBlock FontWeight="DemiBold" HorizontalAlignment="Left" Margin="8,0,0,95" VerticalAlignment="Bottom">Text Style</TextBlock>
          <ComboBox Name="TextStyleComboBoxHardwareDetail" Margin="83,0,0,95" VerticalAlignment="Bottom" Height="20"
                    Width="200" HorizontalAlignment="Center" IsEditable="false"/>
          <CheckBox Name="CheckBoxEqualityFormulaHardwareDetail" Margin="12,0,0,125" HorizontalAlignment="Center"
                    VerticalAlignment="Bottom" IsChecked="True">
            Use Equality Formula
          </CheckBox>
        </Grid>
      </Border>
      <Border Grid.Column="1">
        <Grid Name="MinDimTabHardwareDetail" Visibility="Hidden">
          <TextBlock HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,5,0,0">
            Set the desired minimum spacing for elements in a dimension string
          </TextBlock>
          <TextBlock FontWeight="DemiBold" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="38,40,0,0">Dimension</TextBlock>
          <TextBox Name="MinDimFeetTextBoxHardwareDetail" Width="70" Height="20" HorizontalAlignment="Center"
                   VerticalAlignment="Top" HorizontalContentAlignment="Right" Margin="0,40,80,0"/>
          <TextBlock Name="MinDimFeetLabelHardwareDetail" HorizontalAlignment="Center" VerticalAlignment="Top"
                     Margin="88,40,80,0">ft</TextBlock>
          <TextBox Name="MinDimInchTextBoxHardwareDetail" Width="70" Height="20" HorizontalAlignment="Center"
                   VerticalAlignment="Top" HorizontalContentAlignment="Right" Margin="170,40,70,0"/>
          <TextBlock Name="MinDimInchLabelHardwareDetail" HorizontalAlignment="Center" VerticalAlignment="Top"
                     Margin="255,40,70,0">in</TextBlock>
        </Grid>
      </Border>
      <Border Grid.Column="1">
        <Grid Name="AppendStringTabHardwareDetail" Visibility="Hidden">
          <Grid.RowDefinitions>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="2.5*"/>
          </Grid.RowDefinitions>
          <TextBlock HorizontalAlignment="Center" Padding="5,0,10,0" VerticalAlignment="Top" Margin="0,5,0,0"
                     TextWrapping="Wrap" TextAlignment="Justify">
            Move your cursor to the desired Append String location. Define the desired parameter from the dropdown. Select the + button to add the new parameter definition at your cursor's current location.
          </TextBlock>
          <TextBlock FontWeight="DemiBold" HorizontalAlignment="Left" Margin="28,10,0,0" VerticalAlignment="Center"
                     Grid.Row="0">Append String</TextBlock>
          <RichTextBox DataObject.Pasting="AppendStringTextBox_Pasting"
                       PreviewTextInput="AppendStringTextBox_PreviewTextInput"
                       TextChanged="AppendStringTextBoxHardwareDetail_TextChanged"
                       Name="AppendStringTextBoxHardwareDetail" Width="200" Height="35" HorizontalAlignment="Center"
                       VerticalAlignment="Center" Margin="80,13,5,0" Grid.Row="0" VerticalScrollBarVisibility="Auto"/>
          <TextBlock FontWeight="DemiBold" HorizontalAlignment="Left" Margin="28,90,0,0" VerticalAlignment="Center"
                     Grid.Row="0">Example Result</TextBlock>
          <TextBox Name="ExampleResultTextBoxHardwareDetail" Foreground="Gray" IsReadOnly="true" TextWrapping="Wrap"
                   ScrollViewer.VerticalScrollBarVisibility="Auto" Width="200" Height="35"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="80,95,5,0" Grid.Row="0"
                   AcceptsReturn="false"/>
          <Border BorderThickness="2" BorderBrush="Black" Width="325" Margin="0,0,0,0" Height="115" Grid.Row="1">
            <Grid Name="ParameterDefinitionBlockHardwareDetail" Visibility="Hidden">
              <TextBlock FontWeight="DemiBold" HorizontalAlignment="Center" VerticalAlignment="Top" Foreground="Black"
                         Margin="0,3,0,0">
                Parameter Definition
              </TextBlock>
              <ComboBox SelectionChanged="ParameterValuesList_SelectionChanged" Name="ParameterValuesListHardwareDetail"
                        FontWeight="DemiBold" Width="200" Height="20" HorizontalAlignment="Left" VerticalAlignment="Top"
                        Margin="30,26,0,0"/>
              <Button Click="AddButton_Click" Name="AddButtonHardwareDetail" FontWeight="DemiBold" Height="20" Width="60"
                      Padding="0,-3,0,0" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,26,30,0"
                      Foreground="Blue" FontSize="13"/>
              <TextBlock FontWeight="DemiBold" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="30,20,0,0">Prefix</TextBlock>
              <TextBox DataObject.Pasting="AppendStringTextBox_Pasting"
                       PreviewTextInput="AppendStringTextBox_PreviewTextInput" TextChanged="PrePostTextBox_TextChanged"
                       x:Name="PrefixTextBoxHardwareDetail" FontWeight="DemiBold" Height="20" Width="40"
                       HorizontalAlignment="Left" VerticalAlignment="Center" Margin="63,20,0,0"/>
              <TextBlock FontWeight="DemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20,75,0">Suffix</TextBlock>
              <TextBox DataObject.Pasting="AppendStringTextBox_Pasting"
                       PreviewTextInput="AppendStringTextBox_PreviewTextInput" TextChanged="PrePostTextBox_TextChanged"
                       x:Name="SuffixTextBoxHardwareDetail" FontWeight="DemiBold" Height="20" Width="40"
                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20,0,0"/>
              <TextBlock FontWeight="DemiBold" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,20,102,0">Result</TextBlock>
              <TextBox x:Name="ResultTextBoxHardwareDetail" FontWeight="DemiBold" Height="20" Width="69"
                       HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,20,30,0" IsEnabled="false"/>
              <TextBlock Name="ApplicableTextHardwareDetail" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                         Foreground="Gray" Margin="0,0,35,15" FontWeight="DemiBold" FontSize="11" Visibility="Hidden">
                *This field will only appear when applicable
              </TextBlock>
            </Grid>
          </Border>
        </Grid>
      </Border>
    </Grid>
    <Button Click="okayButton_Click" x:Name="okayButton" Width="91" FontWeight="DemiBold" Height="25"
            Margin="10,0,0,10" BorderBrush="Black" Visibility="Visible" HorizontalAlignment="Left"
            VerticalAlignment="Bottom" Grid.Column="0" Grid.Row="2">Apply Settings</Button>
  </Grid>
</Window>