<Window x:Class="EDGE.TicketTools.CopyTicketAnnotation.Message"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:EDGE.TicketTools.CopyTicketAnnotation"
        Height="270" Width="455" Title="Message" MinHeight="200" MinWidth="300"
        WindowStartupLocation="CenterScreen">
  <ScrollViewer HorizontalScrollBarVisibility="Visible">
    <Grid>
      <FrameworkElement.Resources>
        <Style TargetType="{x:Type Panel}">
          <Setter Property="FrameworkElement.Margin" Value="0,0,0,6"/>
        </Style>
      </FrameworkElement.Resources>
      <TextBox Name="MessageBox" Margin="5" IsReadOnly="true"/>
    </Grid>
  </ScrollViewer>
</Window>