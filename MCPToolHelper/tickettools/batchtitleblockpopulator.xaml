<Window x:Class="EDGE.TicketTools.BatchTitleBlockPopulator"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:EDGE.TicketTools"
        MouseDown="Window_MouseDown" Height="380" Width="300" Background="LightGray"
        ResizeMode="CanMinimize" WindowStyle="None">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="15"/>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="15"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="10"/>
      <RowDefinition Height="55"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="40"/>
      <RowDefinition Height="15"/>
    </Grid.RowDefinitions>
    <Label Name="TitleLabel" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Top"
           FontSize="16">
      Batch Ticket Title Block Populator
    </Label>
    <Label Name="InstructionLabel" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Left"
           VerticalAlignment="Bottom" FontSize="12" Margin="0,0,0,0">
      Select assemblies or assembly sheets to update:
    </Label>
    <TreeView x:Name="treeView" Grid.Column="1" Grid.Row="2" TabIndex="0"
              ItemsSource="{Binding Path=ItemsList, Mode=TwoWay}">
      <FrameworkElement.Resources>
        <HierarchicalDataTemplate x:Key="{DataTemplateKey {x:Type local:ParentClass}}" DataType="{x:Type local:ParentClass}"
                                  ItemsSource="{Binding Members}">
          <CheckBox Content="{Binding Name}" IsChecked="{Binding checkedItemBoolParent}">
            <FrameworkElement.Style>
              <Style TargetType="{x:Type CheckBox}"/>
            </FrameworkElement.Style>
          </CheckBox>
        </HierarchicalDataTemplate>
        <HierarchicalDataTemplate x:Key="{DataTemplateKey {x:Type local:HierarchyCheckBoxItems}}"
                                  DataType="{x:Type local:HierarchyCheckBoxItems}" ItemsSource="{Binding Members}">
          <CheckBox Content="{Binding AssemblyName}" IsChecked="{Binding CheckedItemBool}">
            <FrameworkElement.Style>
              <Style TargetType="{x:Type CheckBox}"/>
            </FrameworkElement.Style>
          </CheckBox>
        </HierarchicalDataTemplate>
        <DataTemplate DataType="{x:Type local:Sheets}">
          <CheckBox Content="{Binding SheetName}" IsChecked="{Binding CheckedSheetBool}">
            <FrameworkElement.Style>
              <Style TargetType="{x:Type CheckBox}"/>
            </FrameworkElement.Style>
          </CheckBox>
        </DataTemplate>
      </FrameworkElement.Resources>
      <ItemsControl.ItemContainerStyle>
        <Style TargetType="{x:Type TreeViewItem}">
          <Setter Property="TreeViewItem.IsExpanded" Value="{Binding ExpandedBool, Mode=TwoWay}"/>
        </Style>
      </ItemsControl.ItemContainerStyle>
    </TreeView>
    <Grid Column="1" Row="3">
      <Grid.ColumnDefinitions>
        <ColumnDefinition/>
        <ColumnDefinition/>
      </Grid.ColumnDefinitions>
      <Button Click="ContinueButton_Click" Name="ContinueButton" Content="Continue" Grid.Column="0"
              HorizontalAlignment="Right" Margin="0,0,5,0" Height="25" Width="120" TabIndex="1"/>
      <Button Click="CancelButton_Click" Name="CancelButton" Content="Cancel" Grid.Column="1"
              HorizontalAlignment="Left" Margin="5,0,0,0" Height="25" Width="120" TabIndex="2"/>
    </Grid>
  </Grid>
</Window>