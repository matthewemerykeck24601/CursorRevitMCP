<Window x:Class="EDGE.TicketTools.TicketManager.Views.CustomizeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:viewModels="clr-namespace:EDGE.TicketTools.TicketManager.ViewModels"
        Height="505.794" MinHeight="300" MaxHeight="575" MaxWidth="900" WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight" Width="498.787" Title="{Binding WindowTitle}">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="10"/>
      <ColumnDefinition Width="*" MaxWidth="980"/>
      <ColumnDefinition Width="10"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="10"/>
      <RowDefinition Height="27"/>
      <RowDefinition Height="*" MaxHeight="390"/>
      <RowDefinition Height="22"/>
      <RowDefinition Height="10"/>
    </Grid.RowDefinitions>
    <Label x:Name="DataGridTitle" Grid.Row="1" Grid.Column="1" FontWeight="Bold" VerticalAlignment="Center"
           HorizontalAlignment="Center" Content="{Binding DataGridLabel}"/>
    <Button Click="ConfirmButton_Click" x:Name="confirmButton" Grid.Row="3" Grid.Column="1" Width="75"
            HorizontalAlignment="Left" Content="Save" Margin="0.4,0.4,0,10.2" Grid.RowSpan="2"
            CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}"/>
    <Button Click="CancelButton_Click" Grid.Row="3" Grid.Column="1" Width="75" HorizontalAlignment="Right"
            Content="Cancel" Margin="0,0.4,0.4,10.2" Grid.RowSpan="2"
            CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}"/>
    <Label x:Name="label"
           Content="Please enter a column name and select a parameter to add to the Ticket Manager:"
           Grid.Column="1" HorizontalAlignment="Left" Margin="0.4,0.4,0,0" Grid.Row="1"
           VerticalAlignment="Top"/>
    <TextBox x:Name="parameterTextBox1" TabIndex="2" Grid.Column="1" HorizontalAlignment="Left" Height="23"
             Margin="10.4,27.2,0,0" Grid.Row="2" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="452"/>
    <TextBox x:Name="parameterTextBox2" TabIndex="5" Grid.Column="1" HorizontalAlignment="Left" Height="23"
             Margin="10.4,110.2,0,0" Grid.Row="2" TextWrapping="Wrap" Text="" VerticalAlignment="Top"
             Width="452"/>
    <TextBox x:Name="parameterTextBox3" TabIndex="8" Grid.Column="1" HorizontalAlignment="Left" Height="23"
             Margin="10.4,191.6,0,0" Grid.Row="2" TextWrapping="Wrap" Text="" VerticalAlignment="Top"
             Width="452"/>
    <TextBox x:Name="parameterTextBox4" TabIndex="11" Grid.Column="1" HorizontalAlignment="Left" Height="23"
             Margin="10.4,272.6,0,0" Grid.Row="2" TextWrapping="Wrap" Text="" VerticalAlignment="Top"
             Width="452"/>
    <ComboBox x:Name="parameterComboBox1" TabIndex="3" Grid.Column="1" HorizontalAlignment="Left"
              Margin="10.4,55.6,0,0" Grid.Row="2" VerticalAlignment="Top" Width="368" IsEditable="false"/>
    <ComboBox x:Name="parameterComboBox2" TabIndex="6" Grid.Column="1" HorizontalAlignment="Left"
              Margin="10.4,138.6,0,0" Grid.Row="2" VerticalAlignment="Top" Width="368" IsEditable="false"/>
    <ComboBox x:Name="parameterComboBox3" TabIndex="9" Grid.Column="1" HorizontalAlignment="Left"
              Margin="10.4,219.6,0,0" Grid.Row="2" VerticalAlignment="Top" Width="368" IsEditable="false"/>
    <ComboBox x:Name="parameterComboBox4" TabIndex="12" Grid.Column="1" HorizontalAlignment="Left"
              Margin="10.4,300.6,0,0" Grid.Row="2" VerticalAlignment="Top" Width="368" IsEditable="false"/>
    <Label x:Name="label1" Content="" Grid.Column="1" HorizontalContentAlignment="Left"
           HorizontalAlignment="Left" Margin="10.4,336.6,0,0" Grid.Row="2" VerticalAlignment="Top" Width="452"/>
    <Label x:Name="label2" Content="Custom Column 1" HorizontalContentAlignment="Left" Grid.Column="1"
           HorizontalAlignment="Left" Margin="3.4,2.6,0,0" Grid.Row="2" VerticalAlignment="Top"
           RenderTransformOrigin="-0.737,-0.287"/>
    <Label x:Name="label2_Copy" Content="Custom Column 2" Grid.Column="1" HorizontalAlignment="Left"
           Margin="3.4,84.6,0,0" Grid.Row="2" VerticalAlignment="Top" RenderTransformOrigin="-0.737,-0.287"/>
    <Label x:Name="label2_Copy1" Content="Custom Column 3" Grid.Column="1" HorizontalAlignment="Left"
           Margin="3.4,165.6,0,0" Grid.Row="2" VerticalAlignment="Top" RenderTransformOrigin="-0.737,-0.287"/>
    <Label x:Name="label2_Copy2" Content="Custom Column 4" Grid.Column="1" HorizontalAlignment="Left"
           Margin="3.4,246.6,0,0" Grid.Row="2" VerticalAlignment="Top" RenderTransformOrigin="-0.737,-0.287"
           Width="106"/>
    <Label x:Name="label2_Copy3" Content="Enter one or more Custom Parameters to continue" Foreground="Red"
           Visibility="Hidden" Grid.Column="1" HorizontalAlignment="Left" Margin="189.4,2.6,0,0" Grid.Row="2"
           VerticalAlignment="Top" RenderTransformOrigin="-0.737,-0.287"/>
    <Label x:Name="label2_Copy4" Content="Duplicate Custom Parameters are not allowed" Foreground="Red"
           Visibility="Hidden" Grid.Column="1" HorizontalAlignment="Left" Margin="10.4,336.6,0,0" Grid.Row="2"
           VerticalAlignment="Top" RenderTransformOrigin="-0.737,-0.287"/>
    <Label x:Name="label2_Copy5"
           Content="Enter Custom Parameter name or clear Custom Parameter for one or more Custom Parameters to Continue"
           Foreground="Red" Visibility="Hidden" Grid.Column="1" HorizontalAlignment="Left"
           Margin="10.4,336.6,0,0" Grid.Row="2" VerticalAlignment="Top" RenderTransformOrigin="-0.737,-0.287"/>
    <Button Click="ResetButton_Click" x:Name="masterResetButton" Grid.Row="3" Grid.Column="1" Width="75"
            HorizontalAlignment="Left" Content="Clear All" Margin="80.4,0.4,0,10.2" Grid.RowSpan="2"
            CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}"/>
    <Button Click="ResetButton4_Click" x:Name="resetButton4" Grid.Row="2" Grid.Column="1" Width="79"
            HorizontalAlignment="Left" Content="Clear" Margin="383.4,300.6,0,68.6"
            CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}"/>
    <Button Click="ResetButton3_Click" x:Name="resetButton3" Grid.Row="2" Grid.Column="1" Width="79"
            HorizontalAlignment="Left" Content="Clear" Margin="383.4,219.6,0,149.6"
            CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}"/>
    <Button Click="ResetButton2_Click" x:Name="resetButton2" Grid.Row="2" Grid.Column="1" Width="79"
            HorizontalAlignment="Left" Content="Clear" Margin="383.4,138.6,0,230.6"
            CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}"/>
    <Button Click="ResetButton1_Click" x:Name="resetButton1" Grid.Row="2" Grid.Column="1" Width="79"
            HorizontalAlignment="Left" Content="Clear" Margin="383.4,55.6,0,312.6"
            CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}"/>
    <Button Click="ResetFileButton_Click" x:Name="resetFileButton" Grid.Row="3" Grid.Column="1" Width="75"
            HorizontalAlignment="Left" Content="Reset File" Margin="160.4,0.4,0,10.2" Grid.RowSpan="2"
            RenderTransformOrigin="1.451,0.574"
            CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}}"/>
  </Grid>
</Window>