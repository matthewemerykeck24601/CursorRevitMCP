<Window x:Class="EDGE.__Testing.BulkFamilyUpdater.Views.BFUSelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:EDGE.__Testing.BulkFamilyUpdater.Views"
        Height="450" Width="350" ResizeMode="NoResize" Background="LightGray">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="0.1*"/>
      <ColumnDefinition/>
      <ColumnDefinition Width="0.1*"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height=".25*"/>
      <RowDefinition x:Name="parameterGroupRow" Height=".4*"/>
      <RowDefinition Height="2*"/>
      <RowDefinition Height="0.4*"/>
    </Grid.RowDefinitions>
    <Label x:Name="headerLabel" Grid.Column="1" Grid.Row="0" Margin="-4,0,0,0" Content="Choose a Parameter:"
           VerticalAlignment="Center"/>
    <Grid x:Name="parameterGroupGrid" Column="1" Row="1">
      <Label x:Name="parameterGroupLabel" Margin="-4,0,0,0" Content="Parameter Group:"/>
      <ComboBox SelectionChanged="parameterGroupComboBox_SelectionChanged" x:Name="parameterGroupComboBox"
                Height="20" Margin="0,15,0,0" TabIndex="0" SelectedValuePath="ValueString"
                DisplayMemberPath="ValueString" ItemsSource="{Binding ParameterGroupsList}"
                SelectedValue="{Binding SelectedParameterGroup}"/>
    </Grid>
    <Grid Column="1" Row="2">
      <Grid.RowDefinitions>
        <RowDefinition x:Name="parametersLabelGrid" Height="0.1*"/>
        <RowDefinition/>
      </Grid.RowDefinitions>
      <Label x:Name="parametersLabel" Margin="-4,0,0,0" Grid.Row="0" Content="Parameters:"/>
      <ListBox SelectionChanged="parametersListBox_SelectionChanged" x:Name="parametersListBox" Grid.Row="1"
               TabIndex="1" ItemsSource="{Binding ParametersList, UpdateSourceTrigger=PropertyChanged}"
               SelectedItem="{Binding SelectedParameter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
    </Grid>
    <Grid Column="1" Row="3">
      <Grid.ColumnDefinitions>
        <ColumnDefinition/>
        <ColumnDefinition/>
      </Grid.ColumnDefinitions>
      <Button Click="oKButton_Click" x:Name="oKButton" Grid.Column="0" TabIndex="2" Content="OK" Height="30"
              Margin="0,0,5,0" IsEnabled="false"/>
      <Button Click="cancelButton_Click" x:Name="cancelButton" Grid.Column="1" TabIndex="3" Content="Cancel"
              Height="30" Margin="5,0,0,0"/>
    </Grid>
  </Grid>
</Window>